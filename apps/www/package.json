{
  "name": "@shelkovo/www",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && rm -rf ../../dist/www && mkdir -p ../../dist && cp -R dist/site ../../dist/www",
    "preview": "astro preview",
    "typecheck": "astro sync && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual:status": "playwright test -c playwright.status-visual.local.config.ts",
    "test:visual:status:update": "playwright test -c playwright.status-visual.local.config.ts --update-snapshots",
    "test:visual:status:serve": "astro build --root tests/status-timeline-visual && astro preview --root tests/status-timeline-visual --host 127.0.0.1 --port 4324",
    "test:visual:news-event": "playwright test -c playwright.news-event-card-visual.local.config.ts",
    "test:visual:news-event:update": "playwright test -c playwright.news-event-card-visual.local.config.ts --update-snapshots",
    "test:visual:news-event:serve": "astro build --root tests/news-event-card-visual && astro preview --root tests/news-event-card-visual --host 127.0.0.1 --port 4327",
    "test:visual:sticky-table": "playwright test -c playwright.sticky-table-visual.local.config.ts",
    "test:visual:sticky-table:update": "playwright test -c playwright.sticky-table-visual.local.config.ts --update-snapshots",
    "test:visual:sticky-table:serve": "astro build --root tests/sticky-table-visual && astro preview --root tests/sticky-table-visual --host 127.0.0.1 --port 4329"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@shelkovo/format": "workspace:*",
    "@shelkovo/geo": "workspace:*",
    "@shelkovo/markdown": "workspace:*",
    "@shelkovo/seo": "workspace:*",
    "@shelkovo/ui": "workspace:*",
    "@shelkovo/url": "workspace:*",
    "astro": "^7.0.6",
    "diff": "^9.0.0",
    "svelte": "^5.56.4",
    "vcard-creator": "^1.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/svelte": "^5.4.2",
    "@yandex/ymaps3-types": "^1.0.20297024",
    "astro-compressor": "^1.3.0",
    "happy-dom": "^20.10.6",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "unified": "^11.0.5",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
