---
import type { GetStaticPaths } from 'astro';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';

import ContactMethods from '@/components/contacts/ContactMethods.astro';
import ContactReviews from '@/components/contacts/ContactReviews.astro';
import ContactVcfLink from '@/components/contacts/ContactVcfLink.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { loadContactDetail, loadContactDetails } from '@/lib/contacts/load';
import { contactCategoryUrl, contactsUrl } from '@/lib/contacts/routes';
import { contactPageSchema } from '@/lib/contacts/seo';
import { CONTACTS_PROSE, formatContactCategory } from '@/lib/contacts/view';
import { renderMarkdown } from '@/lib/markdown/render';

export const getStaticPaths = (async () => {
  const contacts = await loadContactDetails();

  return contacts.map((contact) => ({
    params: { category: contact.category, slug: contact.slug },
  }));
}) satisfies GetStaticPaths;

const categoryKey = Astro.params.category;
const slug = Astro.params.slug;

if (!categoryKey || !slug) {
  throw new Error('contact category and slug are required');
}

const contact = await loadContactDetail(categoryKey, slug);

if (!contact) {
  throw new Error(`contact "${categoryKey}/${slug}" not found`);
}

const category = formatContactCategory(contact.category);
const title = `${contact.title} — ${category} — Сарафан — Шелково Онлайн`;
const description =
  contact.seo?.description ??
  `Контакт из раздела «Сарафан»: ${category}. Перед обращением уточняйте цену, сроки и состав работ.`;
const bodyHtml = renderMarkdown(contact.body);
const categoryUrl = contactCategoryUrl({ category: contact.category });
const reviewsHeadingId = 'contact-reviews';
const breadcrumbs = withHomeBreadcrumbs([
  { label: 'Сарафан', href: contactsUrl() },
  { label: category, href: categoryUrl },
  { label: contact.title },
]);
const schema = contactPageSchema({
  contact,
  description,
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Сарафан', url: contactsUrl() },
    { name: category, url: categoryUrl },
    { name: contact.title, url: contact.url },
  ]),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={contact.url}
  keywords={['сарафан Шелково', contact.title, category]}
  schema={schema}
>
  <main class="ui-page pb-8 md:pb-12 lg:pb-14">
    <header class="ui-page-header">
      <div class="ui-page-header-stack max-w-4xl">
        <Breadcrumbs items={breadcrumbs} linkLast />

        <div class="flex items-center gap-5 md:gap-7">
          <h1 class="ui-page-title">{contact.title}</h1>
          {
            contact.vcf ? (
              <span class="inline-flex translate-y-1 md:translate-y-1.5">
                <ContactVcfLink vcf={contact.vcf} />
              </span>
            ) : null
          }
        </div>
      </div>
    </header>

    <article class="space-y-8 px-5 md:px-6">
      <ContactMethods contacts={contact.contacts} location={contact.location} />
      <div class={CONTACTS_PROSE} set:html={bodyHtml} />
      {
        contact.reviews.length > 0 ? (
          <section class="max-w-[65ch] space-y-3">
            <h2 id={reviewsHeadingId} class="ui-prose-title">
              Отзывы
            </h2>
            <ContactReviews
              reviews={contact.reviews}
              labelledBy={reviewsHeadingId}
            />
          </section>
        ) : null
      }
    </article>
  </main>
</BaseLayout>
