---
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';

import ContactListItem from '@/components/contacts/ContactListItem.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { loadContactsData } from '@/lib/contacts/load';
import { contactsUrl } from '@/lib/contacts/routes';
import { contactsCollectionPageSchema } from '@/lib/contacts/seo';
import {
  CONTACTS_CHAT_LABEL,
  CONTACTS_CHAT_URL,
  CONTACTS_EMPTY_MESSAGE,
  CONTACTS_INTRO_PREFIX,
  CONTACTS_INTRO_SUFFIX,
  CONTACTS_NEIGHBOR_TABLE_LABEL,
  CONTACTS_NEIGHBOR_TABLE_PREFIX,
  CONTACTS_NEIGHBOR_TABLE_SUFFIX,
  CONTACTS_NEIGHBOR_TABLE_URL,
  formatContactCategory,
  formatContactCategoryEmoji,
} from '@/lib/contacts/view';

const data = await loadContactsData();
const title = 'Сарафан — Шелково Онлайн';
const description =
  'Контакты, которыми поделились жители Шелково. Сайт публикует контекст и способы связи, но не гарантирует качество работ.';
const breadcrumbs = withHomeBreadcrumbs([{ label: 'Сарафан' }]);
const schema = contactsCollectionPageSchema({
  name: title,
  description,
  url: contactsUrl(),
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Сарафан', url: contactsUrl() },
  ]),
  items: data.categories.map((category) => ({
    name: formatContactCategory(category.category),
    url: category.url,
  })),
});

const sectionId = (category: string): string => category;
---

<BaseLayout
  title={title}
  description={description}
  canonical={contactsUrl()}
  keywords={['сарафан Шелково', 'контакты Шелково']}
  schema={schema}
>
  <main class="ui-page pb-8 md:pb-12 lg:pb-14">
    <section class="ui-page-header">
      <div class="ui-page-header-stack max-w-4xl">
        <Breadcrumbs items={breadcrumbs} />

        <div>
          <h1 class="ui-page-title">Сарафан</h1>
          <p class="ui-copy mt-3 max-w-3xl text-muted-foreground">
            {CONTACTS_INTRO_PREFIX}<a
              href={CONTACTS_CHAT_URL}
              class="site-text-link">{CONTACTS_CHAT_LABEL}</a
            >{CONTACTS_INTRO_SUFFIX}{CONTACTS_NEIGHBOR_TABLE_PREFIX}<a
              href={CONTACTS_NEIGHBOR_TABLE_URL}
              class="site-text-link">{CONTACTS_NEIGHBOR_TABLE_LABEL}</a
            >{CONTACTS_NEIGHBOR_TABLE_SUFFIX}
          </p>
        </div>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="sr-only">Категории сарафана</h2>
      {
        data.categories.length > 0 ? (
          <div class="mb-8 flex flex-wrap gap-2 px-5 md:px-6">
            {data.categories.map((category) => (
              <a
                href={`#${sectionId(category.category)}`}
                class="rounded-full border border-border bg-card px-3 py-1.5 text-sm font-semibold leading-6 text-foreground transition-colors hover:border-primary hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
              >
                <span aria-hidden="true">
                  {formatContactCategoryEmoji(category.category)}
                </span>{' '}
                {formatContactCategory(category.category)}
              </a>
            ))}
          </div>
        ) : null
      }

      {
        data.categories.length > 0 ? (
          <div class="space-y-10">
            {data.categories.map((category) => {
              const label = formatContactCategory(category.category);

              return (
                <section aria-labelledby={sectionId(category.category)}>
                  <div class="mb-2 px-5 md:px-6">
                    <h2
                      id={sectionId(category.category)}
                      class="ui-group-title"
                    >
                      <a href={category.url} class="ui-link">
                        {label}
                      </a>
                    </h2>
                  </div>

                  <div class="border-t border-border px-5 md:px-6">
                    <div class="grid gap-x-8 md:grid-cols-2">
                      {category.contacts.map((contact) => (
                        <ContactListItem contact={contact} />
                      ))}
                    </div>
                  </div>
                </section>
              );
            })}
          </div>
        ) : (
          <div class="ui-shell px-5 py-6 md:px-6 md:py-7">
            <p class="ui-copy max-w-3xl text-muted-foreground">
              {CONTACTS_EMPTY_MESSAGE}
            </p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
