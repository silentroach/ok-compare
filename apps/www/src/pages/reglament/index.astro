---
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';

import { estimate2026 } from '@/data/reglament/estimate-2026';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { collectionPageSchema } from '@/lib/news/seo';
import { buildReglamentPayload } from '@/lib/reglament/discovery';
import {
  reglamentEstimate2026DataUrl,
  reglamentLlmsUrl,
  reglamentMarkdownUrl,
  reglamentUrl,
} from '@/lib/reglament/routes';
import type { CostBreakdown, EditableFieldKey } from '@/lib/reglament/schema';

export const prerender = true;

const payload = buildReglamentPayload(estimate2026);
const title = 'Смета 2026: калькулятор тарифа — Шелково Онлайн';
const description =
  'Интерактивная версия сметы регламента 2026: тариф за сотку в месяц, секционные таблицы и расчетная база по PDF-источникам.';
const breadcrumbs = withHomeBreadcrumbs([{ label: 'Регламент' }]);
const schema = collectionPageSchema({
  name: title,
  description,
  url: reglamentUrl(),
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Регламент', url: reglamentUrl() },
  ]),
  items: payload.sections.map((section) => ({
    name: section.title,
    url: `${reglamentUrl()}#${section.id}`,
  })),
});

type ReglamentPayload = ReturnType<typeof buildReglamentPayload>;
type SourceRef = ReglamentPayload['source_refs'][number];
type PayloadRow = ReglamentPayload['sections'][number]['rows'][number];
type DisplayValue =
  ReglamentPayload['sections'][number]['rows'][number]['baseline']['base'];
type BasicNumberFieldKey = Extract<
  EditableFieldKey,
  'volume' | 'frequency' | 'rate' | 'fixed_price'
>;
type ExpertNumberFieldKey = Exclude<
  EditableFieldKey,
  'enabled' | BasicNumberFieldKey
>;
type BreakdownFieldKey = keyof CostBreakdown;

interface NumberControl<Key extends EditableFieldKey = BasicNumberFieldKey> {
  readonly key: Key;
  readonly label: string;
  readonly value: number;
  readonly unit?: string;
  readonly min?: number;
  readonly max?: number;
  readonly step: number;
}

const moneyFormatter = new Intl.NumberFormat('ru-RU', {
  maximumFractionDigits: 2,
  minimumFractionDigits: 0,
});

const signedMoneyFormatter = new Intl.NumberFormat('ru-RU', {
  maximumFractionDigits: 2,
  minimumFractionDigits: 0,
  signDisplay: 'exceptZero',
});

const formatNumber = (value: number): string => moneyFormatter.format(value);
const formatMoney = (value: number): string => `${formatNumber(value)} ₽`;
const formatAnnualMoney = (value: number): string =>
  `${formatMoney(value)}/год`;
const formatTariffValue = (value: number): string => `${formatNumber(value)} ₽`;
const formatTariff = (value: number): string =>
  `${formatTariffValue(value)}/сотка`;
const formatTariffDelta = (value: number): string =>
  `${signedMoneyFormatter.format(value)} ₽`;
const formatDisplayValue = (value: DisplayValue): string =>
  value
    ? `${formatNumber(value.value)} ${value.unit}${value.label ? `, ${value.label}` : ''}`
    : 'из сметной строки';
const formatSource = (ref: SourceRef): string =>
  `${ref.pdf}.pdf, стр. ${ref.page}${ref.fragment ? `, ${ref.fragment}` : ''}`;
const breakdownFields = [
  { key: 'primary_salary', label: 'Основная зарплата' },
  { key: 'machinist_salary', label: 'Зарплата машинистов' },
  { key: 'fot', label: 'ФОТ' },
  { key: 'machines', label: 'Машины' },
  { key: 'materials', label: 'Материалы' },
  { key: 'contractors', label: 'Подрядчики' },
  { key: 'insurance', label: 'Страховые' },
  { key: 'overhead', label: 'Накладные' },
  { key: 'profit', label: 'Прибыль' },
  { key: 'usn', label: 'УСН' },
  { key: 'income', label: 'Доходов всего' },
  { key: 'vat', label: 'НДС' },
  { key: 'gross', label: 'Итого с НДС' },
] as const satisfies readonly {
  readonly key: BreakdownFieldKey;
  readonly label: string;
}[];
const expertFieldKeys = [
  'primary_salary',
  'machinist_salary',
  'machines',
  'materials',
  'contractors',
  'insurance_rate',
  'overhead_rate',
  'profit_rate',
  'usn_rate',
  'vat_rate',
] as const satisfies readonly ExpertNumberFieldKey[];
const expertFieldKeySet: ReadonlySet<EditableFieldKey> = new Set(
  expertFieldKeys,
);
const isExpertNumberFieldKey = (
  value: EditableFieldKey,
): value is ExpertNumberFieldKey => expertFieldKeySet.has(value);
const fieldValue = (
  row: PayloadRow,
  key: BasicNumberFieldKey,
): number | undefined => {
  if (key === 'volume') {
    return row.baseline.base?.value;
  }

  if (key === 'frequency') {
    return row.baseline.frequency?.value;
  }

  if (key === 'rate') {
    return row.baseline.price?.value;
  }

  return row.baseline.annual_gross;
};
const fieldUnit = (
  row: PayloadRow,
  key: BasicNumberFieldKey,
  fieldUnitValue?: string,
): string | undefined => {
  if (key === 'volume') {
    return row.baseline.base?.unit;
  }

  if (key === 'frequency') {
    return row.baseline.frequency?.unit;
  }

  if (key === 'rate') {
    return row.baseline.price?.unit;
  }

  return fieldUnitValue;
};
const numberControl = (
  row: PayloadRow,
  key: BasicNumberFieldKey,
): NumberControl<BasicNumberFieldKey> | undefined => {
  const field = row.editable_fields.find(
    (item) => item.key === key && item.level === 'basic',
  );
  const value = fieldValue(row, key);

  if (!field || value === undefined) {
    return undefined;
  }

  return {
    key,
    label: field.label,
    value,
    unit: fieldUnit(row, key, field.unit),
    min: field.min,
    max: field.max,
    step: field.step ?? (Number.isInteger(value) ? 1 : 0.01),
  };
};
const expertFieldValue = (
  row: PayloadRow,
  key: ExpertNumberFieldKey,
): number => {
  if (key === 'insurance_rate') {
    return payload.coefficients.insurance_rate;
  }

  if (key === 'overhead_rate') {
    return payload.coefficients.overhead_rate;
  }

  if (key === 'profit_rate') {
    return payload.coefficients.profit_rate;
  }

  if (key === 'usn_rate') {
    return payload.coefficients.usn_rate;
  }

  if (key === 'vat_rate') {
    return payload.coefficients.vat_rate;
  }

  return row.baseline.breakdown[key];
};
const expertNumberControls = (
  row: PayloadRow,
): readonly NumberControl<ExpertNumberFieldKey>[] =>
  row.editable_fields.flatMap((field) => {
    if (field.level !== 'expert' || !isExpertNumberFieldKey(field.key)) {
      return [];
    }

    const value = expertFieldValue(row, field.key);

    return [
      {
        key: field.key,
        label: field.label,
        value,
        unit: field.unit ?? (field.key.endsWith('_rate') ? 'доля' : '₽/год'),
        min: field.min,
        max: field.max,
        step: field.step ?? (Number.isInteger(value) ? 1 : 0.01),
      },
    ];
  });
const hasEnabledControl = (row: PayloadRow): boolean =>
  row.editable_fields.some(
    (field) => field.key === 'enabled' && field.level === 'basic',
  );
const viewSections = payload.sections.map((section) => ({
  ...section,
  rows: section.rows.map((row) => ({
    ...row,
    controls: {
      enabled: hasEnabledControl(row),
      base: numberControl(row, 'volume'),
      frequency: numberControl(row, 'frequency'),
      rate: numberControl(row, 'rate'),
      fixedPrice: numberControl(row, 'fixed_price'),
      expert: expertNumberControls(row),
    },
  })),
}));
const inputClass =
  'w-full min-w-0 rounded-md border border-border bg-surface px-2 py-1.5 text-sm font-semibold text-foreground outline-none focus:border-primary focus:ring-2 focus:ring-primary/20';
---

<BaseLayout
  title={title}
  description={description}
  canonical={reglamentUrl()}
  keywords={[
    'смета 2026 Шелково',
    'калькулятор тарифа Шелково',
    'регламент Шелково',
  ]}
  schema={schema}
>
  <main class="ui-page pb-8 md:pb-12 lg:pb-16" data-reglament-calculator>
    <section class="px-5 pb-6 pt-3 md:px-6 md:pb-8 md:pt-5 lg:pb-10 lg:pt-6">
      <div class="max-w-5xl space-y-6">
        <Breadcrumbs items={breadcrumbs} />

        <div class="space-y-4">
          <p
            class="text-sm font-semibold uppercase tracking-[0.16em] text-muted-foreground"
          >
            Смета регламента 2026
          </p>
          <h1
            class="max-w-4xl text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
          >
            Калькулятор тарифа по смете 2026
          </h1>
          <p
            class="max-w-3xl text-base leading-7 text-muted-foreground md:text-lg"
          >
            Смета разложена по разделам и строкам. На этом этапе страница
            показывает официальные значения, а главная единица сравнения -
            <span class="font-semibold text-foreground">₽/сотка</span>.
            Расчетный период - месяц.
          </p>
        </div>

        <div
          class="grid overflow-hidden rounded-xl border border-border bg-surface md:grid-cols-3"
          aria-label="Итоги сметы"
        >
          <div
            class="border-b border-border p-4 md:border-b-0 md:border-r md:p-5"
          >
            <p
              class="text-xs font-bold uppercase tracking-[0.12em] text-muted-foreground"
            >
              Официальный тариф
            </p>
            <p class="mt-2 text-2xl font-bold tracking-tight text-foreground">
              {formatTariff(payload.official.tariff_per_sotka_month)}
            </p>
            <p class="mt-1 text-xs text-muted-foreground">
              {formatAnnualMoney(payload.official.annual_gross)}
            </p>
          </div>
          <div
            class="border-b border-border p-4 md:border-b-0 md:border-r md:p-5"
          >
            <p
              class="text-xs font-bold uppercase tracking-[0.12em] text-muted-foreground"
            >
              Текущий расчет
            </p>
            <p
              class="mt-2 text-2xl font-bold tracking-tight text-foreground"
              data-reglament-current-tariff
            >
              {formatTariff(payload.computed.tariff_per_sotka_month)}
            </p>
            <p
              class="mt-1 text-xs text-muted-foreground"
              data-reglament-current-annual
            >
              {formatAnnualMoney(payload.computed.annual_gross)}
            </p>
          </div>
          <div class="p-4 md:p-5">
            <p
              class="text-xs font-bold uppercase tracking-[0.12em] text-muted-foreground"
            >
              Разница
            </p>
            <p
              class="mt-2 text-2xl font-bold tracking-tight text-foreground"
              data-reglament-current-delta
            >
              {formatTariffDelta(payload.computed.delta_tariff_per_sotka_month)}
            </p>
            <p class="mt-1 text-xs text-muted-foreground">
              к официальному тарифу
            </p>
          </div>
        </div>

        <div
          class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-muted-foreground"
        >
          <a class="ui-link text-primary" href={reglamentEstimate2026DataUrl()}>
            JSON-данные
          </a>
          <a class="ui-link text-primary" href={reglamentMarkdownUrl()}>
            Markdown companion
          </a>
          <a class="ui-link text-primary" href={reglamentLlmsUrl()}>
            llms.txt
          </a>
        </div>
      </div>
    </section>

    <div
      class="sticky top-0 z-20 border-y border-border bg-surface px-3 py-1 md:px-6"
    >
      <div
        class="flex h-9 max-w-5xl items-center gap-2 overflow-hidden whitespace-nowrap text-xs text-muted-foreground sm:gap-3 md:text-sm"
      >
        <span class="hidden shrink-0 sm:inline">
          {formatTariff(payload.official.tariff_per_sotka_month)} -&gt;
        </span>
        <strong
          class="min-w-0 flex-1 truncate text-sm text-foreground sm:flex-none md:text-base"
          data-reglament-current-tariff
        >
          {formatTariff(payload.computed.tariff_per_sotka_month)}
        </strong>
        <span class="shrink-0 font-semibold" data-reglament-current-delta>
          {formatTariffDelta(payload.computed.delta_tariff_per_sotka_month)}
        </span>
        <button
          class="ml-auto shrink-0 rounded-full border border-border-strong bg-surface px-2.5 py-0.5 text-xs font-bold text-primary hover:border-primary hover:bg-muted md:px-3 md:text-sm"
          type="button"
          data-reglament-reset
        >
          <span class="hidden sm:inline">Сбросить</span><span class="sm:hidden"
            >Сброс</span
          >
        </button>
      </div>
    </div>

    <section class="px-5 md:px-6" aria-labelledby="estimate-sections-title">
      <div class="max-w-6xl space-y-10">
        <div class="max-w-3xl space-y-2">
          <h2
            id="estimate-sections-title"
            class="text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]"
          >
            Разделы сметы
          </h2>
          <p
            class="text-sm leading-6 text-muted-foreground md:text-base md:leading-7"
          >
            Годовые суммы оставлены в итогах и источниках для проверки, но в
            строках главным числом показан вклад позиции в тариф.
          </p>
        </div>

        {
          viewSections.map((section) => (
            <section
              id={section.id}
              class="border-t border-border pt-7 md:pt-8"
            >
              <div class="mb-4 flex flex-col gap-3 md:mb-5 md:flex-row md:items-end md:justify-between">
                <div class="space-y-1.5">
                  <h3 class="text-xl font-semibold tracking-tight text-foreground md:text-2xl">
                    {section.title}
                  </h3>
                  <p class="text-xs leading-5 text-muted-foreground">
                    Источники раздела:{' '}
                    {section.source_refs.map((ref, index) => (
                      <>
                        {index > 0 && '; '}
                        <a
                          class="ui-link text-primary"
                          href={ref.pdf_url}
                          type="application/pdf"
                        >
                          {formatSource(ref)}
                        </a>
                      </>
                    ))}
                  </p>
                </div>
                <div class="shrink-0 text-left md:text-right">
                  <p
                    class="text-lg font-bold tracking-tight text-foreground"
                    data-reglament-section-tariff={section.id}
                  >
                    {formatTariff(section.official.tariff_per_sotka_month)}
                  </p>
                  <p
                    class="text-xs text-muted-foreground"
                    data-reglament-section-annual={section.id}
                  >
                    {formatAnnualMoney(section.official.annual_gross)}
                  </p>
                  <p
                    class="text-xs font-semibold text-muted-foreground"
                    data-reglament-section-delta={section.id}
                  >
                    {formatTariffDelta(
                      section.computed.delta_tariff_per_sotka_month,
                    )}
                  </p>
                </div>
              </div>

              <div class="-mx-5 overflow-x-auto border-y border-border bg-surface sm:mx-0 sm:rounded-xl sm:border md:mx-0">
                <table class="min-w-[54rem] w-full border-separate border-spacing-0 text-left text-sm">
                  <caption class="sr-only">{section.title}</caption>
                  <thead class="bg-muted text-xs font-bold uppercase tracking-[0.06em] text-muted-foreground">
                    <tr>
                      <th class="w-[32%] px-4 py-2.5 align-bottom">Работа</th>
                      <th class="w-[18%] px-4 py-2.5 align-bottom">База</th>
                      <th class="w-[14%] px-4 py-2.5 align-bottom">
                        Кратность
                      </th>
                      <th class="w-[14%] px-4 py-2.5 align-bottom">
                        Цена/ставка
                      </th>
                      <th class="w-[12%] px-4 py-2.5 text-right align-bottom">
                        Вклад в тариф
                      </th>
                      <th class="w-[10%] px-4 py-2.5 text-right align-bottom">
                        Изменение
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {section.rows.map((row) => (
                      <tr class="border-t border-border">
                        <td class="border-t border-border px-4 py-2.5 align-top">
                          <div class="space-y-1.5">
                            <p class="font-semibold leading-snug text-foreground">
                              {row.title}
                            </p>
                            {row.tags && row.tags.length > 0 && (
                              <div class="flex flex-wrap gap-1.5">
                                {row.tags.map((tag) => (
                                  <span class="inline-flex whitespace-nowrap rounded-full border border-border bg-surface px-2 py-0.5 text-[0.6875rem] font-semibold leading-5 text-muted-foreground">
                                    {tag}
                                  </span>
                                ))}
                              </div>
                            )}
                            {row.controls.enabled && (
                              <label class="inline-flex items-center gap-2 text-xs font-semibold text-muted-foreground">
                                <input
                                  class="h-4 w-4 rounded border-border text-primary focus:ring-primary"
                                  type="checkbox"
                                  checked={row.baseline.is_enabled}
                                  data-reglament-field="enabled"
                                  data-reglament-row-id={row.id}
                                  data-reglament-baseline={String(
                                    row.baseline.is_enabled,
                                  )}
                                />
                                <span>Включено</span>
                              </label>
                            )}
                            <details class="mt-2 border-t border-border pt-2 text-xs leading-5 text-muted-foreground">
                              <summary class="cursor-pointer font-bold text-primary outline-none focus-visible:rounded-md focus-visible:ring-2 focus-visible:ring-primary/25">
                                Детали расчета и источники
                              </summary>
                              <div class="mt-3 space-y-4 border-l border-border pl-3">
                                {row.description && (
                                  <p class="text-muted-foreground">
                                    {row.description}
                                  </p>
                                )}

                                <div class="grid gap-3 sm:grid-cols-2">
                                  <div class="space-y-1">
                                    <p class="font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                      Годовая сумма
                                    </p>
                                    <p
                                      class="font-semibold text-foreground"
                                      data-reglament-row-annual={row.id}
                                    >
                                      {formatAnnualMoney(
                                        row.computed.annual_gross,
                                      )}
                                    </p>
                                  </div>
                                  <div class="space-y-1">
                                    <p class="font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                      Источники
                                    </p>
                                    <ul class="space-y-1">
                                      {row.source_refs.map((ref) => (
                                        <li>
                                          <a
                                            class="ui-link text-primary"
                                            href={ref.pdf_url}
                                            type="application/pdf"
                                          >
                                            {formatSource(ref)}
                                          </a>
                                          {ref.note && (
                                            <span class="block text-muted-foreground">
                                              {ref.note}
                                            </span>
                                          )}
                                        </li>
                                      ))}
                                    </ul>
                                  </div>
                                </div>

                                <div class="space-y-2">
                                  <p class="font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                    Расчетный состав
                                  </p>
                                  <dl class="grid gap-x-3 gap-y-2 sm:grid-cols-2">
                                    {breakdownFields.map((field) => (
                                      <div class="flex items-baseline justify-between gap-3 border-b border-border pb-1">
                                        <dt>{field.label}</dt>
                                        <dd
                                          class="text-right font-semibold text-foreground"
                                          data-reglament-row-breakdown={row.id}
                                          data-reglament-breakdown-field={
                                            field.key
                                          }
                                        >
                                          {formatMoney(
                                            row.computed.breakdown[field.key],
                                          )}
                                        </dd>
                                      </div>
                                    ))}
                                  </dl>
                                </div>

                                {row.controls.expert.length > 0 && (
                                  <fieldset class="space-y-2 border-t border-border pt-3">
                                    <legend class="font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                      Экспертные поля
                                    </legend>
                                    <div class="grid gap-2 sm:grid-cols-2">
                                      {row.controls.expert.map((control) => (
                                        <label class="block space-y-1">
                                          <span class="font-bold text-muted-foreground">
                                            {control.label}
                                          </span>
                                          <input
                                            class={inputClass}
                                            type="number"
                                            inputmode="decimal"
                                            min={control.min}
                                            max={control.max}
                                            step={control.step}
                                            value={control.value}
                                            aria-label={`${row.title}: ${control.label}`}
                                            data-reglament-field={control.key}
                                            data-reglament-row-id={row.id}
                                            data-reglament-baseline={String(
                                              control.value,
                                            )}
                                          />
                                          {control.unit && (
                                            <span class="block text-muted-foreground">
                                              {control.unit}
                                            </span>
                                          )}
                                        </label>
                                      ))}
                                    </div>
                                    <p class="text-muted-foreground">
                                      Эти поля меняют расчетную строку и не
                                      выводятся в основной таблице.
                                    </p>
                                  </fieldset>
                                )}
                              </div>
                            </details>
                          </div>
                        </td>
                        <td class="border-t border-border px-4 py-2.5 align-top text-muted-foreground">
                          {row.controls.base ? (
                            <label class="block space-y-1">
                              <span class="text-[0.6875rem] font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                {row.controls.base.label}
                              </span>
                              <input
                                class={inputClass}
                                type="number"
                                inputmode="decimal"
                                min={row.controls.base.min}
                                max={row.controls.base.max}
                                step={row.controls.base.step}
                                value={row.controls.base.value}
                                aria-label={`${row.title}: ${row.controls.base.label}`}
                                data-reglament-field={row.controls.base.key}
                                data-reglament-row-id={row.id}
                                data-reglament-baseline={String(
                                  row.controls.base.value,
                                )}
                              />
                              {row.controls.base.unit && (
                                <span class="block text-xs text-muted-foreground">
                                  {row.controls.base.unit}
                                </span>
                              )}
                            </label>
                          ) : (
                            formatDisplayValue(row.baseline.base)
                          )}
                        </td>
                        <td class="border-t border-border px-4 py-2.5 align-top text-muted-foreground">
                          {row.controls.frequency ? (
                            <label class="block space-y-1">
                              <span class="text-[0.6875rem] font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                {row.controls.frequency.label}
                              </span>
                              <input
                                class={inputClass}
                                type="number"
                                inputmode="decimal"
                                min={row.controls.frequency.min}
                                max={row.controls.frequency.max}
                                step={row.controls.frequency.step}
                                value={row.controls.frequency.value}
                                aria-label={`${row.title}: ${row.controls.frequency.label}`}
                                data-reglament-field={
                                  row.controls.frequency.key
                                }
                                data-reglament-row-id={row.id}
                                data-reglament-baseline={String(
                                  row.controls.frequency.value,
                                )}
                              />
                              {row.controls.frequency.unit && (
                                <span class="block text-xs text-muted-foreground">
                                  {row.controls.frequency.unit}
                                </span>
                              )}
                            </label>
                          ) : (
                            formatDisplayValue(row.baseline.frequency)
                          )}
                        </td>
                        <td class="border-t border-border px-4 py-2.5 align-top text-muted-foreground">
                          {row.controls.rate || row.controls.fixedPrice ? (
                            <div class="space-y-3">
                              {row.controls.rate && (
                                <label class="block space-y-1">
                                  <span class="text-[0.6875rem] font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                    {row.controls.rate.label}
                                  </span>
                                  <input
                                    class={inputClass}
                                    type="number"
                                    inputmode="decimal"
                                    min={row.controls.rate.min}
                                    max={row.controls.rate.max}
                                    step={row.controls.rate.step}
                                    value={row.controls.rate.value}
                                    aria-label={`${row.title}: ${row.controls.rate.label}`}
                                    data-reglament-field={row.controls.rate.key}
                                    data-reglament-row-id={row.id}
                                    data-reglament-baseline={String(
                                      row.controls.rate.value,
                                    )}
                                  />
                                  {row.controls.rate.unit && (
                                    <span class="block text-xs text-muted-foreground">
                                      {row.controls.rate.unit}
                                    </span>
                                  )}
                                </label>
                              )}
                              {row.controls.fixedPrice && (
                                <label class="block space-y-1">
                                  <span class="text-[0.6875rem] font-bold uppercase tracking-[0.06em] text-muted-foreground">
                                    {row.controls.fixedPrice.label}
                                  </span>
                                  <input
                                    class={inputClass}
                                    type="number"
                                    inputmode="decimal"
                                    min={row.controls.fixedPrice.min}
                                    max={row.controls.fixedPrice.max}
                                    step={row.controls.fixedPrice.step}
                                    value={row.controls.fixedPrice.value}
                                    aria-label={`${row.title}: ${row.controls.fixedPrice.label}`}
                                    data-reglament-field={
                                      row.controls.fixedPrice.key
                                    }
                                    data-reglament-row-id={row.id}
                                    data-reglament-baseline={String(
                                      row.controls.fixedPrice.value,
                                    )}
                                  />
                                  {row.controls.fixedPrice.unit && (
                                    <span class="block text-xs text-muted-foreground">
                                      {row.controls.fixedPrice.unit}
                                    </span>
                                  )}
                                </label>
                              )}
                            </div>
                          ) : (
                            formatDisplayValue(row.baseline.price)
                          )}
                        </td>
                        <td
                          class="border-t border-border px-4 py-2.5 text-right align-top font-semibold text-foreground"
                          data-reglament-row-tariff={row.id}
                        >
                          {formatTariffValue(
                            row.computed.tariff_per_sotka_month,
                          )}
                        </td>
                        <td
                          class="border-t border-border px-4 py-2.5 text-right align-top text-muted-foreground"
                          data-reglament-row-delta={row.id}
                        >
                          {formatTariffDelta(
                            row.computed.delta_tariff_per_sotka_month,
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          ))
        }
      </div>
    </section>
  </main>

  <style>
    [data-reglament-delta-tone='negative'] {
      color: var(--color-success);
    }

    [data-reglament-delta-tone='positive'] {
      color: var(--color-danger);
    }

    [data-reglament-delta-tone='zero'] {
      color: var(--color-text-muted);
    }
  </style>

  <script>
    import { hydrateReglamentCalculators } from '@/lib/reglament/calculator-controller';

    const hydrate = () => hydrateReglamentCalculators();

    hydrate();
    document.addEventListener('astro:after-swap', hydrate);
    document.addEventListener('astro:page-load', hydrate);
  </script>
</BaseLayout>
