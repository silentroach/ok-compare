---
import NotFoundView from '@shelkovo/ui/NotFoundView.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Страница не найдена — Шелково Онлайн';
const description =
  'Такой страницы нет или ее адрес изменился. Вернитесь на главную страницу Шелково Онлайн.';
---

<BaseLayout
  title={title}
  description={description}
  robots="noindex, nofollow"
  canonical="/404.html"
>
  <NotFoundView
    title="Страница не найдена"
    description="Адрес мог измениться, а ссылка устареть. Начните с главной страницы или откройте новости и статус сервисов."
    homeHref="/"
    homeLabel="Вернуться на главную"
  />
</BaseLayout>
