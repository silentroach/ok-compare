---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import logo from '../../../../design/logo.png';

const title = 'Шелково Онлайн';
const description =
  'Главный сайт Шелково находится в разработке. Уже доступен раздел со сравнением тарифов в поселках.';
---

<BaseLayout title={title} description={description}>
  <main class="ui-page flex min-h-[70svh] items-center py-12 md:py-16">
    <section
      class="mx-auto flex max-w-3xl flex-col items-center gap-6 text-center md:gap-8"
    >
      <Image
        src={logo}
        alt="Логотип Шелково"
        width={960}
        height={640}
        format="webp"
        loading="eager"
        class="w-full max-w-[34rem]"
      />

      <div class="space-y-4">
        <h1
          class="text-4xl font-bold tracking-tight text-foreground md:text-5xl"
        >
          Сайт находится в разработке
        </h1>
        <p class="ui-copy mx-auto max-w-2xl text-muted-foreground">
          Основной сайт Шелково сейчас собираем и наполняем. Пока уже доступен
          раздел со
          <a
            href="/compare/"
            class="font-medium text-foreground underline underline-offset-4"
          >
            сравнением тарифов
          </a>
          и данных по поселкам.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
