---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { SchemaDoc } from '@shelkovo/seo';
import dayHero from '@/assets/home/home-hero-day.png';
import nightHero from '@/assets/home/home-hero-night.png';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getHomeHeroMode } from '@/lib/home/hero';
import {
  getHomeStatusAriaLabel,
  getHomeStatusMaintenanceWindows,
  getHomeStatusState,
} from '@/lib/home/status';
import { loadNewsArticles } from '@/lib/news/load';
import { articleUrl } from '@/lib/news/routes';
import { formatNewsDate } from '@/lib/news/view';
import { canon } from '@/lib/site';
import { loadStatusData } from '@/lib/status/load';

const title = 'Шелково Онлайн';
const description =
  'Главный сайт поселка Шелково: новости, статус сервисов, сравнение тарифов и справочная информация по связанным проектам.';
const siteUrl = canon('/');
const organizationId = `${siteUrl}#organization`;
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: title,
    url: siteUrl,
    inLanguage: 'ru-RU',
    publisher: {
      '@id': organizationId,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': organizationId,
    name: title,
    url: siteUrl,
  },
] satisfies readonly SchemaDoc[];

const [news, status] = await Promise.all([
  loadNewsArticles(),
  loadStatusData(),
]);
const buildNow = Date.now();
const latestNews = news.slice(0, 2);
const homeStatusState = getHomeStatusState(status.incidents, buildNow);
const plannedMaintenanceWindows = getHomeStatusMaintenanceWindows(
  status.incidents,
  buildNow,
);

const heroWidths = [960, 1280, 1536, 1916, 2172] as const;
const heroSizes = '100vw';
const buildHeroImage = async (src: ImageMetadata) => {
  const images = await Promise.all(
    heroWidths.map((width) =>
      getImage({ src, width, format: 'webp', quality: 90 }),
    ),
  );

  return {
    src: images[images.length - 1]?.src ?? src.src,
    srcset: images
      .map((image, index) => `${image.src} ${heroWidths[index]}w`)
      .join(', '),
  };
};
const [dayHeroImage, nightHeroImage] = await Promise.all([
  buildHeroImage(dayHero),
  buildHeroImage(nightHero),
]);
const heroMode = getHomeHeroMode();
const heroImage = heroMode === 'day' ? dayHeroImage : nightHeroImage;
---

<BaseLayout title={title} description={description} schema={schema}>
  <main class="pb-2 md:pb-3 lg:pb-4">
    <section
      class="home-hero relative overflow-hidden border-b border-border bg-muted"
      data-home-hero-mode={heroMode}
    >
      <div class="h-[clamp(20rem,37vw,36rem)] w-full overflow-hidden">
        <img
          src={heroImage.src}
          srcset={heroImage.srcset}
          sizes={heroSizes}
          alt="Панорама поселка Шелково"
          width={dayHero.width}
          height={dayHero.height}
          class="h-full w-full object-cover object-left md:object-center"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          data-home-hero-image
          data-day-src={dayHeroImage.src}
          data-day-srcset={dayHeroImage.srcset}
          data-night-src={nightHeroImage.src}
          data-night-srcset={nightHeroImage.srcset}
        />
        <div
          class="home-hero-overlay pointer-events-none absolute inset-x-0 top-0 h-28 md:h-32"
        >
        </div>
        <div class="absolute inset-x-0 top-0 z-10">
          <div
            class="flex w-full justify-end pr-4 pt-4 md:pr-6 md:pt-5 lg:pr-8 lg:pt-6"
          >
            <nav
              class="home-hero-nav flex items-center gap-5 text-sm font-medium md:gap-10 md:text-base"
            >
              <a href="/news/">Новости</a>
              <div
                class="home-hero-nav-dropdown group relative"
                data-home-nav-dropdown
              >
                <button
                  type="button"
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-controls="home-hero-tariff-menu"
                  data-home-nav-dropdown-button
                  class="flex items-center gap-1.5 rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-4 focus-visible:ring-offset-transparent"
                >
                  <span>Тариф 815</span>
                  <span
                    aria-hidden="true"
                    data-home-nav-dropdown-icon
                    class="size-0 border-x-[0.25rem] border-t-[0.3125rem] border-x-transparent border-t-current opacity-70 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                  ></span>
                </button>
                <div
                  id="home-hero-tariff-menu"
                  data-home-nav-dropdown-menu
                  class="home-hero-nav-submenu invisible pointer-events-none absolute right-0 top-full z-20 min-w-[11.75rem] -translate-y-1 pt-2 opacity-0 transition-[opacity,transform,visibility] duration-150 ease-out group-hover:visible group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100"
                >
                  <div
                    class="rounded-xl border border-border bg-card px-1.5 py-1.5 shadow-[0_0.625rem_1.5rem_oklch(24%_0.04_145_/_0.08)]"
                  >
                    <a
                      href="/815/compare/"
                      class="block rounded-lg px-3 py-2 text-sm leading-5 text-foreground transition-colors hover:bg-primary-soft-2 focus-visible:bg-primary-soft-2 focus-visible:outline-none"
                    >
                      Сравнение тарифов
                    </a>
                    <a
                      href="/815/regulation/"
                      class="block rounded-lg px-3 py-2 text-sm leading-5 text-foreground transition-colors hover:bg-primary-soft-2 focus-visible:bg-primary-soft-2 focus-visible:outline-none"
                    >
                      Регламент
                    </a>
                  </div>
                </div>
              </div>
              <a
                href="/status/"
                aria-label={getHomeStatusAriaLabel(homeStatusState)}
                class="home-hero-status-link flex items-center gap-3"
                data-home-status-link
                data-home-status-state={homeStatusState}
              >
                <span>Статус</span>
                <span
                  aria-hidden="true"
                  data-home-status-dot
                  class="home-hero-status-dot inline-block h-3 w-3 rounded-full"
                ></span>
              </a>
            </nav>
            <script
              type="application/json"
              data-home-status-maintenance-windows
              set:html={JSON.stringify(plannedMaintenanceWindows)}
            />
          </div>
        </div>
        <script>
          import { installHomeHeroHydration } from '@/lib/home/hero';
          import { installHomeStatusHydration } from '@/lib/home/status';

          const hydrateHomeNavDropdown = () => {
            const dropdown = document.querySelector('[data-home-nav-dropdown]');
            if (!(dropdown instanceof HTMLElement)) return;
            if (dropdown.dataset.homeNavDropdownHydrated) return;
            dropdown.dataset.homeNavDropdownHydrated = 'true';

            const button = dropdown.querySelector(
              '[data-home-nav-dropdown-button]',
            );
            if (!(button instanceof HTMLButtonElement)) return;
            const controller = new AbortController();
            const { signal } = controller;

            const setOpen = (isOpen) => {
              dropdown.toggleAttribute('data-open', isOpen);
              button.setAttribute('aria-expanded', String(isOpen));
            };

            button.addEventListener(
              'click',
              () => {
                setOpen(!dropdown.hasAttribute('data-open'));
              },
              { signal },
            );

            dropdown.addEventListener(
              'focusout',
              (event) => {
                if (
                  event.relatedTarget instanceof Node &&
                  dropdown.contains(event.relatedTarget)
                ) {
                  return;
                }

                setOpen(false);
              },
              { signal },
            );

            document.addEventListener(
              'pointerdown',
              (event) => {
                if (!dropdown.hasAttribute('data-open')) return;
                if (
                  event.target instanceof Node &&
                  dropdown.contains(event.target)
                ) {
                  return;
                }

                setOpen(false);
              },
              { signal },
            );

            document.addEventListener(
              'keydown',
              (event) => {
                if (
                  event.key !== 'Escape' ||
                  !dropdown.hasAttribute('data-open')
                ) {
                  return;
                }

                setOpen(false);
                button.focus();
              },
              { signal },
            );

            document.addEventListener(
              'astro:before-swap',
              () => controller.abort(),
              { once: true, signal },
            );
          };

          installHomeHeroHydration();
          installHomeStatusHydration();
          hydrateHomeNavDropdown();
          document.addEventListener('astro:after-swap', hydrateHomeNavDropdown);
          document.addEventListener('astro:page-load', hydrateHomeNavDropdown);
        </script>
      </div>
    </section>

    {
      latestNews.length > 0 && (
        <section class="ui-page pt-8 pb-4 md:pt-12 md:pb-6 lg:pt-14 lg:pb-8">
          <div class="px-5 md:px-6">
            <h1 class="ui-page-title border-b border-border pb-4">
              Что нового в поселке
            </h1>

            <div>
              {latestNews.map((article) => (
                <article class="grid grid-cols-1 gap-4 py-6 md:grid-cols-[10rem_minmax(0,1fr)] md:gap-8 md:py-7">
                  <p class="flex flex-wrap items-center gap-2 text-sm font-normal leading-tight tracking-tight text-foreground md:flex-col md:items-center md:gap-1 md:pt-1 md:text-center md:text-base">
                    <time datetime={article.publishedIso}>
                      {formatNewsDate(article.publishedIso)}
                    </time>
                  </p>

                  <div class="max-w-3xl space-y-3">
                    <h2 class="flex items-start gap-2 text-xl font-bold leading-snug tracking-tight text-foreground">
                      <a href={articleUrl(article)} class="ui-link">
                        {article.title}
                      </a>
                    </h2>
                    <p class="text-sm leading-6 text-muted-foreground md:text-base md:leading-7">
                      {article.summary}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .home-hero-overlay {
    background: linear-gradient(
      to bottom,
      color-mix(in oklab, var(--color-bg) 36%, transparent),
      color-mix(in oklab, var(--color-bg) 10%, transparent) 54%,
      transparent
    );
  }

  .home-hero-nav {
    color: var(--color-text);
    text-shadow: 0 0.0625rem 1rem
      color-mix(in oklab, var(--color-bg) 72%, transparent);
  }

  .home-hero-nav a,
  .home-hero-nav button {
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .home-hero-nav a:is(:hover, :focus-visible),
  .home-hero-nav button:is(:hover, :focus-visible) {
    opacity: 0.78;
  }

  .home-hero-nav-submenu {
    color: var(--color-foreground);
    text-shadow: none;
  }

  .home-hero-nav-dropdown[data-open] .home-hero-nav-submenu {
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    opacity: 1;
  }

  .home-hero-nav-dropdown[data-open] [data-home-nav-dropdown-icon] {
    transform: rotate(180deg);
  }

  .home-hero-nav-submenu a:is(:hover, :focus-visible) {
    opacity: 1;
  }

  .home-hero-status-dot {
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-bg) 72%, transparent);
  }

  .home-hero-status-link[data-home-status-state='green'] .home-hero-status-dot {
    background: var(--color-success);
  }

  .home-hero-status-link[data-home-status-state='amber'] .home-hero-status-dot {
    background: var(--color-warning);
  }

  .home-hero-status-link[data-home-status-state='red'] .home-hero-status-dot {
    background: var(--color-danger);
  }

  .home-hero[data-home-hero-mode='night'] .home-hero-overlay {
    background: linear-gradient(
      to bottom,
      oklch(5% 0.01 250 / 0.58),
      oklch(5% 0.01 250 / 0.22) 58%,
      transparent
    );
  }

  .home-hero[data-home-hero-mode='night'] .home-hero-nav {
    color: oklch(97% 0.004 125);
    text-shadow: 0 0.0625rem 1rem oklch(0% 0 0 / 0.76);
  }

  .home-hero[data-home-hero-mode='night'] .home-hero-status-dot {
    box-shadow: 0 0 0 1px oklch(97% 0.004 125 / 0.62);
  }
</style>
