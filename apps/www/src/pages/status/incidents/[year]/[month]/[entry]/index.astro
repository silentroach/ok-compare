---
import type { GetStaticPaths } from 'astro';
import { padNumber } from '@shelkovo/format';

import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import StatusIncidentMeta from '@/components/status/StatusIncidentMeta.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { renderMarkdown } from '@/lib/markdown/render';
import { loadStatusIncident, loadStatusIncidents } from '@/lib/status/load';
import { statusUrl } from '@/lib/status/routes';
import { techArticleSchema } from '@/lib/news/seo';
import { NEWS_PROSE } from '@/lib/news/view';

export const getStaticPaths = (async () => {
  const incidents = await loadStatusIncidents();

  return incidents
    .filter((item) => item.hasPage)
    .map((item) => ({
      params: {
        year: String(item.year),
        month: padNumber(item.month),
        entry: item.slug,
      },
    }));
}) satisfies GetStaticPaths;

const year = Astro.params.year;
const month = Astro.params.month;
const entry = Astro.params.entry;

if (!year || !month || !entry) {
  throw new Error('status incident params are required');
}

const id = `${year}/${month}/${entry}`;
const incident = await loadStatusIncident(id);

if (!incident || !incident.hasPage) {
  throw new Error(`status incident "${id}" not found`);
}

const bodyHtml = incident.body ? renderMarkdown(incident.body) : undefined;
const title = `${incident.title} — Шелково Онлайн`;
const excerptSentence = incident.excerpt?.match(/^[^.!?]+[.!?]/u)?.[0];
const description =
  (incident.excerpt && incident.excerpt.length <= 170
    ? incident.excerpt
    : excerptSentence) ??
  'Подробная запись о статусе сервиса в КП Шелково: что произошло, когда началось и чем закончилось.';
const breadcrumbs = withHomeBreadcrumbs([
  { label: 'Статус', href: statusUrl() },
  { label: incident.title },
]);
const schema = techArticleSchema({
  name: incident.title,
  description,
  url: incident.url,
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Статус', url: statusUrl() },
    { name: incident.title, url: incident.url },
  ]),
  datePublished: incident.startedIso,
  ...(incident.endedIso ? { dateModified: incident.endedIso } : {}),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={incident.url}
  type="article"
  keywords={['статус Шелково', incident.title, 'инцидент Шелково']}
  schema={schema}
>
  <main class="ui-page pb-8 md:pb-12 lg:pb-14">
    <header class="ui-page-header">
      <div class="ui-page-header-stack max-w-4xl">
        <Breadcrumbs items={breadcrumbs} />

        <div class="space-y-3.5">
          <h1 class="ui-page-title">
            {incident.title}
          </h1>

          <StatusIncidentMeta
            incident={incident}
            className="gap-x-4 gap-y-2 text-[0.9375rem] leading-6"
          />
        </div>
      </div>
    </header>

    {
      incident.body && (
        <article class="px-5 md:px-6">
          <div class={NEWS_PROSE} set:html={bodyHtml} />
        </article>
      )
    }
  </main>
</BaseLayout>
