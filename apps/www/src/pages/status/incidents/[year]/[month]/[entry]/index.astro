---
import { getEntry, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { padNumber } from '@shelkovo/format';

import NewsBreadcrumbs from '../../../../../../components/news/NewsBreadcrumbs.astro';
import StatusIncidentMeta from '../../../../../../components/status/StatusIncidentMeta.astro';
import BaseLayout from '../../../../../../layouts/BaseLayout.astro';
import {
  loadStatusIncident,
  loadStatusIncidents,
} from '../../../../../../lib/status/load';
import { statusUrl } from '../../../../../../lib/status/routes';
import { techArticleSchema } from '../../../../../../lib/news/seo';
import { NEWS_PROSE } from '../../../../../../lib/news/view';

export const getStaticPaths = (async () => {
  const incidents = await loadStatusIncidents();

  return incidents.map((item) => ({
    params: {
      year: String(item.year),
      month: padNumber(item.month),
      entry: item.slug,
    },
  }));
}) satisfies GetStaticPaths;

const year = Astro.params.year;
const month = Astro.params.month;
const entry = Astro.params.entry;

if (!year || !month || !entry) {
  throw new Error('status incident params are required');
}

const id = `${year}/${month}/${entry}`;
const incident = await loadStatusIncident(id);
const source = await getEntry('statusIncidents', id);

if (!incident || !source) {
  throw new Error(`status incident "${id}" not found`);
}

const { Content } = await render(source);
const title = `${incident.kind === 'maintenance' ? 'Плановые работы' : 'Инцидент'} ${incident.title} — статус Шелково`;
const description =
  incident.excerpt ??
  'Детальная запись по инциденту или плановым работам в статусе поселка Шелково.';
const breadcrumbs = [
  { label: 'Статус', href: statusUrl() },
  { label: incident.title },
];
const schema = techArticleSchema({
  name: incident.title,
  description,
  url: incident.url,
  breadcrumbs: [
    { name: 'Статус', url: statusUrl() },
    { name: incident.title, url: incident.url },
  ],
  datePublished: incident.started_iso,
  ...(incident.ended_iso ? { dateModified: incident.ended_iso } : {}),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={incident.url}
  type="article"
  keywords={['статус Шелково', incident.title, 'инцидент Шелково']}
  schema={schema}
>
  <main class="ui-page pb-8 pt-4 md:pb-12 md:pt-6 lg:pb-14 lg:pt-7">
    <header class="px-5 pb-6 md:px-6 md:pb-8 lg:pb-10">
      <div class="max-w-4xl space-y-5">
        <NewsBreadcrumbs items={breadcrumbs} />

        <div class="space-y-3.5">
          <h1
            class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08] lg:text-[3.5rem]"
          >
            {incident.title}
          </h1>

          <StatusIncidentMeta
            incident={incident}
            className="gap-x-4 gap-y-2 text-[0.9375rem] leading-6"
          />
        </div>
      </div>
    </header>

    {
      incident.body && (
        <article class="px-5 md:px-6">
          <div class={NEWS_PROSE}>
            <Content />
          </div>
        </article>
      )
    }
  </main>
</BaseLayout>
