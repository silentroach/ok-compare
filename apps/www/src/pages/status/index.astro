---
import StatusIncidentRow from '@/components/status/StatusIncidentRow.astro';
import StatusServiceCard from '@/components/status/StatusServiceCard.astro';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { collectionPageSchema } from '@/lib/news/seo';
import { loadStatusData } from '@/lib/status/load';
import { statusServiceUrl, statusUrl } from '@/lib/status/routes';

const data = await loadStatusData();
const now = Date.now();
const overviewTimelineDays = 30;
const mobileOverviewTimelineDays = 7;
const activeIncidents = data.active.filter((item) => item.kind === 'incident');
const plannedWorks = data.incidents.filter(
  (item) =>
    item.kind === 'maintenance' &&
    (item.isActive || item.startedAt.valueOf() > now),
);
const title = 'Статус поселка — Шелково Онлайн';
const description =
  'Текущее состояние сервисов КП Шелково: отключения, ограничения интернета, плановые работы и история изменений.';
const breadcrumbs = withHomeBreadcrumbs([{ label: 'Статус' }]);
const schemaItems = data.incidents
  .filter((item) => item.hasPage)
  .map((item) => ({ name: item.title, url: item.url }));
const schema = collectionPageSchema({
  name: title,
  description,
  url: statusUrl(),
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Статус', url: statusUrl() },
  ]),
  items: schemaItems,
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={statusUrl()}
  keywords={[
    'статус Шелково',
    'инциденты Шелково',
    'отключения Шелково',
    'интернет Шелково',
  ]}
  schema={schema}
>
  <main class="ui-page pb-6 md:pb-10 lg:pb-12">
    <section class="ui-page-header">
      <div class="ui-page-header-stack max-w-4xl">
        <Breadcrumbs items={breadcrumbs} />

        <div>
          <div class="space-y-3">
            <h1 class="ui-page-title">Статус КП Шелково</h1>
            <p class="max-w-3xl text-base leading-7 text-muted-foreground">
              Журнал отключений и ограничений в КП Шелково: электричество, вода,
              интернет и проезд через дамбу. Фиксируем время, зону, источник и
              ход восстановления.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-8" aria-labelledby="status-services-title">
      <div class="max-w-6xl">
        <h2 id="status-services-title" class="sr-only">Сводка по сервисам</h2>

        <div class="relative">
          <div
            class="hidden lg:grid lg:grid-cols-[minmax(0,15rem)_minmax(0,1fr)_minmax(0,11rem)_minmax(0,21rem)] lg:gap-6 lg:px-6 lg:py-3"
          >
            <p class="text-[0.875rem] font-semibold text-muted-foreground">
              Сервис
            </p>
            <p class="text-[0.875rem] font-semibold text-muted-foreground">
              Хронология за месяц
            </p>
            <p class="text-[0.875rem] font-semibold text-muted-foreground">
              Статус
            </p>
            <p class="text-[0.875rem] font-semibold text-muted-foreground">
              Последняя запись
            </p>
          </div>

          <div>
            {
              data.services.map((summary) => (
                <StatusServiceCard
                  summary={summary}
                  serviceHref={statusServiceUrl(summary.service)}
                  timelineDays={overviewTimelineDays}
                  mobileTimelineDays={mobileOverviewTimelineDays}
                />
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {
      activeIncidents.length > 0 && (
        <section class="mt-12 px-5 md:mt-14 md:px-6">
          <div class="space-y-4">
            <div class="space-y-1.5">
              <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-[2rem]">
                Активные инциденты
              </h2>
              <p class="text-sm leading-6 text-muted-foreground md:text-[0.9375rem]">
                Отключения и ограничения, которые еще не закрыты.
              </p>
            </div>

            <div class="-mx-5 md:-mx-6">
              {activeIncidents.map((incident) => (
                <StatusIncidentRow incident={incident} />
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      plannedWorks.length > 0 && (
        <section class="mt-12 px-5 md:mt-14 md:px-6">
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-[2rem]">
                Плановые работы
              </h2>
              <p class="mt-1.5 text-sm leading-6 text-muted-foreground md:text-[0.9375rem]">
                Запланированные или уже идущие работы по сервисам поселка.
              </p>
            </div>

            <div class="-mx-5 md:-mx-6">
              {plannedWorks.map((incident) => (
                <StatusIncidentRow incident={incident} />
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="mt-12 px-5 md:mt-14 md:px-6">
      <div class="space-y-4">
        <div>
          <h2
            class="text-2xl font-bold tracking-tight text-foreground md:text-[2rem]"
          >
            История
          </h2>
        </div>

        <div class="-mx-5 md:-mx-6">
          {
            data.incidents.map((incident) => (
              <StatusIncidentRow incident={incident} />
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
