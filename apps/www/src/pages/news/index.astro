---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsList from '../../components/news/NewsList.astro';
import NewsTagList from '../../components/news/NewsTagList.astro';
import { loadNewsData } from '../../lib/news/load';
import { collectionPageSchema } from '../../lib/news/seo';
import { formatNewsMonth } from '../../lib/news/view';
import { agentsUrl, newsUrl, tagsUrl } from '../../lib/news/routes';

const data = await loadNewsData();
const recentMonths = data.archives.years
  .flatMap((item) => item.months)
  .slice(0, 6);
const topTags = data.tags.slice(0, 12);
const visible = [...data.home.pinned, ...data.home.latest];
const normalCount = data.articles.length - data.home.pinned.length;
const archiveUrl = data.archives.years[0]?.url ?? newsUrl();

const title = 'Новости Шелково';
const description =
  'Новости поселков Шелково и сервисов ОК Комфорт: краткие сводки, архивы по годам и месяцам, а также навигация по редакционным тегам.';
const schema = collectionPageSchema({
  name: title,
  description,
  url: newsUrl(),
  breadcrumbs: [{ name: 'Новости', url: newsUrl() }],
  items: visible.map((item) => ({ name: item.title, url: item.url })),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={newsUrl()}
  keywords={['новости Шелково', 'новости ОК Комфорт', 'архив новостей Шелково']}
  schema={schema}
>
  <main class="ui-page py-6 md:py-10 lg:py-12">
    <section class="ui-shell-strong overflow-hidden p-6 md:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_20rem] lg:gap-10">
        <div class="space-y-5">
          <div class="flex flex-wrap gap-2">
            <span class="ui-chip">Новости</span>
            <span class="ui-chip">Архивы</span>
            <span class="ui-chip">Теги</span>
          </div>

          <div class="space-y-3">
            <h1
              class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
            >
              Хроника поселков, сервиса и инфраструктуры
            </h1>
            <p class="ui-copy max-w-3xl text-muted-foreground">
              Раздел собирает короткие новости по Шелково, соседним очередям и
              сервисным темам. На главной pinned-публикации идут отдельно, а
              основная лента остается чисто хронологической.
            </p>
          </div>

          <div
            class="flex flex-wrap gap-3 text-sm leading-6 text-muted-foreground"
          >
            <a href={tagsUrl()} class="ui-link font-semibold"> Все теги </a>
            <a href={agentsUrl()} class="ui-link font-semibold">
              Для агентов
            </a>
          </div>
        </div>

        <aside class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          <div
            class="rounded-[1.35rem] border border-border bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-1)]"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Всего новостей
            </p>
            <p
              class="ui-num mt-3 text-3xl font-semibold tracking-tight text-foreground"
            >
              {data.articles.length}
            </p>
          </div>

          <div
            class="rounded-[1.35rem] border border-border bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-1)]"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Закреплено
            </p>
            <p
              class="ui-num mt-3 text-3xl font-semibold tracking-tight text-foreground"
            >
              {data.home.pinned.length}
            </p>
          </div>

          <div
            class="rounded-[1.35rem] border border-border bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-1)]"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Тегов
            </p>
            <p
              class="ui-num mt-3 text-3xl font-semibold tracking-tight text-foreground"
            >
              {data.tags.length}
            </p>
          </div>
        </aside>
      </div>
    </section>

    <div
      class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start"
    >
      <div class="space-y-6">
        {
          data.home.pinned.length > 0 && (
            <section class="space-y-4">
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                  Закреплено
                </p>
                <h2 class="text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]">
                  Закрепленные публикации
                </h2>
              </div>

              <NewsList articles={data.home.pinned} featured empty="" />
            </section>
          )
        }

        <section class="space-y-4">
          <div class="space-y-2">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Лента
            </p>
            <h2
              class="text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]"
            >
              Последние новости
            </h2>
            {
              normalCount > data.home.latest.length && (
                <p class="text-sm leading-7 text-muted-foreground">
                  На главной показываем только последние 10 обычных новостей. За
                  остальными публикациями переходите в{' '}
                  <a href={archiveUrl} class="ui-link font-medium">
                    архив раздела
                  </a>
                  .
                </p>
              )
            }
          </div>

          <NewsList
            articles={data.home.latest}
            empty="Первые публикации для раздела готовятся. Когда новости появятся, здесь будет основная хронологическая лента."
          />
        </section>
      </div>

      <aside class="space-y-6">
        <section class="ui-shell p-5">
          <p
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Архивы
          </p>
          <ul class="mt-4 space-y-3">
            {
              data.archives.years.map((item) => (
                <li class="flex items-center justify-between gap-3 rounded-xl border border-border bg-[color:var(--color-surface-raised)] px-4 py-3">
                  <a href={item.url} class="ui-link font-semibold">
                    {item.year}
                  </a>
                  <span class="ui-num text-sm text-muted-foreground">
                    {item.count}
                  </span>
                </li>
              ))
            }
          </ul>

          {
            recentMonths.length > 0 && (
              <div class="mt-5 space-y-3 border-t border-border pt-5">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                  Последние месяцы
                </p>
                <ul class="space-y-2 text-sm leading-6 text-muted-foreground">
                  {recentMonths.map((item) => (
                    <li class="flex items-center justify-between gap-3">
                      <a href={item.url} class="ui-link font-medium">
                        {formatNewsMonth(item.year, item.month, {
                          capitalize: true,
                        })}
                      </a>
                      <span class="ui-num">{item.count}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </section>

        <section class="ui-shell p-5">
          <div class="flex items-center justify-between gap-3">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Теги
            </p>
            <a href={tagsUrl()} class="ui-link text-sm font-semibold">
              Индекс тегов
            </a>
          </div>

          <NewsTagList
            items={topTags.map((item) => ({
              label: item.label,
              url: item.url,
              count: item.count,
            }))}
            compact
            className="mt-4"
          />

          {
            topTags.length === 0 && (
              <p class="mt-4 text-sm leading-7 text-muted-foreground">
                Теги появятся автоматически, когда в новостях появятся первые
                тематические публикации.
              </p>
            )
          }
        </section>
      </aside>
    </div>
  </main>
</BaseLayout>
