---
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import NewsList from '@/components/news/NewsList.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { loadNewsData } from '@/lib/news/load';
import { newsUrl } from '@/lib/news/routes';
import { collectionPageSchema } from '@/lib/news/seo';

const data = await loadNewsData();
const articles = [...data.home.pinned, ...data.home.latest];

const title = 'Новости Шелково';
const description =
  'Короткие новости по Шелково, соседним очередям и сервисным темам.';
const breadcrumbs = withHomeBreadcrumbs([{ label: 'Новости' }]);
const schema = collectionPageSchema({
  name: title,
  description,
  url: newsUrl(),
  breadcrumbs: withHomeSchemaBreadcrumbs([{ name: 'Новости', url: newsUrl() }]),
  items: articles.map((item) => ({ name: item.title, url: item.url })),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={newsUrl()}
  keywords={['новости Шелково', 'новости ОК Комфорт', 'архив новостей Шелково']}
  schema={schema}
>
  <main class="ui-page pb-6 md:pb-10 lg:pb-12">
    <section class="px-5 pb-6 pt-3 md:px-6 md:pb-8 md:pt-5 lg:pb-10 lg:pt-6">
      <div class="space-y-5">
        <Breadcrumbs items={breadcrumbs} />

        <h1
          class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
        >
          Новости
        </h1>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="sr-only">Лента новостей</h2>
      <NewsList
        articles={articles}
        empty="Первые публикации для раздела готовятся. Когда новости появятся, здесь будет основная лента."
      />
    </section>
  </main>
</BaseLayout>
