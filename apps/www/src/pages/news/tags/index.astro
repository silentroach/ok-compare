---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsBreadcrumbs from '../../../components/news/NewsBreadcrumbs.astro';
import NewsTagList from '../../../components/news/NewsTagList.astro';
import { loadNewsTags } from '../../../lib/news/load';
import { collectionPageSchema } from '../../../lib/news/seo';
import { newsUrl, tagsUrl } from '../../../lib/news/routes';

const tags = await loadNewsTags();
const title = 'Теги новостей Шелково';
const description =
  'Навигация по редакционным тегам news-section: темы, события и локальные сюжеты без client-side фильтров и без пагинации в v1.';
const breadcrumbs = [{ label: 'Новости', href: newsUrl() }, { label: 'Теги' }];
const schema = collectionPageSchema({
  name: title,
  description,
  url: tagsUrl(),
  breadcrumbs: [
    { name: 'Новости', url: newsUrl() },
    { name: 'Теги', url: tagsUrl() },
  ],
  items: tags.map((item) => ({ name: item.label, url: item.url })),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={tagsUrl()}
  keywords={['теги новостей', 'Шелково', 'темы новостей Шелково']}
  schema={schema}
>
  <main class="ui-page pb-6 md:pb-10 lg:pb-12">
    <section class="px-5 pb-6 pt-3 md:px-6 md:pb-8 md:pt-5 lg:pb-10 lg:pt-6">
      <div class="space-y-5">
        <NewsBreadcrumbs items={breadcrumbs} />

        <div class="space-y-3">
          <h1
            class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
          >
            Теги новостей
          </h1>
        </div>
      </div>
    </section>

    <section class="mt-8 space-y-4 px-5 md:px-6">
      <NewsTagList
        items={tags.map((item) => ({
          label: item.label,
          url: item.url,
          count: item.count,
        }))}
      />

      {
        tags.length === 0 && (
          <div class="ui-shell px-5 py-6 md:px-6 md:py-7">
            <p class="ui-copy text-muted-foreground">
              Пока ни одна публикация не получила редакционный тег. Индекс
              появится автоматически после первых новостей.
            </p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
