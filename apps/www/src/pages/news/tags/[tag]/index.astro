---
import type { GetStaticPaths } from 'astro';
import { pluralizeRu } from '@shelkovo/format';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import NewsList from '@/components/news/NewsList.astro';
import { NEWS_LATEST_LIMIT } from '@/lib/news/config';
import { loadNewsTag, loadNewsTags } from '@/lib/news/load';
import { collectionPageSchema } from '@/lib/news/seo';
import { newsUrl, tagUrl, tagsUrl } from '@/lib/news/routes';

export const getStaticPaths = (async () => {
  const tags = await loadNewsTags();

  return tags.map((item) => ({
    params: { tag: item.key },
  }));
}) satisfies GetStaticPaths;

const key = Astro.params.tag;

if (!key) {
  throw new Error('news tag key is required');
}

const tag = await loadNewsTag(key);

if (!tag) {
  throw new Error(`news tag page "${key}" not found`);
}

const title = `Тема: ${tag.label} — Новости — Шелково Онлайн`;
const latestPublicationsLabel = `${NEWS_LATEST_LIMIT} ${pluralizeRu(NEWS_LATEST_LIMIT, ['публикация', 'публикации', 'публикаций'])}`;
const description = `Последние новости Шелково по теме «${tag.label}»: ${latestPublicationsLabel}, а более ранние материалы доступны в архивах.`;
const breadcrumbs = withHomeBreadcrumbs([
  { label: 'Новости', href: newsUrl() },
  { label: 'Теги', href: tagsUrl() },
  { label: tag.label },
]);
const schema = collectionPageSchema({
  name: title,
  description,
  url: tagUrl(tag.key),
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Новости', url: newsUrl() },
    { name: 'Теги', url: tagsUrl() },
    { name: tag.label, url: tagUrl(tag.key) },
  ]),
  items: tag.latest.map((item) => ({ name: item.title, url: item.url })),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={tag.url}
  keywords={['тег новостей', tag.label, 'Шелково']}
  schema={schema}
>
  <main class="ui-page pb-6 md:pb-10 lg:pb-12">
    <section class="px-5 pb-6 pt-3 md:px-6 md:pb-8 md:pt-5 lg:pb-10 lg:pt-6">
      <div class="space-y-5">
        <Breadcrumbs items={breadcrumbs} />

        <div class="space-y-3">
          <h1
            class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
          >
            #{tag.label}
          </h1>
          <p class="ui-copy max-w-3xl text-muted-foreground">
            Последние новости по тегу
          </p>
        </div>
      </div>
    </section>

    <section class="mt-8 space-y-4">
      <h2 class="sr-only">Публикации по тегу {tag.label}</h2>
      {
        tag.count > tag.latest.length && (
          <p class="px-5 text-sm leading-7 text-muted-foreground md:px-6">
            На этой странице показаны последние {latestPublicationsLabel} по
            тегу. Более ранние материалы доступны в месячных и годовых архивах.
          </p>
        )
      }

      <NewsList articles={tag.latest} empty="" />
    </section>
  </main>
</BaseLayout>
