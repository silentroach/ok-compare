---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsBreadcrumbs from '../../components/news/NewsBreadcrumbs.astro';
import { loadNewsData } from '../../lib/news/load';
import { techArticleSchema } from '../../lib/news/seo';
import {
  agentsMarkdownUrl,
  agentsUrl,
  apiCatalogUrl,
  articlesDataUrl,
  articlesOpenApiUrl,
  articlesSchemaUrl,
  feedUrl,
  llmsFullUrl,
  llmsUrl,
  newsMarkdownUrl,
  newsUrl,
  tagsMarkdownUrl,
  tagsUrl,
} from '../../lib/news/routes';

interface Ref {
  readonly label: string;
  readonly note: string;
  readonly href?: string;
}

const data = await loadNewsData();
const exampleArticle = data.articles[0];
const exampleYear = data.archives.years[0];
const exampleMonth = exampleYear?.months[0];
const exampleTag = data.tags[0];

const title = 'Для агентов: маршруты и discovery news-section';
const description =
  'Краткая документация по HTML, Markdown, JSON feed, RSS и discovery-маршрутам news-section.';
const breadcrumbs = [
  { label: 'Новости', href: newsUrl() },
  { label: 'Для агентов' },
];
const schema = techArticleSchema({
  name: title,
  description,
  url: agentsUrl(),
  breadcrumbs: [
    { name: 'Новости', url: newsUrl() },
    { name: 'Для агентов', url: agentsUrl() },
  ],
});

const htmlRefs: readonly Ref[] = [
  {
    label: '/news/',
    href: newsUrl(),
    note: 'Главная лента с pinned-блоком, последними обычными новостями, архивами и тегами.',
  },
  {
    label: exampleYear?.url ?? '/news/YYYY/',
    href: exampleYear?.url,
    note: 'Годовой архив: месяцы с количеством новостей и лента, сгруппированная по месяцам.',
  },
  {
    label: exampleMonth?.url ?? '/news/YYYY/MM/',
    href: exampleMonth?.url,
    note: 'Месячный архив: все новости конкретного месяца в кратком формате.',
  },
  {
    label: exampleArticle?.url ?? '/news/YYYY/MM/[entry]/',
    href: exampleArticle?.url,
    note: 'Каноническая detail-страница одной новости с body, фото, вложениями и addenda.',
  },
  {
    label: '/news/tags/',
    href: tagsUrl(),
    note: 'Индекс всех тегов news-section.',
  },
  {
    label: exampleTag?.url ?? '/news/tags/[tag]/',
    href: exampleTag?.url,
    note: 'Последние 10 новостей по конкретному тегу без пагинации в v1.',
  },
];

const markdownRefs: readonly Ref[] = [
  {
    label: newsMarkdownUrl(),
    href: newsMarkdownUrl(),
    note: 'Text-first companion для главной news-страницы.',
  },
  {
    label: exampleYear?.markdown_url ?? '/news/YYYY/index.md',
    href: exampleYear?.markdown_url,
    note: 'Markdown-версия годового архива.',
  },
  {
    label: exampleMonth?.markdown_url ?? '/news/YYYY/MM/index.md',
    href: exampleMonth?.markdown_url,
    note: 'Markdown-версия месячного архива.',
  },
  {
    label: exampleArticle?.markdown_url ?? '/news/YYYY/MM/[entry]/index.md',
    href: exampleArticle?.markdown_url,
    note: 'Markdown detail page с метаданными, summary, full body и addenda.',
  },
  {
    label: tagsMarkdownUrl(),
    href: tagsMarkdownUrl(),
    note: 'Markdown-индекс всех тегов и их detail companions.',
  },
  {
    label: exampleTag?.markdown_url ?? '/news/tags/[tag]/index.md',
    href: exampleTag?.markdown_url,
    note: 'Markdown-версия страницы тега с последними 10 публикациями.',
  },
  {
    label: agentsMarkdownUrl(),
    href: agentsMarkdownUrl(),
    note: 'Text-first overview всего markdown/discovery surface для агентов.',
  },
];

const discoveryRefs: readonly Ref[] = [
  {
    label: articlesDataUrl(),
    href: articlesDataUrl(),
    note: 'Основной structured feed для агентов и машинного обхода раздела.',
  },
  {
    label: feedUrl(),
    href: feedUrl(),
    note: 'RSS с summary-based описаниями без разворачивания full body.',
  },
  {
    label: llmsUrl(),
    href: llmsUrl(),
    note: 'Короткая текстовая сводка по маршрутам и правилам чтения раздела.',
  },
  {
    label: llmsFullUrl(),
    href: llmsFullUrl(),
    note: 'Расширенная версия llms.txt с описанием payload, tags, archives и addenda.',
  },
  {
    label: apiCatalogUrl(),
    href: apiCatalogUrl(),
    note: 'Linkset JSON для автоматического discovery маршрутов feed/schema/docs.',
  },
  {
    label: articlesSchemaUrl(),
    href: articlesSchemaUrl(),
    note: 'JSON Schema для полного news feed.',
  },
  {
    label: articlesOpenApiUrl(),
    href: articlesOpenApiUrl(),
    note: 'Минимальная read-only OpenAPI 3.1-обертка вокруг основного feed route.',
  },
];

const rules = [
  'все HTML, Markdown и discovery маршруты news-section должны генерироваться статически',
  'канонический URL новости всегда имеет вид /news/YYYY/MM/[entry]/',
  'pinned влияет только на /news/ и не меняет хронологию годовых и месячных архивов',
  'summary используется в list UI, RSS и archive/tag pages, а full body остается только для detail view и machine-readable outputs',
  'addenda живут внутри того же article source file, но на detail page и в feed должны оставаться отдельным массивом/блоком',
  'official-статус определяется author entry, а не отдельным boolean в каждом article file',
];

const authorRules = [
  'официальная новость определяется по author.kind/is_official, а не по route или тегу',
  'community/editorial addenda можно прикладывать к официальной новости без переписывания исходного текста',
  'поздние addenda не поднимают новость вверх в списках; меняется только updated_at и соответствующий badge',
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={agentsUrl()}
  keywords={['news for agents', 'news feed', 'markdown companions', 'Шелково']}
  schema={schema}
>
  <main class="ui-page py-6 md:py-10 lg:py-12">
    <section class="ui-shell-strong overflow-hidden p-6 md:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_22rem] lg:gap-10">
        <div class="space-y-5">
          <NewsBreadcrumbs items={breadcrumbs} />

          <div class="flex flex-wrap gap-2">
            <span class="ui-chip">HTML</span>
            <span class="ui-chip">Markdown companions</span>
            <span class="ui-chip">Discovery</span>
          </div>

          <div class="space-y-3">
            <h1
              class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
            >
              News-section для людей и агентов
            </h1>
            <p class="ui-copy max-w-3xl text-muted-foreground">
              HTML detail pages остаются каноническим человекочитаемым
              представлением, markdown companions дают отдельный text-first
              слой, а feed, RSS, llms.txt, schema и OpenAPI уже собираются из
              того же статического derive-слоя.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            <div
              class="rounded-[1.35rem] border border-border bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-1)]"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
              >
                Статей
              </p>
              <p
                class="ui-num mt-3 text-3xl font-semibold tracking-tight text-foreground"
              >
                {data.articles.length}
              </p>
            </div>

            <div
              class="rounded-[1.35rem] border border-border bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-1)]"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
              >
                Тегов
              </p>
              <p
                class="ui-num mt-3 text-3xl font-semibold tracking-tight text-foreground"
              >
                {data.tags.length}
              </p>
            </div>

            <div
              class="rounded-[1.35rem] border border-border bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-1)]"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
              >
                Лет в архиве
              </p>
              <p
                class="ui-num mt-3 text-3xl font-semibold tracking-tight text-foreground"
              >
                {data.archives.years.length}
              </p>
            </div>
          </div>
        </div>

        <aside class="space-y-4">
          <div
            class="rounded-[1.35rem] border border-[color:var(--color-border-strong)] bg-[color:var(--color-surface-raised)] p-5 shadow-[var(--shadow-2)]"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Уже доступно
            </p>
            <ul class="mt-4 space-y-3">
              {
                htmlRefs
                  .filter((item) => item.href)
                  .slice(0, 3)
                  .map((item) => (
                    <li class="rounded-xl border border-border bg-card px-4 py-3">
                      <a href={item.href} class="ui-link text-sm font-semibold">
                        {item.label}
                      </a>
                      <p class="mt-1 text-xs leading-5 text-muted-foreground">
                        {item.note}
                      </p>
                    </li>
                  ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <div
      class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start"
    >
      <div class="space-y-6">
        <section class="ui-shell p-6 md:p-7">
          <div class="space-y-4">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              HTML surfaces
            </p>
            <h2
              class="text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]"
            >
              Канонические страницы раздела
            </h2>
            <ul class="space-y-3">
              {
                htmlRefs.map((item) => (
                  <li class="rounded-xl border border-border bg-[color:var(--color-surface-raised)] px-4 py-3">
                    {item.href ? (
                      <a href={item.href} class="ui-link font-semibold">
                        <code>{item.label}</code>
                      </a>
                    ) : (
                      <code class="font-semibold text-foreground">
                        {item.label}
                      </code>
                    )}
                    <p class="mt-1 text-sm leading-7 text-muted-foreground">
                      {item.note}
                    </p>
                  </li>
                ))
              }
            </ul>
          </div>
        </section>

        <section class="ui-shell p-6 md:p-7">
          <div class="space-y-4">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Agent surfaces
            </p>
            <h2
              class="text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]"
            >
              Markdown и discovery routes
            </h2>
            <p class="ui-copy text-muted-foreground">
              HTML, Markdown и discovery-маршруты теперь уже собраны как один
              согласованный static surface: feed/schema/API используют те же
              вычисленные article, archive и tag структуры, что и
              человекочитаемые страницы раздела.
            </p>

            <div class="grid gap-4 xl:grid-cols-2">
              <div class="space-y-3">
                <p class="text-sm font-semibold text-foreground">
                  Markdown companions
                </p>
                <ul class="space-y-3">
                  {
                    markdownRefs.map((item) => (
                      <li class="rounded-xl border border-border bg-[color:var(--color-surface-raised)] px-4 py-3">
                        <div class="flex flex-wrap items-center gap-2">
                          {item.href ? (
                            <a href={item.href} class="ui-link font-semibold">
                              <code>{item.label}</code>
                            </a>
                          ) : (
                            <code class="font-semibold text-foreground">
                              {item.label}
                            </code>
                          )}
                          {item.status && (
                            <span class="ui-chip">{item.status}</span>
                          )}
                        </div>
                        <p class="mt-1 text-sm leading-7 text-muted-foreground">
                          {item.note}
                        </p>
                      </li>
                    ))
                  }
                </ul>
              </div>

              <div class="space-y-3">
                <p class="text-sm font-semibold text-foreground">
                  Feed и discovery
                </p>
                <ul class="space-y-3">
                  {
                    discoveryRefs.map((item) => (
                      <li class="rounded-xl border border-border bg-[color:var(--color-surface-raised)] px-4 py-3">
                        <div class="flex flex-wrap items-center gap-2">
                          {item.href ? (
                            <a href={item.href} class="ui-link font-semibold">
                              <code>{item.label}</code>
                            </a>
                          ) : (
                            <code class="font-semibold text-foreground">
                              {item.label}
                            </code>
                          )}
                        </div>
                        <p class="mt-1 text-sm leading-7 text-muted-foreground">
                          {item.note}
                        </p>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </div>
        </section>

        <section class="ui-shell p-6 md:p-7">
          <div class="space-y-4">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Контракт раздела
            </p>
            <h2
              class="text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]"
            >
              Что важно при автоматическом чтении
            </h2>
            <ul
              class="space-y-2 text-sm leading-7 text-muted-foreground md:text-base"
            >
              {rules.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="ui-shell p-5">
          <p
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Official vs community
          </p>
          <ul class="mt-3 space-y-2 text-sm leading-7 text-muted-foreground">
            {authorRules.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="ui-shell p-5">
          <p
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Примеры маршрутов
          </p>
          <ul class="mt-3 space-y-3 text-sm leading-7 text-muted-foreground">
            <li>
              <code class="text-foreground">/news/YYYY/MM/[entry]/</code> — каноническая
              статья
            </li>
            <li>
              <code class="text-foreground">/news/YYYY/MM/[entry]/index.md</code
              >{' '}
              — text-first companion
            </li>
            <li>
              <code class="text-foreground">/news/data/articles.json</code> — основной
              structured feed
            </li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</BaseLayout>
