---
import type { GetStaticPaths } from 'astro';
import { padNumber } from '@shelkovo/format';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import NewsList from '@/components/news/NewsList.astro';
import { loadNewsArchives, loadNewsMonth } from '@/lib/news/load';
import { collectionPageSchema } from '@/lib/news/seo';
import { formatNewsMonth } from '@/lib/news/view';
import { monthUrl, newsUrl, yearUrl } from '@/lib/news/routes';

export const getStaticPaths = (async () => {
  const archives = await loadNewsArchives();

  return archives.years.flatMap((item) =>
    item.months.map((month) => ({
      params: {
        year: String(month.year),
        month: padNumber(month.month),
      },
    })),
  );
}) satisfies GetStaticPaths;

const year = Number(Astro.params.year);
const month = Number(Astro.params.month);
const archive = await loadNewsMonth(year, month);
const allArchives = await loadNewsArchives();

if (!archive) {
  throw new Error(
    `news month archive "${Astro.params.year}/${Astro.params.month}" not found`,
  );
}

const months = allArchives.years.flatMap((item) => item.months);
const index = months.findIndex((item) => item.id === archive.id);
const newer = index > 0 ? months[index - 1] : undefined;
const older =
  index >= 0 && index < months.length - 1 ? months[index + 1] : undefined;
const monthLabel = formatNewsMonth(archive.year, archive.month);
const monthName = formatNewsMonth(archive.year, archive.month, {
  capitalize: true,
});
const newerMonthName = newer
  ? formatNewsMonth(newer.year, newer.month, { capitalize: true })
  : undefined;
const olderMonthName = older
  ? formatNewsMonth(older.year, older.month, { capitalize: true })
  : undefined;
const heading = `Новости за ${monthLabel}`;
const title = `Новости за ${monthLabel} — Шелково Онлайн`;
const description = `Архив новостей Шелково за ${monthLabel}: публикации месяца в хронологическом порядке.`;
const breadcrumbs = withHomeBreadcrumbs([
  { label: 'Новости', href: newsUrl() },
  { label: String(archive.year), href: yearUrl(archive.year) },
  { label: monthName },
]);
const schema = collectionPageSchema({
  name: title,
  description,
  url: monthUrl(archive.year, archive.month),
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Новости', url: newsUrl() },
    { name: String(archive.year), url: yearUrl(archive.year) },
    { name: monthName, url: monthUrl(archive.year, archive.month) },
  ]),
  items: archive.articles.map((item) => ({ name: item.title, url: item.url })),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={monthUrl(archive.year, archive.month)}
  keywords={['месячный архив новостей', monthName, String(archive.year)]}
  schema={schema}
>
  <main class="ui-page pb-6 md:pb-10 lg:pb-12">
    <section class="ui-page-header">
      <div class="ui-page-header-stack">
        <Breadcrumbs items={breadcrumbs} />

        <div>
          <h1 class="ui-page-title">
            {heading}
          </h1>
        </div>

        <nav
          class="flex max-w-3xl flex-col gap-2 pt-1 text-sm font-semibold leading-6 sm:flex-row sm:items-center sm:justify-between"
          aria-label="Навигация по месяцам новостей"
        >
          {
            older && olderMonthName && (
              <a href={older.url} class="ui-link">
                <span aria-hidden="true">← </span>
                {olderMonthName}
              </a>
            )
          }
          {
            newer && newerMonthName && (
              <a
                href={newer.url}
                class:list={['ui-link', !older && 'sm:ml-auto']}
              >
                {newerMonthName}
                <span aria-hidden="true"> →</span>
              </a>
            )
          }
        </nav>
      </div>
    </section>

    <section class="mt-8 space-y-4">
      <div
        class="flex flex-wrap items-center justify-between gap-3 px-5 md:px-6"
      >
        <h2 class="ui-section-title">Новости за месяц</h2>
      </div>

      <NewsList articles={archive.articles} empty="" />
    </section>
  </main>
</BaseLayout>
