---
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import ResourceLink from '@shelkovo/ui/ResourceLink.astro';
import {
  ForestIcon,
  ParkIcon,
  RiverIcon,
  VillageIcon,
} from '@shelkovo/ui/icons';

import { fullReglamentDataset2026 } from '@/data/reglament/full-2026';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { collectionPageSchema } from '@/lib/news/seo';
import type {
  FullReglamentCommonAsset,
  FullReglamentVillageId,
} from '@/lib/reglament/full-schema';
import { formatReglamentNumber } from '@/lib/reglament/format';
import {
  reglamentAssetsUrl,
  reglamentFullSourcePdfUrl,
  reglamentUrl,
} from '@/lib/reglament/routes';

type AssetCategory = FullReglamentCommonAsset['category'];

const title = 'Общее имущество — Регламент — Шелково Онлайн';
const description =
  'Справочник общего имущества Шелково из полного регламента: дороги, ливневые траншеи, зелень, благоустройство, электроснабжение и охрана.';
const breadcrumbs = withHomeBreadcrumbs([
  { label: 'Регламент', href: reglamentUrl() },
  { label: 'Общее имущество' },
]);
const categoryLabels = {
  roads: 'Дороги и тротуары',
  stormwater: 'Ливневые траншеи',
  greenery: 'Зеленые насаждения',
  forest: 'Лес',
  improvement: 'Объекты благоустройства',
  electricity: 'Электроснабжение',
  security: 'Охрана',
} as const satisfies Record<AssetCategory, string>;
const categoryOrder = [
  'roads',
  'stormwater',
  'greenery',
  'forest',
  'improvement',
  'electricity',
  'security',
] as const satisfies readonly AssetCategory[];
const groups = categoryOrder
  .map((category) => ({
    category,
    title: categoryLabels[category],
    assets: fullReglamentDataset2026.common_assets.filter(
      (asset) => asset.category === category,
    ),
  }))
  .filter((group) => group.assets.length > 0);
const schema = collectionPageSchema({
  name: title,
  description,
  url: reglamentAssetsUrl(),
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Регламент', url: reglamentUrl() },
    { name: 'Общее имущество', url: reglamentAssetsUrl() },
  ]),
  items: groups.map((group) => ({
    name: group.title,
    url: `${reglamentAssetsUrl()}#${group.category}`,
  })),
});

const displayQuantity = (
  quantity: FullReglamentCommonAsset['total'],
): string =>
  quantity.value === null
    ? quantity.raw
    : formatReglamentNumber(quantity.value);
const publicVerificationNote = (
  note: FullReglamentCommonAsset['verification_note'],
): string | null => note;
const villageIcons = {
  'shelkovo-village': VillageIcon,
  'shelkovo-forest': ForestIcon,
  'shelkovo-park': ParkIcon,
  'shelkovo-river': RiverIcon,
} as const satisfies Record<FullReglamentVillageId, typeof VillageIcon>;
const tableHeaderCellClass =
  'sticky top-0 z-10 border-b border-border bg-muted px-4 py-2.5 align-bottom';
const tableHeaderCellRightClass = `${tableHeaderCellClass} text-right`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={reglamentAssetsUrl()}
  keywords={[
    'общее имущество Шелково',
    'регламент Шелково имущество',
    'Шелково дороги охрана освещение',
  ]}
  schema={schema}
>
  <main class="ui-page pb-8 md:pb-12 lg:pb-16">
    <section class="ui-page-header">
      <div class="ui-page-header-stack max-w-5xl">
        <Breadcrumbs items={breadcrumbs} />

        <div class="space-y-4">
          <h1 class="ui-page-title max-w-4xl">Что входит в общее имущество</h1>
          <div
            class="max-w-3xl space-y-3 text-sm leading-6 text-muted-foreground md:text-[0.9375rem]"
          >
            <p>
              Справочник по Приложению №2 полного регламента: дороги, ливневые
              траншеи, зеленые насаждения, благоустройство, электроснабжение и
              охрана по поселкам.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-5 md:px-6" aria-labelledby="assets-title">
      <div class="max-w-6xl space-y-10">
        <h2 id="assets-title" class="sr-only">Таблицы общего имущества</h2>

        {
          groups.map((group) => (
            <section id={group.category} class="space-y-4">
              <div class="max-w-3xl space-y-1.5">
                <h3 class="text-2xl font-bold tracking-tight text-foreground md:text-[2rem]">
                  {group.title}
                </h3>
                <p class="text-sm leading-6 text-muted-foreground md:text-base md:leading-7">
                  Источник:{' '}
                  <ResourceLink
                    class="ui-link text-primary"
                    href={reglamentFullSourcePdfUrl()}
                    type="application/pdf"
                    reload
                  >
                    полный регламент
                  </ResourceLink>
                  , Приложение №2, стр. 128-130. Значения перенесены как
                  справочные факты; пустые ячейки сохранены пустыми.
                </p>
              </div>

              <div
                class="reglament-table-shell ui-sticky-table-shell -mx-5 border-y border-border bg-surface sm:mx-0 sm:rounded-xl sm:border md:mx-0"
                data-ui-sticky-table-shell
              >
                <table class="min-w-[58rem] w-full border-separate border-spacing-0 text-left text-sm">
                  <caption class="sr-only">{group.title}</caption>
                  <thead class="text-xs font-bold uppercase tracking-[0.06em] text-muted-foreground">
                    <tr>
                      <th
                        class:list={[
                          tableHeaderCellClass,
                          'w-[24%] sm:rounded-tl-xl',
                        ]}
                      >
                        Объект
                      </th>
                      <th class={tableHeaderCellClass}>Ед. изм.</th>
                      {fullReglamentDataset2026.villages.map((village) => {
                        const AreaIcon = villageIcons[village.id];

                        return (
                          <th class={tableHeaderCellRightClass}>
                            <span class="inline-flex items-baseline justify-end gap-1.5">
                              <AreaIcon class="h-3.5 w-7 shrink-0" />
                              <span>
                                {village.title.replace('Шелково ', '')}
                              </span>
                            </span>
                          </th>
                        );
                      })}
                      <th
                        class:list={[
                          tableHeaderCellRightClass,
                          'sm:rounded-tr-xl',
                        ]}
                      >
                        Всего
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {group.assets.map((asset) => {
                      const note = publicVerificationNote(
                        asset.verification_note,
                      );

                      return (
                        <tr class="border-t border-border">
                          <td class="border-t border-border px-4 py-3 align-top">
                            <div class="space-y-1.5">
                              <p class="font-semibold text-foreground">
                                {asset.title}
                              </p>
                              {note && (
                                <p class="text-xs font-semibold leading-5 text-primary">
                                  {note}
                                </p>
                              )}
                            </div>
                          </td>
                          <td class="border-t border-border px-4 py-3 align-top text-muted-foreground">
                            {asset.unit ?? '-'}
                          </td>
                          {fullReglamentDataset2026.villages.map((village) => (
                            <td class="border-t border-border px-4 py-3 text-right align-top text-muted-foreground">
                              {displayQuantity(
                                asset.values_by_village[village.id],
                              )}
                            </td>
                          ))}
                          <td class="border-t border-border px-4 py-3 text-right align-top font-semibold text-foreground">
                            {displayQuantity(asset.total)}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </section>
          ))
        }
      </div>
    </section>
  </main>

  <script>
    import { hydrateStickyTableHeaders } from '@/lib/sticky-table-headers';

    const hydrate = () => hydrateStickyTableHeaders();

    hydrate();
    document.addEventListener('astro:after-swap', hydrate);
    document.addEventListener('astro:page-load', hydrate);
  </script>
</BaseLayout>
