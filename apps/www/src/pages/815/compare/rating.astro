---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import {
  compareBreadcrumbs,
  compareBreadcrumbSchema,
} from '@/compare/lib/breadcrumbs';
import { compareRatingMeta } from '@/compare/lib/seo';
import { canon } from '@/compare/lib/site';
import { withBase } from '@/compare/lib/url';

const pageMeta = compareRatingMeta();
const pageUrl = canon('/rating/');
const breadcrumbLabel = 'Как считается уровень';
const breadcrumbs = [...compareBreadcrumbs(), { label: breadcrumbLabel }];
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageMeta.title,
  description: pageMeta.description,
  url: pageUrl,
  inLanguage: 'ru-RU',
};
const breadcrumb = compareBreadcrumbSchema([
  { name: breadcrumbLabel, item: pageUrl },
]);

const nav = [
  ['summary', 'Что это вообще такое'],
  ['formula', 'Формула и веса'],
  ['adjustments', 'Дополнительные корректировки'],
  ['infra', 'Инфраструктура'],
  ['spaces', 'Общественные пространства'],
  ['service', 'Сервисная модель'],
  ['distance', 'Удаленность от Москвы'],
  ['unknown', 'Неизвестные данные'],
  ['read', 'Как читать результат'],
];

const weights = [
  ['50%', 'Инфраструктура', 'Базовая инженерная и охранная среда'],
  ['25%', 'Общественные пространства', 'Повседневный комфорт и досуг'],
  ['10%', 'Сервисная модель', 'Насколько поселок поддерживается в порядке'],
  ['15%', 'Близость к Москве', 'Приближенное расстояние за пределами МКАД'],
];
const sectionClass = 'scroll-mt-8 py-4 md:py-5';
const panelClass = 'ui-shell bg-[color:var(--color-surface)] p-4 md:p-5';
const panelClassCompact = 'ui-shell bg-[color:var(--color-surface)] p-4';
const panelClassRoomy = 'ui-shell bg-[color:var(--color-surface)] p-5';
const sectionTitleClass =
  'font-heading text-2xl font-bold leading-tight text-foreground md:text-[2rem] md:leading-[1.15]';
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  keywords={pageMeta.keywords}
  schema={[schema, breadcrumb]}
>
  <main class="ui-page pb-6 md:pb-10 lg:pb-12">
    <section class="ui-page-header">
      <div class="ui-page-header-stack">
        <Breadcrumbs items={breadcrumbs} />

        <div
          class="relative grid gap-8 lg:grid-cols-[minmax(0,1.25fr)_20rem] lg:gap-10"
        >
          <div class="max-w-3xl space-y-6">
            <div class="space-y-3">
              <h1 class="ui-page-title max-w-3xl">
                Как считается условный уровень поселка
              </h1>
              <p class="ui-copy max-w-2xl text-muted-foreground">
                Условный уровень показывает качество среды без учета тарифа.
                Сначала он сравнивает поселки по инфраструктуре, сервису и
                близости к Москве, затем помогает понять, насколько разумна цена
                на фоне похожих вариантов.
              </p>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div class={panelClass}>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.06em] text-info-text/80"
                >
                  Важно
                </p>
                <p class="mt-3 text-sm leading-7 text-info-text">
                  Тариф не участвует в формуле. Так дешевые и дорогие поселки
                  сравниваются внутри близкого по качеству диапазона, без
                  смешения цены и среды в одну цифру.
                </p>
              </div>

              <div class={panelClass}>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
                >
                  Коротко
                </p>
                <p class="mt-3 text-sm leading-7 text-muted-foreground">
                  Больше всего весят дороги, вода, газ, канализация, охрана,
                  повседневная среда и близость к Москве. Премиальные опции
                  учитываются, но не перекрывают слабую базу; неполные карточки
                  тянутся к середине шкалы.
                </p>
              </div>
            </div>
          </div>

          <aside class="space-y-4">
            <div class={panelClassRoomy}>
              <p
                class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
              >
                Итоговая структура
              </p>
              <dl class="mt-3 divide-y divide-border">
                {
                  weights.map(([weight, label, note]) => (
                    <div class="py-3 first:pt-0 last:pb-0">
                      <dt class="flex items-baseline justify-between gap-3">
                        <span class="text-sm font-semibold text-foreground">
                          {label}
                        </span>
                        <span class="ui-num text-lg font-bold text-primary">
                          {weight}
                        </span>
                      </dt>
                      <dd class="mt-1 text-xs leading-5 text-muted-foreground">
                        {note}
                      </dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <div
      class="mt-6 grid gap-6 px-5 md:px-6 lg:grid-cols-[minmax(0,1fr)_17rem] lg:items-start"
    >
      <div class="min-w-0 space-y-6">
        <section id="summary" class={sectionClass}>
          <div class="max-w-3xl space-y-4">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              Что это вообще такое
            </p>
            <h2 class={sectionTitleClass}>Индекс среды, а не цена жизни</h2>
            <p class="ui-copy text-muted-foreground">
              Условный уровень отвечает на один вопрос: насколько сильным
              выглядит поселок по собранным данным. В расчет входят инженерия,
              охрана, среда, сервис и примерная близость к Москве.
            </p>
            <p class="ui-copy text-muted-foreground">
              Один и тот же платеж может быть нормальным для сильного поселка и
              завышенным для слабого. Поэтому сначала сравниваем уровень, потом
              отдельно смотрим на стоимость содержания.
            </p>
          </div>
        </section>

        <section id="formula" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              Формула и веса
            </p>
            <h2 class={sectionTitleClass}>Из чего складывается цифра</h2>
            <div
              class="ui-shell overflow-x-auto bg-[color:var(--color-surface)] p-5"
            >
              <pre
                class="ui-num text-sm leading-8 text-foreground"><code>условный уровень =
  50% инфраструктура +
  25% общественные пространства +
  10% сервисная модель +
  15% близость к Москве</code></pre>
            </div>
            <p class="ui-copy text-muted-foreground">
              Каждый блок переводится в шкалу от 0 до 1 и умножается на свой
              вес. Итоговое число от 0 до 100 показывает силу поселка по текущей
              модели оценки.
            </p>
            <div class="grid gap-3 md:grid-cols-2">
              {
                weights.map(([weight, label, note]) => (
                  <div class={panelClassCompact}>
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <h3 class="font-body text-sm font-semibold text-foreground">
                          {label}
                        </h3>
                        <p class="mt-1 text-sm leading-6 text-muted-foreground">
                          {note}
                        </p>
                      </div>
                      <span class="ui-num text-xl font-bold text-primary">
                        {weight}
                      </span>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </section>

        <section id="adjustments" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              Дополнительные корректировки
            </p>
            <h2 class={sectionTitleClass}>Есть два дополнительных сигнала</h2>
            <p class="ui-copy text-muted-foreground">
              Они не связаны с ценой и не меняют тариф. Эти поправки только
              уточняют качество среды по признакам, которые важно не потерять в
              общей формуле.
            </p>
            <div class="grid gap-4 md:grid-cols-2">
              <div
                class="ui-shell border-success-border bg-[color:var(--color-surface)] p-5"
              >
                <p
                  class="text-xs font-semibold uppercase tracking-[0.06em] text-success-text"
                >
                  Плюс к рейтингу
                </p>
                <h3 class="mt-2 text-lg font-bold text-success-text">
                  +4 балла, если вода уже включена в тариф
                </h3>
                <p class="mt-3 text-sm leading-7 text-success-text">
                  Бонус применяется, если подтверждено центральное
                  водоснабжение, а вода уже оплачивается внутри основного тарифа
                  без отдельной доплаты и лимитов.
                </p>
              </div>
              <div
                class="ui-shell border-danger-border bg-[color:var(--color-surface)] p-5"
              >
                <p
                  class="text-xs font-semibold uppercase tracking-[0.06em] text-danger-text"
                >
                  Минус к рейтингу
                </p>
                <h3 class="mt-2 text-lg font-bold text-danger-text">
                  −15 баллов за упоминание в «Коттеджном рабстве»
                </h3>
                <p class="mt-3 text-sm leading-7 text-danger-text">
                  Если поселок фигурирует в канале «Коттеджное рабство», модель
                  считает это сильным негативным сигналом и снижает условный
                  уровень.
                </p>
              </div>
            </div>
          </div>
        </section>

        <section id="infra" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              1. Инфраструктура
            </p>
            <h2 class={sectionTitleClass}>Самый важный блок</h2>
            <p class="ui-copy text-muted-foreground">
              Это основа пригодности поселка для жизни. Если инженерная база
              слабая, высокий уровень не получится даже при красивой концепции,
              воде рядом или премиальных объектах.
            </p>
            <div class="grid gap-4 md:grid-cols-2">
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">
                  Максимально влияют
                </h3>
                <ul
                  class="mt-3 space-y-2 text-sm leading-6 text-muted-foreground"
                >
                  <li>Дороги</li>
                  <li>Вода</li>
                  <li>Газ</li>
                  <li>Канализация</li>
                  <li>Охрана</li>
                  <li>Видеонаблюдение</li>
                  <li>КПП</li>
                </ul>
              </div>
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">
                  Дополняют картину
                </h3>
                <ul
                  class="mt-3 space-y-2 text-sm leading-6 text-muted-foreground"
                >
                  <li>Освещение</li>
                  <li>Тротуары</li>
                  <li>Ливневка</li>
                  <li>Ограждение</li>
                  <li>Подземное электричество</li>
                  <li>Административное здание</li>
                  <li>Магазины и сервисы внутри поселка</li>
                </ul>
              </div>
            </div>
            <div
              class="ui-shell bg-[color:var(--color-surface)] p-5 text-sm leading-7 text-muted-foreground"
            >
              <p>
                Подтвержденный признак получает полный балл. Ограниченный или
                компромиссный вариант получает часть баллов. Если признака нет,
                начисляется ноль.
              </p>
              <p class="mt-3">
                Для некоторых признаков есть градация. Например, полностью
                асфальтированная дорога оценивается выше частичной, гравийная
                ниже, грунтовая дает минимальный вклад.
              </p>
            </div>
          </div>
        </section>

        <section id="spaces" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              2. Общественные пространства
            </p>
            <h2 class={sectionTitleClass}>
              Комфорт среды, а не только премиальные опции
            </h2>
            <p class="ui-copy text-muted-foreground">
              Этот блок оценивает повседневные сценарии: прогулки, детские зоны,
              спорт, доступ к воде и клубную среду. Премиальные признаки не
              должны перевешивать базовую функциональность поселка.
            </p>
            <div class="grid gap-4 md:grid-cols-2">
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">
                  Более значимые признаки
                </h3>
                <ul
                  class="mt-3 space-y-2 text-sm leading-6 text-muted-foreground"
                >
                  <li>Детские площадки</li>
                  <li>Спортивные зоны</li>
                  <li>Пешеходные маршруты</li>
                  <li>Доступ к воде</li>
                  <li>Клубная инфраструктура</li>
                </ul>
              </div>
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">
                  Менее значимые признаки
                </h3>
                <ul
                  class="mt-3 space-y-2 text-sm leading-6 text-muted-foreground"
                >
                  <li>Пляжные зоны</li>
                  <li>Зоны барбекю</li>
                  <li>Бассейн</li>
                  <li>Фитнес-клуб</li>
                  <li>Ресторан</li>
                  <li>Спа-центр</li>
                  <li>Детский клуб, спортлагерь, школа</li>
                </ul>
              </div>
            </div>
            <p class="ui-copy text-muted-foreground">
              Поселок без SPA или ресторана не считается слабым сам по себе.
              Поселок без нормальной среды, прогулок и детских зон обычно
              выглядит хуже для реальной жизни.
            </p>
          </div>
        </section>

        <section id="service" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              3. Сервисная модель
            </p>
            <h2 class={sectionTitleClass}>
              Насколько поселок поддерживается в рабочем состоянии
            </h2>
            <p class="ui-copy text-muted-foreground">
              Здесь оцениваются признаки регулярного обслуживания: вывоз мусора,
              уборка снега и дорог, благоустройство, аварийная поддержка и
              диспетчеризация.
            </p>
            <div class={panelClassRoomy}>
              <ul
                class="grid gap-2 text-sm leading-6 text-muted-foreground sm:grid-cols-2"
              >
                <li>Вывоз мусора</li>
                <li>Уборка снега</li>
                <li>Уборка дорог</li>
                <li>Благоустройство</li>
                <li>Аварийная служба</li>
                <li>Диспетчер</li>
              </ul>
            </div>
            <p class="ui-copy text-muted-foreground">
              Вес этого блока ниже, чем у инфраструктуры. Хороший сервис важен,
              но он не должен компенсировать слабую инженерную базу.
            </p>
          </div>
        </section>

        <section id="distance" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              4. Удаленность от Москвы
            </p>
            <h2 class={sectionTitleClass}>
              Приближенная оценка расстояния, а не времени в пути
            </h2>
            <p class="ui-copy text-muted-foreground">
              Для расчета берется расстояние по координатам до центра Москвы. Из
              него вычитается приблизительный радиус МКАД. Получается условное
              расстояние «за МКАД» с весом 15%.
            </p>
            <div class={panelClassRoomy}>
              <p class="text-sm leading-7 text-muted-foreground">
                Чем дальше поселок за расчетным радиусом, тем слабее вклад в
                итог. Влияние ограничено, чтобы дальний, но сильный поселок не
                проигрывал только из-за расстояния.
              </p>
            </div>
            <div
              class="ui-shell border-warning-border bg-[color:var(--color-surface)] p-5"
            >
              <p class="text-sm leading-7 text-warning-text">
                Важно: здесь не учитываются пробки, качество шоссе, близость к
                станции, пересадки и реальное время дороги. Это именно
                упрощенный прокси расстояния.
              </p>
            </div>
          </div>
        </section>

        <section id="unknown" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              Неизвестные данные
            </p>
            <h2 class={sectionTitleClass}>
              Отсутствие данных не считается автоматическим минусом, но и не
              превращается в скрытый плюс
            </h2>
            <p class="ui-copy text-muted-foreground">
              Если по признаку нет подтвержденной информации, он не превращается
              в ноль автоматически. Модель считает среднее по известным полям и
              смотрит, насколько полно заполнен блок.
            </p>
            <div
              class="ui-shell border-warning-border bg-[color:var(--color-surface)] p-5"
            >
              <p class="text-sm leading-7 text-warning-text">
                Это консервативная настройка. Сильные стороны поселков обычно
                подтверждаются чаще, чем полный список отсутствующих вещей.
                Поэтому неполные карточки нельзя автоматически тянуть вверх.
              </p>
            </div>
            <div class="grid gap-3 md:grid-cols-3">
              <div class={panelClassCompact}>
                <p class="text-sm font-semibold text-foreground">Шаг 1</p>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  Считаем среднее только по известным полям.
                </p>
              </div>
              <div class={panelClassCompact}>
                <p class="text-sm font-semibold text-foreground">Шаг 2</p>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  Считаем, насколько полно заполнен блок.
                </p>
              </div>
              <div class={panelClassCompact}>
                <p class="text-sm font-semibold text-foreground">Шаг 3</p>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  Если данных мало, частично тянем результат к нейтральному
                  уровню посередине шкалы.
                </p>
              </div>
            </div>
            <p class="ui-copy text-muted-foreground">
              Так поселок не проваливается вниз из-за отсутствия данных, но и не
              улетает вверх на 1-2 подтвержденных сильных сторонах. Чем меньше
              заполнена карточка, тем ближе результат к середине диапазона.
            </p>
          </div>
        </section>

        <section id="read" class={sectionClass}>
          <div class="max-w-3xl space-y-5">
            <p
              class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
            >
              Как читать результат
            </p>
            <h2 class={sectionTitleClass}>
              Что означает высокий или низкий уровень
            </h2>
            <div class="grid gap-4 md:grid-cols-3">
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">Высокий</h3>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  Обычно это сильная базовая инфраструктура, понятная среда и
                  неплохая близость к Москве.
                </p>
              </div>
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">Средний</h3>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  Обычно это сочетание сильных и слабых сторон или заметная
                  удаленность при неплохой внутренней среде.
                </p>
              </div>
              <div class={panelClassRoomy}>
                <h3 class="text-base font-bold text-foreground">Низкий</h3>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  Чаще всего это не один минус, а комбинация проблем в
                  инженерии, среде и общих условиях жизни.
                </p>
              </div>
            </div>
            <div
              class="ui-shell border-primary/30 bg-[color:var(--color-surface)] p-5"
            >
              <p class="text-sm leading-7 text-muted-foreground">
                Условный уровень не заменяет тариф. Логика сравнения такая:
                сначала смотрим, насколько поселки сопоставимы по уровню, затем
                задаем вопрос, какой тариф выглядит разумным для этого уровня.
              </p>
              <p class="mt-3 text-sm leading-7 text-muted-foreground">
                Если по поселку мало подтвержденных данных, рейтинг стоит читать
                осторожнее. Модель специально не награждает такие карточки
                автоматически высоким уровнем.
              </p>
            </div>
          </div>
        </section>
      </div>

      <aside class="space-y-4 lg:sticky lg:top-6">
        <div class="hidden border-l border-border pl-4 lg:block">
          <p
            class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
          >
            На странице
          </p>
          <nav class="mt-3 space-y-1">
            {
              nav.map(([id, label]) => (
                <a
                  href={withBase(`/rating/#${id}`)}
                  class="block rounded-sm border border-transparent px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-muted-soft hover:text-foreground aria-[current=true]:border-primary/30 aria-[current=true]:bg-[color:var(--color-primary-soft)] aria-[current=true]:font-semibold aria-[current=true]:text-primary"
                  data-rating-nav-link
                  data-section-id={id}
                >
                  {label}
                </a>
              ))
            }
          </nav>
        </div>

        <div class="border-t border-border pt-4">
          <p
            class="text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
          >
            Напоминание
          </p>
          <p class="mt-3 text-sm leading-7 text-muted-foreground">
            Если вы сортируете список по условному уровню, вы сортируете именно
            по качеству среды по нашей модели, а не по цене, не по престижу и не
            по ликвидности.
          </p>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const navLinks = Array.from(
      document.querySelectorAll('[data-rating-nav-link]'),
    );
    const sections = navLinks.map((link) => {
      const id = link.getAttribute('data-section-id');
      return id ? document.getElementById(id) : undefined;
    });

    const setCurrentSection = () => {
      let current = sections.find(Boolean);

      for (const section of sections) {
        if (!section) continue;
        if (section.getBoundingClientRect().top <= 140) current = section;
      }

      for (const link of navLinks) {
        if (link.getAttribute('data-section-id') === current?.id) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      }
    };

    let navFrame = 0;
    const scheduleCurrentSection = () => {
      if (navFrame) return;
      navFrame = window.requestAnimationFrame(() => {
        navFrame = 0;
        setCurrentSection();
      });
    };

    setCurrentSection();
    window.addEventListener('scroll', scheduleCurrentSection, {
      passive: true,
    });
    window.addEventListener('resize', scheduleCurrentSection);
    window.addEventListener('hashchange', scheduleCurrentSection);
  </script>
</BaseLayout>
