---
import Link from '@/compare/components/Link.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/compare/lib/url';

const title = 'Страница не найдена — Сравни с Шелково';
const description =
  'Такой страницы нет или ее адрес изменился. Вернитесь к списку поселков и сравнению тарифов.';
---

<BaseLayout
  title={title}
  description={description}
  robots="noindex, nofollow"
  canonical={withBase('404.html')}
>
  <main class="ui-page pb-12 md:pb-16">
    <section class="ui-page-header text-center">
      <div class="ui-page-header-stack mx-auto max-w-2xl items-center">
        <p class="ui-chip">404</p>
        <h1 class="ui-page-title">Страница не найдена</h1>
        <p class="ui-copy max-w-xl text-muted-foreground">
          Такой страницы нет или ее адрес изменился. Вернитесь к списку поселков
          и сравнению тарифов.
        </p>
      </div>
    </section>

    <div class="mx-auto space-y-4 px-5 text-center md:px-6">
      <Link href="/" class="ui-btn ui-btn-md ui-btn-solid ui-btn-primary">
        К сравнению поселков
      </Link>

      <div class="text-sm text-muted-foreground">
        <p>
          Можно сразу открыть <Link href="/" class="ui-link"
            >список всех поселков</Link
          >.
        </p>
      </div>
    </div>
  </main>
</BaseLayout>
