---
import CommonSpacesTable from '@/compare/components/CommonSpacesTable.svelte';
import InfrastructureTable from '@/compare/components/InfrastructureTable.svelte';
import ServiceTable from '@/compare/components/ServiceTable.svelte';
import SettlementMap from '@/compare/components/SettlementMap.svelte';
import SourcesList from '@/compare/components/SourcesList.svelte';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import { GlobeIcon, MapPinIcon, TelegramIcon } from '@shelkovo/ui/icons';
import {
  formatCurrency,
  formatDistance,
  formatPercentage,
} from '@shelkovo/format';
import { calculateDistance } from '@shelkovo/geo';
import {
  compareBreadcrumbSchema,
  settlementBreadcrumbs,
} from '@/compare/lib/breadcrumbs';
import { loadAllData, findBaseline } from '@/compare/lib/data';
import {
  getLotCalc,
  formatTariffAuto,
  formatTariffBase,
  getTariffCalc,
} from '@/compare/lib/format';
import type { Settlement } from '@/compare/lib/settlement/types';
import { settlementPageMeta } from '@/compare/lib/seo';
import { canon } from '@/compare/lib/site';
import { telegram } from '@/compare/lib/url';

// Generate static paths for all settlements
export async function getStaticPaths() {
  const { settlements, comparisons } = await loadAllData();
  const shelkovo = findBaseline(settlements);

  return settlements.map((settlement) => ({
    params: { slug: settlement.slug },
    props: {
      settlement,
      comparison: comparisons.get(settlement.slug),
      shelkovo,
    },
  }));
}

interface Props {
  settlement: Settlement;
  comparison:
    | {
        tariffDelta: number;
        tariffDeltaPercent: number;
        isCheaper: boolean;
      }
    | undefined;
  shelkovo?: Settlement;
}

const { settlement, comparison, shelkovo } = Astro.props;

// Calculate distance from Shelkovo
const distanceFromShelkovo =
  shelkovo && !settlement.isBaseline
    ? calculateDistance(
        shelkovo.location.lat,
        shelkovo.location.lng,
        settlement.location.lat,
        settlement.location.lng,
      )
    : 0;

const hasPoint =
  Number.isFinite(settlement.location.lat) &&
  Number.isFinite(settlement.location.lng);
const company = settlement.managementCompany;
const companyTitle = company?.title ?? '';
const companyUrl = company?.url ?? '';
const tg = settlement.telegram ? telegram(settlement.telegram) : undefined;
const waterInc = settlement.waterInTariff === true;
const obman = settlement.rabstvo === true;
const obmanUrl = telegram('obmandachniki');
const hasLabels = waterInc || obman || settlement.isBaseline;
const waterTitle =
  'Центральная вода уже включена в тариф и доступна без отдельной доплаты.';
const hasDelta =
  !settlement.isBaseline && !!comparison && comparison.tariffDelta !== 0;
const pageUrl = canon(`/settlements/${settlement.slug}/`);
const pageMeta = settlementPageMeta(settlement, comparison);
const delta =
  hasDelta && comparison
    ? `${comparison.isCheaper ? 'Дешевле' : 'Дороже'} Шелково на ${formatCurrency(Math.abs(comparison.tariffDelta))}.`
    : settlement.isBaseline
      ? 'Базовый поселок для сравнения.'
      : comparison
        ? 'Тариф как в Шелково.'
        : '';
const breadcrumbs = settlementBreadcrumbs(settlement.name);
const breadcrumb = compareBreadcrumbSchema([
  {
    name: settlement.name,
    item: pageUrl,
  },
]);
const same = [settlement.website, ...(tg ? [tg] : [])];
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: settlement.name,
  url: pageUrl,
  description: pageMeta.description,
  keywords: pageMeta.keywords.join(', '),
  address: settlement.location.addressText,
  mainEntityOfPage: pageUrl,
  ...(same.length ? { sameAs: same } : {}),
  ...(hasPoint
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: settlement.location.lat,
          longitude: settlement.location.lng,
        },
      }
    : {}),
};
const tariffCalc = getTariffCalc(
  settlement.tariff,
  settlement.lots,
  settlement.infrastructure,
  settlement.commonSpaces,
);
const lotCalc = getLotCalc(
  settlement.lots,
  settlement.infrastructure,
  settlement.commonSpaces,
);
const tipDesktopId = `${settlement.slug}-tariff-tip-desktop`;
const tipMobileId = `${settlement.slug}-tariff-tip-mobile`;
const assumption = tariffCalc?.assumption;
const heroMap = hasPoint
  ? [
      {
        slug: settlement.slug,
        name: settlement.name,
        shortName: settlement.shortName,
        lat: settlement.location.lat,
        lng: settlement.location.lng,
        normalizedTariff: settlement.tariff.normalizedPerSotkaMonth,
        isBaseline: settlement.isBaseline,
      },
    ]
  : [];
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  keywords={pageMeta.keywords}
  schema={[schema, breadcrumb]}
  preconnectYandexMaps
>
  <main class="ui-page relative pb-6 pt-3 md:pb-10 md:pt-5 lg:pb-12 lg:pt-0">
    <h1 class="sr-only">{settlement.name}</h1>

    <div
      class="relative z-20 mb-4 px-5 md:px-6 lg:absolute lg:inset-x-0 lg:top-6 lg:mb-0"
    >
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <section
      class="hero-bleed relative hidden lg:block"
      data-testid="settlement-hero"
    >
      <div
        class={`hero-map-fade absolute inset-0 overflow-hidden ${hasPoint ? '' : 'hero-map-placeholder'}`}
      >
        {
          hasPoint && (
            <div class="absolute inset-0 opacity-80">
              <SettlementMap
                settlements={heroMap}
                interactive={false}
                popup={false}
                shell={false}
                muted={false}
                height={430}
                focusX={0.8}
                client:visible
              />
            </div>
          )
        }

        <div class="settlement-hero-wash-top absolute inset-0"></div>
        <div class="settlement-hero-wash-bottom absolute inset-0"></div>
      </div>

      <div
        class="ui-page relative z-10 flex flex-col px-5 pt-8 pb-4 md:px-6 xl:pt-10 xl:pb-6"
      >
        <div class="flex items-start justify-end gap-4">
          <div class="flex flex-wrap justify-end gap-2">
            {
              waterInc && (
                <span class="ui-badge ui-badge-water" title={waterTitle}>
                  Вода в тарифе
                </span>
              )
            }
            {
              obman && (
                <a
                  href={obmanUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="ui-badge ui-badge-danger transition-opacity hover:opacity-90"
                  title="Открыть Telegram-канал Коттеджное рабство"
                >
                  Коттеджное рабство
                </a>
              )
            }
            {
              settlement.isBaseline && (
                <span class="ui-badge ui-badge-info">Наш посёлок</span>
              )
            }
          </div>
        </div>

        <div
          class={`w-full max-w-3xl self-start ${hasLabels ? 'mt-0' : 'mt-8'}`}
        >
          <div class="mb-4">
            <div class="flex items-start gap-4">
              <div class="min-w-0">
                <div
                  aria-hidden="true"
                  class="settlement-hero-title-shadow ui-page-title"
                >
                  {settlement.name}
                </div>
              </div>
              <div class="mt-1 flex shrink-0 items-center gap-2">
                {
                  settlement.website && (
                    <a
                      href={settlement.website}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="Открыть сайт поселка"
                      class="ui-icon-btn"
                      title="Перейти на сайт поселка"
                    >
                      <GlobeIcon class="h-5 w-5" />
                    </a>
                  )
                }
                {
                  tg && (
                    <a
                      href={tg}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="Открыть Telegram-канал поселка"
                      class="ui-icon-btn"
                      title="Перейти в Telegram-канал"
                    >
                      <TelegramIcon class="h-5 w-5 text-telegram" />
                    </a>
                  )
                }
                <a
                  href={settlement.location.mapUrl ??
                    `https://yandex.ru/maps/?pt=${settlement.location.lng},${settlement.location.lat}&z=15&l=map`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Открыть поселок на Яндекс.Картах"
                  class="ui-icon-btn"
                  title="Открыть на Яндекс.Картах"
                >
                  <MapPinIcon class="h-5 w-5" />
                </a>
              </div>
            </div>
            <p
              class="settlement-hero-text-shadow mt-2 text-base text-muted-foreground"
            >
              {settlement.location.district}
            </p>
            {
              companyTitle && (
                <div class="settlement-hero-glass-pill mt-3 inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm backdrop-blur-[2px]">
                  <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">
                    Обслуживается
                  </span>
                  {companyUrl ? (
                    <a
                      href={companyUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-semibold text-foreground underline decoration-foreground/30 underline-offset-3 transition-colors hover:text-primary"
                      title="Перейти на сайт управляющей компании"
                    >
                      {companyTitle}
                    </a>
                  ) : (
                    <span class="font-semibold text-foreground">
                      {companyTitle}
                    </span>
                  )}
                </div>
              )
            }
          </div>

          <div
            class={`grid gap-3 ${hasDelta ? 'grid-cols-[repeat(3,minmax(0,17rem))]' : 'grid-cols-[repeat(2,minmax(0,17rem))]'}`}
          >
            <div
              class="settlement-hero-glass-card relative z-20 rounded-2xl border p-4 backdrop-blur-[2px]"
            >
              <p
                class="mb-1 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
              >
                Тариф
              </p>
              <div class="group relative inline-flex max-w-full">
                <span
                  class={`ui-num text-xl font-bold text-foreground ${tariffCalc ? 'cursor-help' : ''}`}
                  tabindex={tariffCalc ? 0 : undefined}
                  aria-describedby={tariffCalc ? tipDesktopId : undefined}
                >
                  {formatTariffAuto(settlement.tariff)}
                </span>
                {
                  tariffCalc && (
                    <div
                      id={tipDesktopId}
                      role="tooltip"
                      class="settlement-hero-tooltip pointer-events-none absolute left-0 top-full z-[80] mt-2 hidden w-[min(88vw,25rem)] rounded-xl border p-3 text-left backdrop-blur-md group-hover:block group-focus-within:block"
                    >
                      <p class="text-xs text-muted-foreground">
                        {tariffCalc.intro}
                      </p>
                      {assumption && (
                        <p class="mt-1 text-xs text-muted-foreground">
                          {assumption}
                        </p>
                      )}
                      {lotCalc && (
                        <div class="mt-2 border-t border-border/60 pt-2">
                          <p class="text-xs font-semibold text-foreground">
                            Средняя площадь участка
                          </p>
                          <p class="mt-1 text-xs text-muted-foreground">
                            Данные: {lotCalc.known}
                          </p>
                          {lotCalc.factors && (
                            <p class="text-xs text-muted-foreground">
                              Вычет: {lotCalc.factors}
                            </p>
                          )}
                          <p class="text-xs text-foreground">
                            Итого: {lotCalc.total}
                          </p>
                        </div>
                      )}
                      <div
                        class={`mt-2 space-y-2 ${lotCalc ? 'border-t border-border/60 pt-2' : ''}`}
                      >
                        {tariffCalc.rows.map((item) => (
                          <div>
                            <p class="text-xs font-semibold text-foreground">
                              {item.title}
                            </p>
                            <p class="text-xs text-muted-foreground">
                              {item.source}
                            </p>
                            <p class="text-xs text-foreground">
                              {item.formula}
                            </p>
                          </div>
                        ))}
                      </div>
                      <p class="mt-2 text-xs font-semibold text-foreground">
                        Итого: {tariffCalc.total}
                      </p>
                    </div>
                  )
                }
              </div>
              {
                settlement.tariff.normalizedIsEstimate && (
                  <p class="mt-1 text-xs text-muted-foreground opacity-75">
                    {formatTariffBase(settlement.tariff)}
                  </p>
                )
              }
              {
                settlement.tariff.note && (
                  <p class="mt-1 text-xs text-muted-foreground">
                    {settlement.tariff.note}
                  </p>
                )
              }
            </div>

            {
              hasDelta && comparison && (
                <div class="settlement-hero-glass-card rounded-2xl border p-4 backdrop-blur-[2px]">
                  <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-muted-foreground">
                    Разница с Шелково
                  </p>
                  <p
                    class={`ui-num text-xl font-bold ${comparison.isCheaper ? 'text-success-text' : 'text-warning-text'}`}
                  >
                    {comparison.isCheaper ? '−' : '+'}
                    {formatCurrency(Math.abs(comparison.tariffDelta))}
                  </p>
                  <p class="mt-1 text-xs text-muted-foreground">
                    {comparison.isCheaper ? 'Дешевле' : 'Дороже'} на{' '}
                    {formatPercentage(comparison.tariffDeltaPercent / 100, {
                      signed: false,
                    })}
                  </p>
                </div>
              )
            }

            <div
              class="settlement-hero-glass-card rounded-2xl border p-4 backdrop-blur-[2px]"
            >
              <p
                class="mb-1 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
              >
                Расположение
              </p>
              <p class="text-sm font-semibold text-foreground">
                {settlement.location.addressText}
              </p>
              {
                distanceFromShelkovo > 0 && (
                  <p class="mt-1 text-xs text-muted-foreground">
                    {formatDistance(distanceFromShelkovo)} от Шелково
                  </p>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <header
      class="mb-4 px-6 pb-4 pt-1 md:mb-8 md:px-8 md:pb-8 md:pt-1 lg:hidden"
    >
      <div
        class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between"
      >
        <div>
          <div class="mb-2 space-y-3">
            <div class="min-w-0 flex-1">
              <div aria-hidden="true" class="ui-page-title">
                {settlement.name}
              </div>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              {
                settlement.website && (
                  <a
                    href={settlement.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Открыть сайт поселка"
                    class="ui-btn ui-btn-sm ui-btn-outline min-h-9"
                    title="Перейти на сайт поселка"
                  >
                    <GlobeIcon class="h-4 w-4" />
                    <span>Сайт</span>
                  </a>
                )
              }
              {
                tg && (
                  <a
                    href={tg}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Открыть Telegram-канал поселка"
                    class="ui-btn ui-btn-sm ui-btn-outline min-h-9"
                    title="Перейти в Telegram-канал"
                  >
                    <TelegramIcon class="h-4 w-4 text-telegram" />
                    <span>Telegram</span>
                  </a>
                )
              }
              <a
                href={settlement.location.mapUrl ??
                  `https://yandex.ru/maps/?pt=${settlement.location.lng},${settlement.location.lat}&z=15&l=map`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Открыть поселок на Яндекс.Картах"
                class="ui-btn ui-btn-sm ui-btn-outline min-h-9"
                title="Открыть на Яндекс.Картах"
              >
                <MapPinIcon class="h-4 w-4" />
                <span>Карта</span>
              </a>
            </div>
          </div>
        </div>
        <p class="text-muted-foreground">
          {settlement.location.district}
        </p>
        {
          companyTitle && (
            <p class="mt-2 text-sm text-muted-foreground">
              Обслуживается:{' '}
              {companyUrl ? (
                <a
                  href={companyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold text-foreground underline decoration-foreground/30 underline-offset-2 transition-colors hover:text-primary"
                  title="Перейти на сайт управляющей компании"
                >
                  {companyTitle}
                </a>
              ) : (
                <span class="font-semibold text-foreground">
                  {companyTitle}
                </span>
              )}
            </p>
          )
        }
      </div>

      {
        hasLabels && (
          <div class="mt-4 flex flex-wrap gap-2">
            {waterInc && (
              <span class="ui-badge ui-badge-water" title={waterTitle}>
                Вода в тарифе
              </span>
            )}
            {obman && (
              <a
                href={obmanUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="ui-badge ui-badge-danger transition-opacity hover:opacity-90"
                title="Открыть Telegram-канал Коттеджное рабство"
              >
                Коттеджное рабство
              </a>
            )}
            {settlement.isBaseline && (
              <span class="ui-badge ui-badge-info">Наш посёлок</span>
            )}
          </div>
        )
      }
    </header>

    <section
      class="mb-5 px-6 py-0 md:mb-8 md:px-8 lg:hidden"
      data-testid="base-info-section"
    >
      <h2 class="sr-only">Паспорт поселка</h2>

      <div class="max-w-3xl">
        <p
          class="font-body text-xs font-semibold uppercase tracking-[0.06em] text-muted-foreground"
        >
          Тариф на обслуживание
        </p>
        <div class="mt-1 flex flex-wrap items-end gap-x-4 gap-y-1">
          <div
            class="ui-num group relative inline-flex max-w-full text-3xl font-bold leading-tight text-foreground"
          >
            <span
              class={tariffCalc ? 'cursor-help' : ''}
              tabindex={tariffCalc ? 0 : undefined}
              aria-describedby={tariffCalc ? tipMobileId : undefined}
            >
              {formatTariffAuto(settlement.tariff)}
            </span>
            {
              tariffCalc && (
                <div
                  id={tipMobileId}
                  role="tooltip"
                  class="settlement-hero-tooltip pointer-events-none absolute left-0 top-full z-[80] mt-2 hidden w-[min(92vw,25rem)] rounded-xl border p-3 text-left text-sm backdrop-blur-md group-hover:block group-focus-within:block"
                >
                  <p class="text-xs text-muted-foreground">
                    {tariffCalc.intro}
                  </p>
                  {assumption && (
                    <p class="mt-1 text-xs text-muted-foreground">
                      {assumption}
                    </p>
                  )}
                  {lotCalc && (
                    <div class="mt-2 border-t border-border/60 pt-2">
                      <p class="text-xs font-semibold text-foreground">
                        Средняя площадь участка
                      </p>
                      <p class="mt-1 text-xs text-muted-foreground">
                        Данные: {lotCalc.known}
                      </p>
                      {lotCalc.factors && (
                        <p class="text-xs text-muted-foreground">
                          Вычет: {lotCalc.factors}
                        </p>
                      )}
                      <p class="text-xs text-foreground">
                        Итого: {lotCalc.total}
                      </p>
                    </div>
                  )}
                  <div
                    class={`mt-2 space-y-2 ${lotCalc ? 'border-t border-border/60 pt-2' : ''}`}
                  >
                    {tariffCalc.rows.map((item) => (
                      <div>
                        <p class="text-xs font-semibold text-foreground">
                          {item.title}
                        </p>
                        <p class="text-xs text-muted-foreground">
                          {item.source}
                        </p>
                        <p class="text-xs text-foreground">{item.formula}</p>
                      </div>
                    ))}
                  </div>
                  <p class="mt-2 text-xs font-semibold text-foreground">
                    Итого: {tariffCalc.total}
                  </p>
                </div>
              )
            }
          </div>
          {
            settlement.tariff.normalizedIsEstimate && (
              <span class="text-base text-muted-foreground">
                {formatTariffBase(settlement.tariff)}
              </span>
            )
          }
          {
            settlement.tariff.note && (
              <span class="text-base text-muted-foreground">
                {settlement.tariff.note}
              </span>
            )
          }
        </div>

        {
          hasDelta && comparison && (
            <p class="mt-3 text-base leading-7 text-muted-foreground">
              <span class="font-semibold text-foreground">
                Сравнение с Шелково:{' '}
              </span>
              <span
                class={`ui-num font-bold ${comparison.isCheaper ? 'text-success-text' : 'text-warning-text'}`}
              >
                {comparison.isCheaper ? '−' : '+'}
                {formatCurrency(Math.abs(comparison.tariffDelta))}
              </span>
              , {comparison.isCheaper ? 'дешевле' : 'дороже'} на{' '}
              {formatPercentage(comparison.tariffDeltaPercent / 100, {
                signed: false,
              })}
            </p>
          )
        }

        <p class="mt-2 text-base leading-7 text-muted-foreground">
          <span class="font-semibold text-foreground">Расположение: </span>
          {settlement.location.addressText}
          {
            distanceFromShelkovo > 0 && (
              <span>, {formatDistance(distanceFromShelkovo)} от Шелково</span>
            )
          }
        </p>
      </div>
    </section>

    <section
      class="mb-4 px-5 py-3 md:mb-5 md:px-6"
      data-testid="infrastructure-section"
    >
      <InfrastructureTable
        title="Инфраструктура"
        infra={settlement.infrastructure}
        shelkovoInfra={!settlement.isBaseline
          ? shelkovo?.infrastructure
          : undefined}
        client:idle
      />
    </section>

    <section
      class="mb-4 px-5 py-3 md:mb-5 md:px-6"
      data-testid="common-spaces-section"
    >
      <CommonSpacesTable
        title="Общие пространства"
        spaces={settlement.commonSpaces}
        shelkovoSpaces={!settlement.isBaseline
          ? shelkovo?.commonSpaces
          : undefined}
        client:idle
      />
    </section>

    <section
      class="mb-4 px-5 py-3 md:mb-5 md:px-6"
      data-testid="services-section"
    >
      <ServiceTable
        title="Модель обслуживания"
        services={settlement.serviceModel}
        shelkovoServices={!settlement.isBaseline
          ? shelkovo?.serviceModel
          : undefined}
        client:idle
      />
    </section>

    {
      settlement.sources.length > 0 && (
        <section
          class="mb-4 px-5 py-3 md:mb-5 md:px-6"
          data-testid="sources-section"
        >
          <h2 class="mb-4 text-xl font-bold text-foreground">Источники</h2>
          <SourcesList sources={settlement.sources} />
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
