---
import type { GetStaticPaths } from 'astro';

import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { BreadcrumbItem } from '@/lib/breadcrumbs';
import { kbBreadcrumbs } from '@/lib/kb/breadcrumbs';
import { loadKbPages } from '@/lib/kb/load';
import type { KbPage } from '@/lib/kb/types';
import { renderMarkdown } from '@/lib/markdown/render';

interface Props {
  readonly page: KbPage;
  readonly breadcrumbs: readonly BreadcrumbItem[];
}

const KB_TITLE = 'База знаний';

export const getStaticPaths = (async () => {
  const pages = await loadKbPages();
  const rootSourceId = 'index';
  const hasRootPage = pages.some(
    (page) => page.sourceId === rootSourceId && !page.routeSlug,
  );

  if (!hasRootPage) {
    throw new Error('kb root page "src/data/kb/index.md" not found');
  }

  return pages.map((page) => ({
    params: {
      slug: page.routeSlug,
    },
    props: {
      page,
      breadcrumbs: kbBreadcrumbs(page, pages),
    },
  }));
}) satisfies GetStaticPaths;

const { page, breadcrumbs } = Astro.props;
const title = page.routeSlug
  ? `${page.title} — ${KB_TITLE} — Шелково Онлайн`
  : `${KB_TITLE} — Шелково Онлайн`;
const bodyHtml = page.body ? renderMarkdown(page.body) : undefined;
---

<BaseLayout title={title} canonical={page.canonical} robots={page.robots}>
  <main class="ui-page pb-8 md:pb-12 lg:pb-14">
    <header class="ui-page-header">
      <div class="ui-page-header-stack max-w-4xl">
        <Breadcrumbs items={breadcrumbs} />

        <h1 class="ui-page-title">{page.title}</h1>
      </div>
    </header>

    {
      bodyHtml && (
        <article class="px-5 md:px-6">
          <div class="ui-prose" set:html={bodyHtml} />
        </article>
      )
    }
  </main>
</BaseLayout>
