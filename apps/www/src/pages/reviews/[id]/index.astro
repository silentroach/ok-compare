---
import type { GetStaticPaths } from 'astro';
import Breadcrumbs from '@shelkovo/ui/Breadcrumbs.astro';

import ReviewAspectList from '@/components/reviews/ReviewAspectList.astro';
import ReviewMeta from '@/components/reviews/ReviewMeta.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  withHomeBreadcrumbs,
  withHomeSchemaBreadcrumbs,
} from '@/lib/breadcrumbs';
import { renderMarkdown } from '@/lib/markdown/render';
import { loadReview, loadReviews } from '@/lib/reviews/load';
import { reviewPageSchema } from '@/lib/reviews/seo';
import { reviewsUrl } from '@/lib/reviews/routes';
import {
  formatReviewAuthor,
  formatReviewTitle,
  REVIEWS_PROSE,
} from '@/lib/reviews/view';

export const getStaticPaths = (async () => {
  const reviews = await loadReviews();

  return reviews.map((review) => ({
    params: { id: review.id },
  }));
}) satisfies GetStaticPaths;

const id = Astro.params.id;

if (!id) {
  throw new Error('review id is required');
}

const review = await loadReview(id);

if (!review) {
  throw new Error(`review "${id}" not found`);
}

const reviewTitle = formatReviewTitle(review);
const title = `${reviewTitle} — Отзывы — Шелково Онлайн`;
const description = `Отзыв собственника ${formatReviewAuthor(review)} о жизни в Шелково.`;
const bodyHtml = renderMarkdown(review.body);
const breadcrumbs = withHomeBreadcrumbs([
  { label: 'Отзывы', href: reviewsUrl() },
  { label: reviewTitle },
]);
const schema = reviewPageSchema({
  review,
  breadcrumbs: withHomeSchemaBreadcrumbs([
    { name: 'Отзывы', url: reviewsUrl() },
    { name: reviewTitle, url: review.url },
  ]),
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={review.url}
  type="article"
  keywords={['отзывы Шелково', reviewTitle]}
  schema={schema}
>
  <main class="ui-page pb-8 md:pb-12 lg:pb-14">
    <header class="ui-page-header">
      <div class="ui-page-header-stack max-w-4xl">
        <Breadcrumbs items={breadcrumbs} linkLast />
        <div class="space-y-4">
          <h1 class="ui-page-title">{reviewTitle}</h1>
          <ReviewMeta review={review} showVerified />
        </div>
      </div>
    </header>

    <article class="space-y-8 px-5 md:px-6">
      <div class={REVIEWS_PROSE} set:html={bodyHtml} />
      <ReviewAspectList aspects={review.aspects} />
      <section
        aria-labelledby="review-disclaimer"
        class="ui-shell max-w-[65ch] px-4 py-4 md:px-5"
      >
        <h2
          id="review-disclaimer"
          class="font-body text-base font-semibold text-foreground"
        >
          Отказ от ответственности
        </h2>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          Отзывы — это авторские тексты собственников. Владелец сайта проверяет,
          что автор является текущим собственником участка или дома в Шелково,
          но не является автором отзыва, не редактирует текст и не подтверждает
          каждое фактическое утверждение. Мнение автора может не совпадать с
          позицией владельца сайта. Ответственность за сведения, оценки и
          формулировки в отзыве несет автор в пределах закона.
        </p>
      </section>
    </article>
  </main>
</BaseLayout>
