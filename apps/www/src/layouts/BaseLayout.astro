---
import '@shelkovo/ui/styles.css';
import '../styles/site.css';
import { ClientRouter, fade } from 'astro:transitions';
import {
  BRAND_KEYWORDS,
  collectKeywords,
  imageMimeType,
  serializeSchema,
} from '@shelkovo/seo';
import FontPreloads from '@shelkovo/ui/FontPreloads.astro';
import type { SchemaDoc } from '@shelkovo/seo';
import SiteFooter from '@shelkovo/ui/SiteFooter.astro';
import { browserColor, themeColor } from '@shelkovo/ui/theme';
import { absoluteUrl, canon } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  keywords?: string | string[];
  robots?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: string;
  schema?: SchemaDoc | readonly SchemaDoc[];
}

const {
  title = 'Шелково Онлайн',
  description = 'Новости, статус сервисов и справочная информация о поселке Шелково и связанных проектах.',
  keywords,
  robots,
  canonical: href,
  image,
  imageAlt,
  type = 'website',
  schema,
} = Astro.props;

const canonical = canon(href ?? Astro.url.pathname);
const keywordContent = collectKeywords(keywords, BRAND_KEYWORDS).join(', ');
const social = image ? absoluteUrl(image) : undefined;
const socialAlt = social ? (imageAlt ?? title) : undefined;
const socialMime = social ? imageMimeType(social) : undefined;
const docs = serializeSchema(schema);
const prod = import.meta.env.PROD;
const ymId = 108975391;
const ym = `(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,'script','https://mc.yandex.ru/metrika/tag.js?id=${ymId}','ym');ym(${ymId},'init',{ssr:true,clickmap:true,referrer:document.referrer,url:location.href,accurateTrackBounce:true,trackLinks:true});`;
const ymTransitions = `(() => {if (window.__shelkovoYmTransitions) return;window.__shelkovoYmTransitions = true;let href = location.href;document.addEventListener('astro:page-load', () => {if (location.href === href) return;href = location.href;if (typeof window.ym === 'function') window.ym(${ymId}, 'hit', href, { title: document.title });});})();`;
const contentTransition = fade({ duration: '60ms' });
---

<!doctype html>
<html lang="ru" transition:name="root" transition:animate="none">
  <head>
    <base href={import.meta.env.BASE_URL} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <FontPreloads />
    <meta
      name="theme-color"
      content={themeColor.light}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColor.dark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="description" content={description} />
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content="Шелково Онлайн" />
    <meta name="apple-mobile-web-app-title" content="Шелково" />
    <meta name="msapplication-TileColor" content={browserColor.tile} />
    <meta name="msapplication-TileImage" content="/mstile-150x150.png" />
    <link rel="canonical" href={canonical} />
    {robots && <meta name="robots" content={robots} />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Шелково Онлайн" />
    {social && <meta property="og:image" content={social} />}
    {socialAlt && <meta property="og:image:alt" content={socialAlt} />}
    {socialMime && <meta property="og:image:type" content={socialMime} />}

    <meta
      name="twitter:card"
      content={social ? 'summary_large_image' : 'summary'}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {social && <meta name="twitter:image" content={social} />}
    {socialAlt && <meta name="twitter:image:alt" content={socialAlt} />}

    <link rel="preconnect" href="https://mc.yandex.ru" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="mask-icon"
      href="/safari-pinned-tab.svg"
      color={browserColor.mask}
    />
    <title>{title}</title>
    {docs.map((item) => <script type="application/ld+json" set:html={item} />)}
    <ClientRouter />
    {prod && <script is:inline type="text/javascript" set:html={ym} />}
    {
      prod && (
        <script is:inline type="text/javascript" set:html={ymTransitions} />
      )
    }
  </head>
  <body class="ui-root-site flex min-h-screen flex-col text-foreground">
    {
      prod && (
        <noscript>
          <div>
            <img
              src={`https://mc.yandex.ru/watch/${ymId}`}
              style="position:absolute; left:-9999px;"
              alt=""
            />
          </div>
        </noscript>
      )
    }
    <div
      class="flex-1"
      transition:name="site-content"
      transition:animate={contentTransition}
    >
      <slot />
    </div>
    <SiteFooter />
  </body>
</html>
