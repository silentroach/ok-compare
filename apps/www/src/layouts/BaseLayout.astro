---
import '@shelkovo/ui/styles.css';
import SiteFooter from '@shelkovo/ui/SiteFooter.astro';
import { themeColor } from '@shelkovo/ui/theme';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Шелково Онлайн',
  description = 'Главный сайт поселка Шелково и связанных проектов.',
} = Astro.props;

const root = Astro.site ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, root).toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <base href={import.meta.env.BASE_URL} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="theme-color"
      content={themeColor.light}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColor.dark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content="Шелково Онлайн" />
    <meta name="apple-mobile-web-app-title" content="Шелково" />
    <meta name="msapplication-TileColor" content="#dceeff" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#8a5a36" />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col text-foreground">
    <div class="flex-1">
      <slot />
    </div>
    <SiteFooter />
  </body>
</html>
