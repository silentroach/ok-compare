---
import '@shelkovo/ui/styles.css';
import { themeColor } from '@shelkovo/ui/theme';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Шелково Онлайн',
  description = 'Главный сайт поселка Шелково и связанных проектов.',
} = Astro.props;

const root = Astro.site ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, root).toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <base href={import.meta.env.BASE_URL} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="theme-color"
      content={themeColor.light}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColor.dark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-foreground">
    <slot />
  </body>
</html>
