---
import Forest from '@shelkovo/ui/icons/areas/Forest.astro';
import Park from '@shelkovo/ui/icons/areas/Park.astro';
import River from '@shelkovo/ui/icons/areas/River.astro';
import Village from '@shelkovo/ui/icons/areas/Village.astro';

import type { NewsArea } from '../lib/news/schema';
import { formatNewsArea } from '../lib/news/view';

interface Props {
  readonly area: NewsArea;
}

const { area }: Props = Astro.props;

const AREA_ICONS = {
  river: River,
  forest: Forest,
  park: Park,
  village: Village,
} as const;

const label = formatNewsArea(area);
const Icon = AREA_ICONS[area];
---

<span
  title={label}
  aria-label={label}
  role="img"
  class="inline-flex shrink-0 items-center justify-center leading-none"
>
  <Icon class="block h-4 w-auto" />
</span>
