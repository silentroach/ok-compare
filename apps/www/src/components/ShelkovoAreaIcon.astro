---
import {
  ForestIcon,
  ParkIcon,
  RiverIcon,
  VillageIcon,
} from '@shelkovo/ui/icons';

import type { NewsArea } from '../lib/news/schema';
import { formatNewsArea } from '../lib/news/view';

interface Props {
  readonly area: NewsArea;
}

const { area }: Props = Astro.props;

const AREA_ICONS = {
  river: RiverIcon,
  forest: ForestIcon,
  park: ParkIcon,
  village: VillageIcon,
} as const;

const label = formatNewsArea(area);
const Icon = AREA_ICONS[area];
---

<span
  title={label}
  aria-label={label}
  role="img"
  class="inline-flex shrink-0 items-center justify-center leading-none"
>
  <Icon class="block h-4 w-auto" />
</span>
