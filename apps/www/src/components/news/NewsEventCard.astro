---
import CalendarPlusIcon from '@shelkovo/ui/icons/system/CalendarPlus.astro';
import type { NewsEvent } from '@/lib/news/schema';
import { buildNewsEventMapUrl, formatNewsEventRange } from '@/lib/news/view';

interface Props {
  readonly event: NewsEvent;
}

const { event } = Astro.props;
const eventRange = formatNewsEventRange(event);
const mapUrl = buildNewsEventMapUrl(event);
const hasCoordinates = event.coordinates !== undefined;
const mapLabel = hasCoordinates
  ? 'Открыть точку на Яндекс Картах'
  : 'Найти место на Яндекс Картах';
---

<section
  class="news-event-card relative isolate overflow-hidden rounded-[1.25rem] border border-border-strong bg-surface-raised px-5 py-5 shadow-[var(--shadow-2)] md:px-7 md:py-6"
  aria-labelledby="news-event-title"
>
  <div
    class:list={[
      'news-event-map-layer absolute inset-0 -z-20',
      hasCoordinates
        ? 'news-event-map-layer--located'
        : 'news-event-map-layer--placeholder',
    ]}
    aria-hidden="true"
  >
    {hasCoordinates && <span class="news-event-map-pin" />}
  </div>
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-r from-surface-raised via-surface-raised/95 to-surface-raised/80"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-3xl space-y-5">
    <div class="space-y-3">
      <span class="ui-chip news-event-card-chip">Событие</span>
      <div class="space-y-2">
        <h2
          id="news-event-title"
          class="text-2xl font-semibold tracking-tight text-foreground md:text-3xl"
        >
          {event.title}
        </h2>
        <p class="ui-copy max-w-2xl text-muted-foreground">
          Встреча из этой новости добавлена отдельным файлом календаря.
        </p>
      </div>
    </div>

    <dl class="grid gap-3 text-base leading-6 md:grid-cols-[max-content_1fr]">
      <dt class="font-semibold text-muted-foreground">Когда</dt>
      <dd class="font-medium text-foreground">
        <time datetime={event.starts_iso}>{eventRange}</time>
      </dd>

      {
        event.location && (
          <>
            <dt class="font-semibold text-muted-foreground">Где</dt>
            <dd class="font-medium text-foreground">{event.location}</dd>
          </>
        )
      }
    </dl>

    <div class="flex flex-wrap gap-3">
      <a
        href={event.ics_url}
        download="event.ics"
        class="ui-btn ui-btn-md ui-btn-primary ui-btn-solid"
      >
        <CalendarPlusIcon class="size-4 shrink-0" />
        <span>Добавить в календарь</span>
      </a>

      {
        mapUrl && (
          <a
            href={mapUrl}
            target="_blank"
            rel="noreferrer noopener"
            class="ui-btn ui-btn-md ui-btn-outline"
          >
            {mapLabel}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .news-event-card-chip {
    color: var(--color-primary);
  }

  .news-event-map-layer {
    background:
      radial-gradient(
        circle at 78% 28%,
        oklch(83% 0.155 78 / 0.22),
        transparent 15rem
      ),
      radial-gradient(
        circle at 64% 62%,
        oklch(36% 0.115 143 / 0.1),
        transparent 13rem
      ),
      linear-gradient(
        32deg,
        transparent 47%,
        oklch(82% 0.018 130 / 0.42) 48%,
        transparent 50%
      ),
      linear-gradient(
        124deg,
        transparent 48%,
        oklch(82% 0.018 130 / 0.35) 49%,
        transparent 51%
      ),
      linear-gradient(oklch(88% 0.012 135 / 0.46) 1px, transparent 1px),
      linear-gradient(90deg, oklch(88% 0.012 135 / 0.46) 1px, transparent 1px),
      oklch(98.8% 0.003 125);
    background-size:
      auto,
      auto,
      9rem 9rem,
      11rem 11rem,
      2rem 2rem,
      2rem 2rem,
      auto;
    filter: saturate(1.08);
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      rgb(0 0 0 / 0.72) 34%,
      black 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      rgb(0 0 0 / 0.72) 34%,
      black 100%
    );
  }

  .news-event-map-layer--located {
    opacity: 0.84;
  }

  .news-event-map-layer--placeholder {
    opacity: 0.54;
    filter: saturate(0.9);
  }

  .news-event-map-pin {
    position: absolute;
    top: 43%;
    right: clamp(3rem, 18vw, 12rem);
    width: 0.95rem;
    height: 0.95rem;
    border: 2px solid var(--color-surface-raised);
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow:
      0 0 0 0.45rem oklch(83% 0.155 78 / 0.24),
      0 0.75rem 1.5rem oklch(24% 0.04 145 / 0.18);
  }

  @media (max-width: 47.999rem) {
    .news-event-map-layer {
      opacity: 0.38;
      -webkit-mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        rgb(0 0 0 / 0.7) 28%,
        black 100%
      );
      mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        rgb(0 0 0 / 0.7) 28%,
        black 100%
      );
    }

    .news-event-map-pin {
      top: 24%;
      right: 18%;
    }
  }
</style>
