---
import CalendarPlusIcon from '@shelkovo/ui/icons/system/CalendarPlus.astro';
import ResourceLink from '@shelkovo/ui/ResourceLink.astro';
import type { NewsEvent } from '@/lib/news/types';
import {
  buildNewsEventMapEmbedUrl,
  buildNewsEventMapUrl,
  formatNewsEventMonth,
  formatNewsEventRange,
} from '@/lib/news/view';

interface Props {
  readonly event: NewsEvent;
  readonly variant?: 'wide' | 'compact';
}

const { event, variant = 'wide' } = Astro.props;
const isCompact = variant === 'compact';
const eventRange = formatNewsEventRange(event);
const mapUrl = buildNewsEventMapUrl(event);
const mapEmbedUrl = isCompact
  ? buildNewsEventMapEmbedUrl(event, { centerOffsetYPx: 50 })
  : undefined;
const hasCoordinates = event.coordinates !== undefined;
const eventDateParts = event.startsIso.slice(0, 10).split('-');
const eventDay = String(Number(eventDateParts[2] ?? ''));
const eventMonth = formatNewsEventMonth(event.startsIso);
const eventTime = event.endsTime
  ? `${event.startsTime}-${event.endsTime}`
  : event.startsTime;
const calendarFilename = `${event.slug}.ics`;
const titleId = `news-event-title-${event.slug}`;
---

{
  isCompact ? (
    <aside
      class:list={[
        'news-event-compact-card',
        hasCoordinates ? 'news-event-compact-card--mapped' : undefined,
      ]}
      aria-labelledby={titleId}
    >
      {mapEmbedUrl && (
        <div class="news-event-compact-map" aria-hidden="true">
          <div class="news-event-compact-map-layer">
            <iframe
              src={mapEmbedUrl}
              title={`Фоновая карта места события: ${event.location ?? event.title}`}
              loading="lazy"
              tabindex="-1"
              class="news-event-compact-map-frame"
            />
            <span class="ui-map-marker news-event-compact-map-pin" />
          </div>
        </div>
      )}

      <div class="news-event-compact-content">
        <time class="news-event-compact-date-card" datetime={event.startsIso}>
          <span class="news-event-compact-day">{eventDay}</span>
          <span class="news-event-compact-month">{eventMonth}</span>
        </time>

        <h2 id={titleId} class="news-event-compact-title">
          {event.title}
        </h2>

        <ul class="news-event-compact-meta">
          <li>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="news-event-compact-icon"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="8.25" />
              <path d="M12 7.75v4.75l3 1.75" />
            </svg>
            <span>{eventTime}</span>
          </li>

          {event.location && (
            <li>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="news-event-compact-icon"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M19 10.2c0 5.1-7 10.05-7 10.05s-7-4.95-7-10.05a7 7 0 1 1 14 0Z" />
                <circle cx="12" cy="10.2" r="2.35" />
              </svg>
              <span>{event.location}</span>
            </li>
          )}
        </ul>

        <div class="news-event-compact-actions">
          <ResourceLink
            href={event.icsUrl}
            download={calendarFilename}
            class="news-event-compact-action news-event-compact-action--primary"
            aria-label="Добавить в календарь"
            title="Добавить в календарь"
          >
            <CalendarPlusIcon class="news-event-calendar-icon news-event-compact-icon news-event-compact-icon--calendar" />
          </ResourceLink>

          {mapUrl && (
            <a
              href={mapUrl}
              target="_blank"
              rel="noreferrer noopener"
              class="news-event-compact-action"
              aria-label="Открыть на Яндекс Картах"
              title="Открыть на Яндекс Картах"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="news-event-compact-icon"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M19 10.2c0 5.1-7 10.05-7 10.05s-7-4.95-7-10.05a7 7 0 1 1 14 0Z" />
                <circle cx="12" cy="10.2" r="2.35" />
              </svg>
            </a>
          )}
        </div>
      </div>
    </aside>
  ) : (
    <section class="news-event-card" aria-labelledby={titleId}>
      <div
        class:list={[
          'news-event-map-layer',
          hasCoordinates
            ? 'news-event-map-layer--located'
            : 'news-event-map-layer--placeholder',
        ]}
        aria-hidden="true"
      />
      {hasCoordinates && <span class="news-event-map-pin" aria-hidden="true" />}

      <div class="news-event-panel">
        <time class="news-event-date-card" datetime={event.startsIso}>
          <span class="news-event-date-day">{eventDay}</span>
          <span class="news-event-date-month">{eventMonth}</span>
          <span class="news-event-date-time">{eventTime}</span>
        </time>

        <div class="news-event-main">
          <h2 id={titleId} class="news-event-title">
            {event.title}
          </h2>
          <p class="news-event-details">
            <time datetime={event.startsIso}>{eventRange}</time>
            {event.location && (
              <>
                <span class="news-event-details-divider" aria-hidden="true">
                  ·
                </span>
                <span>{event.location}</span>
              </>
            )}
          </p>

          <div class="news-event-actions">
            <ResourceLink
              href={event.icsUrl}
              download={calendarFilename}
              class="ui-btn ui-btn-md news-event-action news-event-action--calendar"
            >
              <CalendarPlusIcon class="news-event-calendar-icon" />
              <span>Добавить в календарь</span>
            </ResourceLink>

            {mapUrl && (
              <a
                href={mapUrl}
                target="_blank"
                rel="noreferrer noopener"
                class="ui-btn ui-btn-md ui-btn-outline news-event-action news-event-action--map"
              >
                Открыть на Яндекс Картах
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .news-event-card,
  .news-event-compact-card {
    --news-event-wash-strong: color-mix(
      in oklab,
      var(--color-surface-raised) 96%,
      transparent
    );
    --news-event-wash-base: color-mix(
      in oklab,
      var(--color-surface-raised) 92%,
      transparent
    );
    --news-event-wash-mid: color-mix(
      in oklab,
      var(--color-surface-raised) 56%,
      transparent
    );
    --news-event-wash-soft: color-mix(
      in oklab,
      var(--color-surface-raised) 28%,
      transparent
    );
    --news-event-map-line: color-mix(
      in oklab,
      var(--color-border) 58%,
      transparent
    );
    --news-event-map-road-strong: color-mix(
      in oklab,
      var(--color-surface-raised) 88%,
      transparent
    );
    --news-event-map-road: color-mix(
      in oklab,
      var(--color-surface-raised) 70%,
      transparent
    );
    --news-event-panel-border: color-mix(
      in oklab,
      var(--color-surface-raised) 72%,
      transparent
    );
    --news-event-panel-bg: color-mix(
      in oklab,
      var(--color-surface-raised) 88%,
      transparent
    );
  }

  .news-event-card {
    position: relative;
    isolation: isolate;
    display: grid;
    align-items: center;
    min-height: 17rem;
    overflow: hidden;
    padding: clamp(0.85rem, 2vw, 1.25rem);
    border: 1px solid
      color-mix(
        in oklab,
        var(--color-border-strong) 74%,
        var(--color-primary) 26%
      );
    border-radius: 1.35rem;
    background: var(--color-primary-soft-2);
    box-shadow: var(--shadow-2);
  }

  .news-event-card::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        90deg,
        var(--news-event-wash-strong) 0%,
        var(--news-event-wash-base) 43%,
        var(--news-event-wash-mid) 70%,
        var(--news-event-wash-soft) 100%
      ),
      radial-gradient(
        circle at 22% 18%,
        color-mix(in oklab, var(--color-accent) 18%, transparent),
        transparent 15rem
      );
    content: '';
  }

  .news-event-card::after {
    position: absolute;
    inset: 0 0 auto;
    height: 0.22rem;
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-accent) 42%,
      transparent 82%
    );
    content: '';
  }

  .news-event-map-layer {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(
        circle at 73% 34%,
        color-mix(in oklab, var(--color-accent) 24%, transparent),
        transparent 10rem
      ),
      radial-gradient(
        circle at 24% 78%,
        color-mix(in oklab, var(--color-primary) 14%, transparent),
        transparent 10rem
      ),
      linear-gradient(
        34deg,
        transparent 45%,
        var(--news-event-map-road-strong) 46%,
        var(--news-event-map-road-strong) 49%,
        transparent 50%
      ),
      linear-gradient(
        118deg,
        transparent 48%,
        var(--news-event-map-road) 49%,
        var(--news-event-map-road) 51%,
        transparent 52%
      ),
      linear-gradient(var(--news-event-map-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--news-event-map-line) 1px, transparent 1px),
      linear-gradient(
        135deg,
        var(--color-primary-soft-2),
        var(--color-surface-muted)
      );
    background-size:
      auto,
      auto,
      8rem 8rem,
      9rem 9rem,
      1.75rem 1.75rem,
      1.75rem 1.75rem,
      auto;
    filter: saturate(1.04);
  }

  .news-event-map-layer--placeholder {
    filter: saturate(0.82);
    opacity: 0.72;
  }

  .news-event-map-pin {
    position: absolute;
    z-index: 0;
    top: 38%;
    left: 86%;
    width: 1rem;
    height: 1rem;
    border: 2px solid var(--color-surface-raised);
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow:
      0 0 0 0.5rem color-mix(in oklab, var(--color-accent) 22%, transparent),
      0 0.75rem 1.5rem var(--color-shadow);
  }

  .news-event-map-pin::after {
    position: absolute;
    top: calc(100% - 0.08rem);
    left: 50%;
    width: 0.52rem;
    height: 0.52rem;
    background: var(--color-accent);
    transform: translateX(-50%) rotate(45deg);
    content: '';
  }

  .news-event-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(5.75rem, 6.5rem) minmax(0, 1fr);
    gap: clamp(0.9rem, 2vw, 1.25rem);
    width: min(100%, 43rem);
    padding: clamp(0.9rem, 2vw, 1.2rem);
    border: 1px solid var(--news-event-panel-border);
    border-radius: 1.1rem;
    background: var(--news-event-panel-bg);
    box-shadow: 0 1rem 2.2rem var(--color-shadow);
    backdrop-filter: blur(2px);
  }

  .news-event-date-card {
    display: grid;
    align-content: center;
    justify-items: start;
    min-height: 7.5rem;
    padding: 0.8rem;
    border: 1px solid
      color-mix(in oklab, var(--color-accent) 40%, var(--color-border) 60%);
    border-radius: 0.9rem;
    background:
      radial-gradient(
        circle at 85% 18%,
        color-mix(in oklab, var(--color-accent) 22%, transparent),
        transparent 4rem
      ),
      color-mix(
        in oklab,
        var(--color-surface-raised) 82%,
        var(--color-accent-soft) 18%
      );
    color: var(--color-foreground);
    text-decoration: none;
  }

  .news-event-date-day {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(2.65rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.075em;
    line-height: 0.88;
  }

  .news-event-date-month {
    display: block;
    margin-top: 0.28rem;
    color: color-mix(in oklab, var(--color-earth) 76%, var(--color-text) 24%);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .news-event-date-time {
    display: inline-flex;
    margin-top: 0.85rem;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .news-event-main {
    display: grid;
    align-content: center;
    gap: 0.8rem;
    min-width: 0;
  }

  .news-event-title {
    max-width: 16ch;
    margin: 0;
    color: var(--color-foreground);
    font-size: clamp(1.35rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .news-event-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.45rem;
    max-width: 34rem;
    margin: 0;
    color: var(--color-muted-foreground);
    font-size: 0.98rem;
    font-weight: 650;
    line-height: 1.45;
  }

  .news-event-details-divider {
    color: var(--color-accent-text);
    font-weight: 900;
  }

  .news-event-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding-top: 0.1rem;
  }

  .news-event-action {
    min-height: 2.45rem;
    border-radius: 999px;
    padding-inline: 0.95rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .news-event-action--calendar {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: color-mix(in oklab, var(--color-text) 78%, var(--color-earth) 22%);
    box-shadow: 0 0.55rem 1.2rem
      color-mix(in oklab, var(--color-accent) 18%, transparent);
  }

  .news-event-action--calendar:hover {
    border-color: var(--color-accent-hover);
    background: var(--color-accent-hover);
    color: var(--color-text);
  }

  .news-event-action--map {
    background: color-mix(
      in oklab,
      var(--color-surface-raised) 82%,
      transparent
    );
  }

  :global(.news-event-calendar-icon) {
    width: 1rem;
    height: 1rem;
    flex: none;
  }

  @media (max-width: 47.999rem) {
    .news-event-card {
      align-items: stretch;
      min-height: 0;
      padding: 0.7rem;
      border-radius: 1.15rem;
    }

    .news-event-card::before {
      background:
        linear-gradient(
          180deg,
          var(--news-event-wash-strong) 0%,
          var(--news-event-wash-base) 58%,
          var(--news-event-wash-mid) 100%
        ),
        radial-gradient(
          circle at 18% 14%,
          color-mix(in oklab, var(--color-accent) 18%, transparent),
          transparent 12rem
        );
    }

    .news-event-panel {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      padding: 0.85rem;
      border-radius: 0.95rem;
      background: var(--news-event-panel-bg);
    }

    .news-event-date-card {
      grid-template-columns: auto auto 1fr;
      align-items: end;
      gap: 0.45rem 0.55rem;
      min-height: 0;
      padding: 0.75rem;
    }

    .news-event-date-day {
      font-size: 2.6rem;
    }

    .news-event-date-month {
      margin: 0 0 0.22rem;
    }

    .news-event-date-time {
      justify-self: end;
      margin: 0 0 0.28rem;
    }

    .news-event-title {
      max-width: none;
      font-size: clamp(1.3rem, 7vw, 1.7rem);
    }

    .news-event-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .news-event-action {
      width: 100%;
      min-height: 2.65rem;
      white-space: normal;
    }

    .news-event-map-pin {
      top: 76%;
      left: 86%;
    }
  }

  .news-event-compact-card {
    position: relative;
    isolation: isolate;
    display: grid;
    overflow: hidden;
    padding: 1rem;
    border: 1px solid
      color-mix(
        in oklab,
        var(--color-border-strong) 76%,
        var(--color-primary) 24%
      );
    border-radius: 1rem;
    background: var(--color-surface-raised);
    box-shadow: 0 0.65rem 1.55rem var(--color-shadow);
  }

  .news-event-compact-card--mapped {
    background:
      linear-gradient(
        110deg,
        var(--news-event-wash-strong) 0%,
        var(--news-event-wash-base) 52%,
        var(--news-event-map-road) 100%
      ),
      var(--color-surface-raised);
  }

  .news-event-compact-map {
    --news-event-compact-map-frame-shift-y: 50px;
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    opacity: 0.36;
    pointer-events: none;
  }

  .news-event-compact-map-layer {
    position: absolute;
    top: -66%;
    right: auto;
    bottom: -8%;
    left: 0;
    width: 150%;
    height: 164%;
  }

  .news-event-compact-map-frame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    filter: grayscale(0.18) saturate(0.78) contrast(0.92);
    transform: translateY(var(--news-event-compact-map-frame-shift-y));
  }

  .news-event-compact-map-pin {
    --ui-map-marker-size: 18px;
    --ui-map-marker-color: var(--color-primary);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .news-event-compact-content {
    display: grid;
    gap: 0.85rem;
  }

  .news-event-compact-date-card {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    border-bottom: 1px solid
      color-mix(in oklab, var(--color-border) 78%, var(--color-accent) 22%);
    padding-bottom: 0.75rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .news-event-compact-day {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.08em;
    line-height: 0.9;
  }

  .news-event-compact-month {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
  }

  .news-event-compact-title {
    margin: 0;
    color: var(--color-foreground);
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 0.98rem + 0.42vw, 1.22rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1.05;
    text-wrap: balance;
  }

  .news-event-compact-meta {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .news-event-compact-meta li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: var(--color-muted-foreground);
    font-size: 0.9rem;
    font-weight: 560;
    line-height: 1.35;
  }

  .news-event-compact-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.55rem;
    padding-top: 0.15rem;
  }

  .news-event-compact-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.45rem;
    height: 2.45rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 0.62rem;
    background: color-mix(
      in oklab,
      var(--color-surface-raised) 82%,
      transparent
    );
    color: var(--color-foreground);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .news-event-compact-action:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .news-event-compact-action--primary {
    border-color: color-mix(
      in oklab,
      var(--color-accent) 62%,
      var(--color-border) 38%
    );
    color: var(--color-accent-text);
  }

  .news-event-compact-icon {
    width: 1.05rem;
    height: 1.05rem;
    flex: none;
  }

  :global(.news-event-compact-icon) {
    width: 1.05rem;
    height: 1.05rem;
    flex: none;
  }

  :global(.news-event-compact-icon--calendar) {
    transform: translateY(-0.04rem);
  }
</style>
