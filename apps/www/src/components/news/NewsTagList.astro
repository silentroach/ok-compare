---
interface Item {
  readonly label: string;
  readonly url: string;
  readonly count?: number;
}

interface Props {
  readonly items: readonly Item[];
  readonly compact?: boolean;
  readonly className?: string;
}

const { items, compact = false, className } = Astro.props;
---

{
  items.length > 0 &&
    (compact ? (
      <ul class:list={['flex flex-wrap gap-2', className]}>
        {items.map((item) => (
          <li>
            <a
              href={item.url}
              class="ui-chip transition-colors hover:border-[color:var(--color-border-strong)] hover:text-foreground"
            >
              <span>{item.label}</span>
              {typeof item.count === 'number' && (
                <span class="ui-num text-[0.72rem]">{item.count}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <ul class:list={['grid gap-3 sm:grid-cols-2 lg:grid-cols-3', className]}>
        {items.map((item) => (
          <li>
            <a
              href={item.url}
              class="ui-shell flex h-full items-center justify-between gap-3 p-4 transition-colors hover:border-[color:var(--color-border-strong)] hover:bg-[color:var(--color-surface-raised)]"
            >
              <span class="font-semibold text-foreground">{item.label}</span>
              {typeof item.count === 'number' && (
                <span class="ui-num text-sm text-muted-foreground">
                  {item.count}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    ))
}
