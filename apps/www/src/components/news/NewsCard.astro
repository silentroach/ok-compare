---
import { StarIcon } from '@shelkovo/ui/icons';
import type { NewsListArticle } from '../../lib/news/types';
import NewsMeta from './NewsMeta.astro';
import NewsTagList from './NewsTagList.astro';

interface Props {
  readonly article: NewsListArticle;
  readonly featured?: boolean;
}

const { article, featured = false } = Astro.props;
---

<article
  class:list={[
    featured ? 'ui-shell-strong' : 'ui-shell',
    'h-full overflow-hidden',
  ]}
>
  {
    featured && article.cover && (
      <img
        src={article.cover.url}
        alt={article.cover.alt}
        loading="lazy"
        width={article.cover.width}
        height={article.cover.height}
        class="aspect-video w-full border-b border-border-strong object-cover"
      />
    )
  }

  <div class="space-y-4 px-5 py-5 md:px-6 md:py-6">
    <div class="space-y-3">
      <h3 class="ui-card-title flex items-start gap-2">
        <a href={article.url} class="ui-link">{article.title}</a>
        {
          article.pinned && (
            <>
              <span
                class="mt-1 inline-flex shrink-0 text-star"
                title="закреплено сверху"
                aria-hidden="true"
              >
                <StarIcon class="size-4" />
              </span>
              <span class="sr-only">Закреплено сверху</span>
            </>
          )
        }
      </h3>

      <NewsMeta
        publishedIso={article.publishedIso}
        author={article.author}
        fullAuthorName
      />
    </div>

    <p class="ui-copy text-muted-foreground">{article.summary}</p>

    <NewsTagList items={article.tags} compact />
  </div>
</article>
