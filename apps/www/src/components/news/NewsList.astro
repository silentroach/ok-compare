---
import type { NewsListArticle } from '../../lib/news/types';
import NewsCard from './NewsCard.astro';

interface Props {
  readonly articles: readonly NewsListArticle[];
  readonly featured?: boolean;
  readonly empty?: string;
  readonly hideFirstBorder?: boolean;
}

const {
  articles,
  featured = false,
  empty,
  hideFirstBorder = false,
} = Astro.props;
const flushFirstBorder = !featured && hideFirstBorder;
---

{
  articles.length > 0 ? (
    <ul
      role={featured ? 'list' : undefined}
      class:list={[
        featured ? 'grid gap-4 lg:grid-cols-2' : 'space-y-4',
        flushFirstBorder && 'news-list--flush-first',
      ]}
    >
      {articles.map((article) => (
        <li>
          <NewsCard article={article} featured={featured} />
        </li>
      ))}
    </ul>
  ) : (
    empty && (
      <div class="ui-shell px-5 py-6 md:px-6 md:py-7">
        <p class="ui-copy text-muted-foreground">{empty}</p>
      </div>
    )
  )
}
