---
import type { NewsListArticle } from '../../lib/news/schema';
import NewsCard from './NewsCard.astro';

interface Props {
  readonly articles: readonly NewsListArticle[];
  readonly featured?: boolean;
  readonly empty?: string;
}

const { articles, featured = false, empty } = Astro.props;
---

{
  articles.length > 0 ? (
    <ul
      role={featured ? 'list' : undefined}
      class:list={[featured ? 'grid gap-4 lg:grid-cols-2' : 'space-y-4']}
    >
      {articles.map((article) => (
        <li>
          <NewsCard article={article} featured={featured} />
        </li>
      ))}
    </ul>
  ) : (
    empty && (
      <div class="ui-shell px-5 py-6 md:px-6 md:py-7">
        <p class="ui-copy text-muted-foreground">{empty}</p>
      </div>
    )
  )
}
