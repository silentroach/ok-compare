---
import type { NewsPhoto } from '../../lib/news/schema';

interface Props {
  readonly photos: readonly NewsPhoto[];
  readonly title?: string;
  readonly heading?: 'h2' | 'h3' | 'h4';
  readonly framed?: boolean;
}

const { photos, title = 'Фото', heading = 'h2', framed = true } = Astro.props;

const Heading = heading;
---

{
  photos.length > 0 && (
    <section class:list={framed && ['ui-shell p-6 md:p-7']}>
      <div class="space-y-4">
        <Heading class="text-2xl font-semibold tracking-tight text-foreground">
          {title}
        </Heading>

        <div class="grid gap-4 md:grid-cols-2">
          {photos.map((photo) => (
            <figure class="space-y-2">
              <img
                src={photo.url}
                alt={photo.alt}
                loading="lazy"
                class="w-full rounded-[1.25rem] border border-border bg-[color:var(--color-surface-muted)] object-cover shadow-[var(--shadow-1)]"
              />
              {photo.caption && (
                <figcaption class="text-sm leading-6 text-muted-foreground">
                  {photo.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
