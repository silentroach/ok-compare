---
import { Image } from 'astro:assets';
import type { NewsPhoto } from '@/lib/news/types';

interface Props {
  readonly photos: readonly NewsPhoto[];
  readonly title?: string;
  readonly heading?: 'h2' | 'h3' | 'h4';
}

const { photos, title = 'Фото', heading = 'h2' } = Astro.props;

const Heading = heading;
const MAX_RENDERED_WIDTH = 1600;
const RESPONSIVE_WIDTHS = [480, 768, 960, 1280, 1600];
const galleryPhotos = photos.map((photo, index) => {
  const fullWidth =
    photos.length >= 3 &&
    (index === 0 || (photos.length % 2 === 0 && index === photos.length - 1));
  const width = Math.min(photo.width, MAX_RENDERED_WIDTH);

  return {
    url: photo.url,
    alt: photo.alt,
    caption: photo.caption,
    fullWidth,
    renderedWidth: width,
    renderedHeight: Math.round((photo.height * width) / photo.width),
    widths: RESPONSIVE_WIDTHS.filter((candidate) => candidate <= width),
    sizes: fullWidth
      ? '(min-width: 1180px) 1132px, calc(100vw - 2.5rem)'
      : '(min-width: 1180px) 558px, (min-width: 768px) calc((100vw - 3.5rem) / 2), calc(100vw - 2.5rem)',
  };
});
---

{
  photos.length > 0 && (
    <section class="border-t border-border px-5 pt-6 md:px-6 md:pt-8">
      <div class="space-y-4">
        <Heading class="ui-prose-title">{title}</Heading>

        <div class="grid gap-x-4 gap-y-6 md:grid-cols-2">
          {galleryPhotos.map((photo) => (
            <figure
              class:list={[
                'space-y-2',
                photo.fullWidth ? 'md:col-span-2' : undefined,
              ]}
            >
              <a
                href={photo.url}
                target="_blank"
                rel="noreferrer noopener"
                aria-label={`Открыть фото: ${photo.alt}`}
                class="block focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
              >
                <Image
                  src={photo.url}
                  width={photo.renderedWidth}
                  height={photo.renderedHeight}
                  widths={photo.widths}
                  sizes={photo.sizes}
                  format="webp"
                  quality={82}
                  alt={photo.alt}
                  loading="lazy"
                  decoding="async"
                  class="h-auto w-full border border-border bg-surface-muted"
                />
              </a>
              {photo.caption && (
                <figcaption class="text-sm leading-6 text-muted-foreground">
                  {photo.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
