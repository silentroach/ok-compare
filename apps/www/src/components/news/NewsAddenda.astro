---
import type { NewsAddendum } from '../../lib/news/schema';
import { renderNewsMarkdown } from '../../lib/news/html';
import { NEWS_PROSE } from '../../lib/news/view';
import NewsAttachments from './NewsAttachments.astro';
import NewsMeta from './NewsMeta.astro';
import NewsPhotos from './NewsPhotos.astro';

interface Props {
  readonly items: readonly NewsAddendum[];
}

const { items } = Astro.props;

const addenda = items.map((item) => ({
  ...item,
  html: item.body ? renderNewsMarkdown(item.body) : undefined,
}));
---

{
  addenda.length > 0 && (
    <section class="space-y-4">
      <div class="ui-shell-strong p-6 md:p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
          Поздние уточнения
        </p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-foreground md:text-[2rem]">
          Дополнено
        </h2>
        <p class="mt-2 text-sm leading-7 text-muted-foreground">
          Исходный текст новости не переписываем: новые данные, пояснения и
          вложения остаются отдельными редакционными блоками.
        </p>
      </div>

      <div class="space-y-4">
        {addenda.map((item) => (
          <article class="ui-shell p-6 md:p-7">
            <div class="space-y-4">
              <div class="space-y-3">
                {item.title && (
                  <h3 class="text-xl font-semibold tracking-tight text-foreground">
                    {item.title}
                  </h3>
                )}

                <NewsMeta
                  publishedIso={item.published_iso}
                  time={item.time}
                  author={item.author}
                  isOfficial={item.author.is_official}
                  sourceUrl={item.source_url}
                />
              </div>

              {item.html && <div class={NEWS_PROSE} set:html={item.html} />}

              <NewsPhotos
                photos={item.photos}
                title="Фото"
                heading="h3"
                framed={false}
              />

              <NewsAttachments
                items={item.attachments}
                title="Вложения"
                heading="h3"
                framed={false}
              />
            </div>
          </article>
        ))}
      </div>
    </section>
  )
}
