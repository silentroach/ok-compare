---
import {
  EmailIcon,
  GlobeIcon,
  MapPinIcon,
  PhoneIcon,
  TelegramIcon,
  WhatsAppIcon,
} from '@shelkovo/ui/icons';

import type { Contact, ContactContacts } from '@/lib/contacts/types';
import {
  contactExcerpt,
  contactMethods,
  contactPlace,
} from '@/lib/contacts/view';

type ContactMethodType = keyof ContactContacts;

interface Props {
  readonly contact: Contact;
}

const { contact } = Astro.props;
const methods = contactMethods(contact.contacts);
const place = contactPlace(contact.location);
const excerpt = contactExcerpt(contact);
const methodIcons = {
  phone: PhoneIcon,
  telegram: TelegramIcon,
  whatsapp: WhatsAppIcon,
  email: EmailIcon,
  website: GlobeIcon,
} as const satisfies Record<ContactMethodType, typeof PhoneIcon>;
const methodIconColors = {
  phone: undefined,
  telegram: 'text-telegram',
  whatsapp: 'text-whatsapp',
  email: undefined,
  website: undefined,
} as const satisfies Record<ContactMethodType, string | undefined>;
---

<article class="py-5 md:py-6">
  <div class="space-y-3">
    <h3 class="text-lg font-bold tracking-tight text-foreground md:text-xl">
      {
        contact.hasDetailPage ? (
          <a href={contact.url} class="ui-link">
            {contact.title}
          </a>
        ) : (
          contact.title
        )
      }
    </h3>

    <ul
      class="flex flex-wrap gap-x-4 gap-y-2 text-sm leading-6 text-foreground md:text-base md:leading-7"
    >
      {
        place ? (
          <li>
            <span class="sr-only">{place.label}: </span>
            <a
              href={place.href}
              class="inline-flex items-center gap-1.5 ui-link font-semibold"
            >
              <MapPinIcon class="size-4 shrink-0" />
              {place.title}
            </a>
          </li>
        ) : null
      }

      {
        methods.map((method) => {
          const Icon = methodIcons[method.type];
          const iconColor =
            methodIconColors[method.type] ??
            (!method.href ? 'text-primary' : undefined);
          const value =
            method.type === 'telegram'
              ? method.value.replace(/^@/u, '')
              : method.value;

          return (
            <li>
              <span class="sr-only">{method.label}: </span>
              {method.href ? (
                <a
                  href={method.href}
                  class="inline-flex items-center gap-1.5 ui-link font-semibold"
                >
                  <Icon class:list={['size-4 shrink-0', iconColor]} />
                  {value}
                </a>
              ) : (
                <span class="inline-flex items-center gap-1.5">
                  <Icon class:list={['size-4 shrink-0', iconColor]} />
                  {value}
                </span>
              )}
            </li>
          );
        })
      }
    </ul>

    {
      excerpt ? (
        <p class="max-w-3xl text-base leading-7 text-muted-foreground">
          {excerpt}
        </p>
      ) : null
    }
  </div>
</article>
