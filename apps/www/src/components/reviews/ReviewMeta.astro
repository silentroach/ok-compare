---
import type { Review } from '@/lib/reviews/types';
import {
  formatReviewArea,
  formatReviewAuthor,
  formatReviewDate,
} from '@/lib/reviews/view';

interface Props {
  readonly review: Pick<Review, 'author' | 'area' | 'publishedIso'>;
  readonly showVerified?: boolean;
  readonly className?: string;
}

const { review, showVerified = false, className } = Astro.props;
---

<div
  class:list={[
    'flex flex-wrap items-center gap-x-3 gap-y-1.5 text-sm leading-5 text-muted-foreground',
    className,
  ]}
>
  <time datetime={review.publishedIso}>{formatReviewDate(review)}</time>
  <span aria-hidden="true">•</span>
  <span>{formatReviewAuthor(review)}</span>
  <span aria-hidden="true">•</span>
  <span
    class="inline-flex rounded-full border border-border/80 px-2 py-0.5 text-xs font-medium text-foreground"
  >
    {formatReviewArea(review.area)}
  </span>
  {
    showVerified && (
      <span class="inline-flex rounded-full bg-primary-soft px-2 py-0.5 text-xs font-semibold text-primary">
        проверенный собственник
      </span>
    )
  }
</div>
