---
import type { Review } from '@/lib/reviews/types';
import { formatReviewAspectType, formatReviewTitle } from '@/lib/reviews/view';
import ReviewMeta from './ReviewMeta.astro';

interface Props {
  readonly review: Review;
}

const { review } = Astro.props;
const ratedAspects = review.aspects.filter((aspect) => aspect.rating);
---

<article class="ui-shell h-full px-5 py-5 md:px-6 md:py-6">
  <div class="space-y-4">
    <div class="space-y-3">
      <h3 class="text-2xl font-bold tracking-tight text-foreground">
        <a href={review.url} class="ui-link">{formatReviewTitle(review)}</a>
      </h3>
      <ReviewMeta review={review} />
    </div>

    {
      ratedAspects.length > 0 && (
        <ul class="flex flex-wrap gap-2 text-xs font-semibold text-muted-foreground">
          {ratedAspects.map((aspect) => (
            <li class="rounded-full border border-border/80 px-2 py-1">
              {formatReviewAspectType(aspect.type)}: {aspect.rating} из 5
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>
