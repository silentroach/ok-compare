---
import SiteNav from '@/components/site/SiteNav.astro';
import {
  getHomeStatusAriaLabel,
  getHomeStatusMaintenanceWindows,
  getHomeStatusState,
} from '@/lib/home/status';
import { loadStatusData } from '@/lib/status/load';

const status = await loadStatusData();
const buildNow = Date.now();
const statusState = getHomeStatusState(status.incidents, buildNow);
const statusAriaLabel = getHomeStatusAriaLabel(statusState);
const maintenanceWindows = getHomeStatusMaintenanceWindows(
  status.incidents,
  buildNow,
);
---

<header class="site-header z-40 border-b md:sticky md:top-0">
  <div
    class="ui-page flex min-h-12 items-center justify-between gap-4 px-5 py-2 md:min-h-14 md:px-6 md:py-2.5"
  >
    <a href="/" class="site-header-brand"> Шелково Онлайн </a>

    <div class="hidden md:block">
      <SiteNav
        variant="header"
        statusState={statusState}
        statusAriaLabel={statusAriaLabel}
      />
    </div>

    <details class="site-header-menu md:hidden">
      <summary class="site-header-menu-button">
        <span>Меню</span>
        <span aria-hidden="true" class="site-header-menu-icon"></span>
      </summary>

      <div class="site-header-mobile-panel">
        <SiteNav
          variant="mobile"
          statusState={statusState}
          statusAriaLabel={statusAriaLabel}
          ariaLabel="Главное меню сайта"
        />
      </div>
    </details>
  </div>

  <script
    type="application/json"
    data-home-status-maintenance-windows
    set:html={JSON.stringify(maintenanceWindows)}
  />
</header>

<style>
  .site-header {
    border-color: color-mix(in oklab, var(--color-border) 68%, transparent);
    background: transparent;
  }

  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(
      in oklab,
      var(--color-surface-raised) 74%,
      transparent
    );
    box-shadow:
      inset 0 1px 0
        color-mix(in oklab, var(--color-surface-raised) 86%, transparent),
      0 1px 0 color-mix(in oklab, var(--color-surface-raised) 54%, transparent);
    -webkit-backdrop-filter: saturate(145%) blur(4px);
    backdrop-filter: saturate(145%) blur(4px);
    pointer-events: none;
  }

  @media (max-width: 47.999rem) {
    .site-header {
      position: relative;
    }
  }

  .site-header-brand {
    flex: none;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    text-wrap: balance;
    transition: color 0.2s ease;
  }

  .site-header-brand:is(:hover, :focus-visible) {
    color: var(--color-primary-hover);
    outline: none;
  }

  .site-header-menu {
    position: relative;
    flex: none;
  }

  .site-header-menu-button {
    display: inline-flex;
    min-height: 2.25rem;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface-raised);
    padding: 0.4375rem 0.8125rem;
    color: var(--color-foreground);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.25;
    cursor: pointer;
    user-select: none;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .site-header-menu-button::-webkit-details-marker {
    display: none;
  }

  .site-header-menu-button {
    list-style: none;
  }

  .site-header-menu-button:is(:hover, :focus-visible) {
    border-color: var(--color-primary);
    color: var(--color-primary-hover);
    outline: none;
  }

  .site-header-menu-icon {
    width: 0;
    height: 0;
    border-inline: 0.25rem solid transparent;
    border-top: 0.3125rem solid currentColor;
    opacity: 0.72;
    transition: transform 0.2s ease;
  }

  .site-header-menu[open] .site-header-menu-icon {
    transform: rotate(180deg);
  }

  .site-header-mobile-panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    width: min(20rem, calc(100vw - 2rem));
    border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    border-radius: 1rem;
    background: color-mix(
      in oklab,
      var(--color-surface-raised) 68%,
      transparent
    );
    padding: 0.5rem;
    box-shadow:
      inset 0 1px 0
        color-mix(in oklab, var(--color-surface-raised) 90%, transparent),
      0 1rem 2rem oklch(24% 0.04 145 / 0.12);
    -webkit-backdrop-filter: saturate(165%) blur(16px);
    backdrop-filter: saturate(165%) blur(16px);
  }

  @media (min-width: 48rem) {
    .site-header-brand {
      font-size: 1.0625rem;
    }
  }
</style>
