---
interface Props {
  readonly title: string;
  readonly description: string;
  readonly tone?: 'calm' | 'warning' | 'danger';
}

const { title, description, tone = 'calm' } = Astro.props;

const styleByTone = {
  calm: undefined,
  warning:
    'border-top-color: var(--color-warning-border); background: var(--color-warning-soft);',
  danger:
    'border-top-color: var(--color-danger-border); background: var(--color-danger-soft);',
} as const;
---

<div
  class="border-t border-border px-4 py-5 md:px-5 md:py-6"
  style={styleByTone[tone]}
>
  <div class="max-w-3xl space-y-1.5">
    <p class="text-base font-semibold tracking-tight text-foreground">
      {title}
    </p>
    <p class="text-sm leading-6 text-muted-foreground md:text-[0.9375rem]">
      {description}
    </p>
  </div>
</div>
