---
import { dateTimeFromISO } from '@shelkovo/format';
import AlertCircleIcon from '@shelkovo/ui/icons/system/AlertCircle.astro';
import CheckCircleIcon from '@shelkovo/ui/icons/system/CheckCircle.astro';

import type { StatusService } from '@/lib/status/schema';
import {
  buildStatusTimelineProblemSegments,
  getStatusTimelineSegmentGeometry,
  getStatusTimelineRange,
  type StatusTimelineIncidentInput,
  type StatusTimelineSpan,
} from '@/lib/status/timeline';
import {
  buildStatusTimelineTooltipData,
  buildStatusTimelineTooltipListItemData,
  formatStatusService,
  formatStatusTimelineGroupTitle,
  formatStatusTimelineTooltipGroupLabel,
  formatStatusTimelineTooltipLabel,
} from '@/lib/status/view';

interface Props {
  readonly service: StatusService;
  readonly incidents: readonly StatusTimelineIncidentInput[];
  readonly timelineDays?: number;
}

const { service, incidents, timelineDays = 90 } = Astro.props;

const range = getStatusTimelineRange(Date.now(), timelineDays);
const tooltipId = `status-service-timeline-tooltip-${service}-${timelineDays}`;
const serviceLabel = formatStatusService(service);
const visibleSegmentsById = new Map(
  buildStatusTimelineProblemSegments({ incidents, range }).map((segment) => [
    segment.id,
    segment,
  ]),
);

interface TimelineTooltipSerializedItem {
  readonly kind: StatusTimelineIncidentInput['kind'];
  readonly title: string;
  readonly is_active: boolean;
  readonly started_iso: string;
  readonly started_has_time: boolean;
  readonly ended_iso?: string;
  readonly ended_has_time: boolean;
  readonly duration?: StatusTimelineIncidentInput['duration'];
}

interface TimelineGroup {
  readonly dayKey: string;
  readonly compact: boolean;
  readonly isFuture: boolean;
  readonly items: StatusTimelineIncidentInput[];
  readonly visibleSegments: StatusTimelineSpan[];
}

const STATUS_TIMELINE_COMPACT_MARKER_MS = 60 * 60 * 1000;

const toTimelineSortMs = (value?: string): number => {
  const parsed = Date.parse(value ?? '');

  return Number.isFinite(parsed) ? parsed : Number.POSITIVE_INFINITY;
};

const getTimelineDayKey = (value: string): string =>
  dateTimeFromISO(value).toISODate() ?? value.slice(0, 10);

const isCompactTimelineCandidate = (
  item: StatusTimelineIncidentInput,
  visibleSegment?: StatusTimelineSpan,
): boolean =>
  visibleSegment !== undefined &&
  !item.is_active &&
  !!item.ended_iso &&
  getTimelineDayKey(item.started_iso) === getTimelineDayKey(item.ended_iso);

const buildCompactTimelineMarkerSpan = (
  span: StatusTimelineSpan,
): StatusTimelineSpan | undefined => {
  if (span.endMs <= span.startMs) {
    return undefined;
  }

  const centerMs = span.startMs + (span.endMs - span.startMs) / 2;
  const halfMarkerMs = STATUS_TIMELINE_COMPACT_MARKER_MS / 2;
  const startMs = Math.max(range.startMs, centerMs - halfMarkerMs);
  const endMs = Math.min(range.endMs, centerMs + halfMarkerMs);

  if (endMs <= startMs) {
    return { startMs, endMs };
  }

  return {
    startMs,
    endMs,
  };
};

const serializeTimelineTooltipItems = (
  items: readonly StatusTimelineIncidentInput[],
): string =>
  JSON.stringify(
    items.map(
      ({
        duration,
        ended_has_time,
        ended_iso,
        is_active,
        kind,
        started_has_time,
        started_iso,
        title,
      }) =>
        ({
          kind,
          title,
          is_active,
          started_iso,
          started_has_time,
          ...(ended_iso ? { ended_iso } : {}),
          ended_has_time,
          ...(duration ? { duration } : {}),
        }) satisfies TimelineTooltipSerializedItem,
    ),
  );

const timelineGroups = incidents
  .filter((item) => {
    const visibleSegment = visibleSegmentsById.get(item.id);

    return (
      visibleSegment !== undefined ||
      toTimelineSortMs(item.started_iso) >= range.endMs
    );
  })
  .toSorted(
    (a, b) =>
      toTimelineSortMs(a.started_iso) - toTimelineSortMs(b.started_iso) ||
      toTimelineSortMs(a.ended_iso) - toTimelineSortMs(b.ended_iso) ||
      a.id.localeCompare(b.id),
  )
  .reduce<TimelineGroup[]>((groups, item) => {
    const visibleSegment = visibleSegmentsById.get(item.id);
    const isCompactCandidate = isCompactTimelineCandidate(item, visibleSegment);
    const last = groups.at(-1);
    const dayKey = getTimelineDayKey(item.started_iso);
    const isFuture = visibleSegment === undefined;

    if (
      last &&
      last.compact &&
      isCompactCandidate &&
      last.dayKey === dayKey &&
      last.isFuture === isFuture
    ) {
      last.items.push(item);

      if (visibleSegment) {
        last.visibleSegments.push(visibleSegment);
      }

      return groups;
    }

    groups.push({
      dayKey,
      compact: isCompactCandidate,
      isFuture,
      items: [item],
      visibleSegments: visibleSegment ? [visibleSegment] : [],
    });

    return groups;
  }, [])
  .map((group) => {
    const [firstItem] = group.items;
    const lastItem = group.items.at(-1) ?? firstItem;
    const hasVisibleSpan = group.visibleSegments.length > 0;
    const tooltipItems = group.items.map((item) =>
      buildStatusTimelineTooltipListItemData(item, { nonBreaking: true }),
    );
    const tooltipTitle =
      group.items.length === 1
        ? firstItem.title
        : formatStatusTimelineGroupTitle({
            count: group.items.length,
            startedIso: firstItem.started_iso,
            nonBreaking: true,
          });
    const reachesRangeEnd = group.visibleSegments.some(
      (item) => item.endMs === range.endMs,
    );
    const actualSpan = hasVisibleSpan
      ? {
          startMs: Math.min(
            ...group.visibleSegments.map((item) => item.startMs),
          ),
          endMs: Math.max(...group.visibleSegments.map((item) => item.endMs)),
        }
      : undefined;
    const useCompactMarker = group.compact && group.items.length > 1;
    const geometrySpan =
      useCompactMarker && actualSpan
        ? buildCompactTimelineMarkerSpan(actualSpan)
        : actualSpan;
    const geometry = geometrySpan
      ? getStatusTimelineSegmentGeometry(geometrySpan, range)
      : undefined;
    const geometryStartIso =
      useCompactMarker && geometrySpan
        ? new Date(geometrySpan.startMs).toISOString()
        : undefined;
    const geometryEndIso =
      useCompactMarker && geometrySpan
        ? new Date(geometrySpan.endMs).toISOString()
        : undefined;
    const latestEndedIso = group.items
      .map((item) => item.ended_iso)
      .filter((item) => item !== undefined)
      .toSorted((a, b) => toTimelineSortMs(a) - toTimelineSortMs(b))
      .at(-1);
    const groupEndIso = group.items.some((item) => !item.ended_iso)
      ? undefined
      : latestEndedIso;

    if (group.items.length === 1) {
      const tooltip = buildStatusTimelineTooltipData({
        service,
        incident: firstItem,
        nonBreaking: true,
      });
      const phaseIcon =
        firstItem.kind !== 'incident'
          ? undefined
          : firstItem.is_active
            ? 'alert'
            : firstItem.ended_iso
              ? 'check'
              : undefined;

      return {
        href: firstItem.has_page ? firstItem.url : undefined,
        hidden: !hasVisibleSpan,
        id: firstItem.id,
        left: geometry?.leftPercent,
        compactMarker: useCompactMarker,
        ...(geometryStartIso ? { geometryStartIso } : {}),
        ...(geometryEndIso ? { geometryEndIso } : {}),
        reachesRangeEnd,
        startIso: firstItem.started_iso,
        ...(groupEndIso ? { endIso: groupEndIso } : {}),
        statusKind: firstItem.kind,
        tone: firstItem.kind === 'maintenance' ? 'amber' : 'red',
        tooltip,
        tooltipLabel: formatStatusTimelineTooltipLabel(tooltip),
        tooltipTitle,
        phaseIcon,
        width: geometry?.widthPercent,
      };
    }

    return {
      href: undefined,
      hidden: !hasVisibleSpan,
      id: firstItem.id,
      left: geometry?.leftPercent,
      compactMarker: useCompactMarker,
      ...(geometryStartIso ? { geometryStartIso } : {}),
      ...(geometryEndIso ? { geometryEndIso } : {}),
      reachesRangeEnd,
      startIso: firstItem.started_iso,
      ...(groupEndIso ? { endIso: groupEndIso } : {}),
      statusKind: group.items.some((item) => item.kind === 'incident')
        ? 'incident'
        : 'maintenance',
      tone: group.items.some((item) => item.kind === 'incident')
        ? 'red'
        : 'amber',
      tooltipItems: serializeTimelineTooltipItems(group.items),
      tooltipLabel: formatStatusTimelineTooltipGroupLabel({
        serviceLabel,
        title: tooltipTitle,
        items: tooltipItems,
      }),
      tooltipServiceLabel: serviceLabel,
      tooltipTitle,
      width: geometry?.widthPercent,
    };
  });
---

<div
  class="js-status-service-timeline status-service-timeline"
  data-status-timeline
  data-range-days={String(timelineDays)}
>
  <div class="status-service-timeline__track">
    <div class="status-service-timeline__segments" data-status-timeline-track>
      {
        timelineGroups.map(
          ({
            compactMarker,
            endIso,
            geometryEndIso,
            geometryStartIso,
            href,
            hidden,
            id,
            left,
            phaseIcon,
            reachesRangeEnd,
            statusKind,
            tone,
            tooltip,
            tooltipLabel,
            tooltipItems,
            tooltipServiceLabel,
            tooltipTitle,
            startIso,
            width,
          }) => {
            const TimelineSegment = href ? 'a' : 'span';

            return (
              <TimelineSegment
                href={href}
                tabindex={href ? undefined : '0'}
                title={tooltipLabel}
                aria-label={tooltipLabel}
                data-incident-id={id}
                data-status-problem
                data-status-kind={statusKind}
                data-start={startIso}
                data-end={endIso}
                data-geometry-start={geometryStartIso}
                data-geometry-end={geometryEndIso}
                data-tooltip-service-label={
                  tooltip?.serviceLabel ?? tooltipServiceLabel
                }
                data-tooltip-kind-label={tooltip?.kindLabel}
                data-tooltip-title={tooltip?.title}
                data-tooltip-phase-label={tooltip?.phaseLabel}
                data-tooltip-phase-icon={tooltip ? phaseIcon : undefined}
                data-tooltip-period-label={tooltip?.periodLabel}
                data-tooltip-group-title={tooltip ? undefined : tooltipTitle}
                data-tooltip-items={tooltipItems}
                class:list={[
                  'status-service-timeline__segment status-service-timeline__segment--problem',
                  compactMarker &&
                    'status-service-timeline__segment--compact-marker',
                  reachesRangeEnd &&
                    'status-service-timeline__segment--problem-active-end',
                  tone === 'amber'
                    ? 'status-service-timeline__segment--amber'
                    : 'status-service-timeline__segment--red',
                ]}
                hidden={hidden}
                style={
                  hidden || left === undefined || width === undefined
                    ? undefined
                    : `--segment-left: ${left}; --segment-width: ${width};`
                }
              />
            );
          },
        )
      }
    </div>
  </div>

  <div
    id={tooltipId}
    class="status-service-timeline__tooltip tooltip-glass"
    data-status-timeline-tooltip
    role="tooltip"
    aria-hidden="true"
    hidden
  >
    <p class="status-service-timeline__tooltip-title">
      <span
        class="status-service-timeline__tooltip-phase-icon status-service-timeline__tooltip-phase-icon--alert"
        data-status-tooltip-phase-icon-alert
        aria-hidden="true"
        hidden
      >
        <AlertCircleIcon class="size-4" />
      </span>
      <span
        class="status-service-timeline__tooltip-phase-icon status-service-timeline__tooltip-phase-icon--check"
        data-status-tooltip-phase-icon-check
        aria-hidden="true"
        hidden
      >
        <CheckCircleIcon class="size-4" />
      </span>
      <span data-status-tooltip-title></span>
    </p>
    <p class="status-service-timeline__tooltip-row" data-status-tooltip-period>
    </p>
    <div
      class="status-service-timeline__tooltip-list"
      data-status-tooltip-list
      hidden
    >
    </div>
  </div>
</div>

<style>
  .status-service-timeline {
    position: relative;
    z-index: 0;
    display: grid;
    gap: 0.45rem;
    isolation: isolate;
  }

  .status-service-timeline[data-status-tooltip-open='true'] {
    z-index: 30;
  }

  .status-service-timeline__track {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-border) 92%, white 8%);
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-success) 14%, white 86%);
    box-shadow: inset 0 1px 2px oklch(24% 0.04 145 / 0.05);
    height: 1rem;
  }

  .status-service-timeline__segments {
    position: absolute;
    inset: 0 0.2rem;
    height: 100%;
  }

  .status-service-timeline__segment {
    --segment-resolved-width: max(
      calc(var(--segment-width) * 1%),
      var(--segment-min-width, 0.45rem)
    );
    --segment-bleed-end: 0px;
    position: absolute;
    top: 50%;
    left: max(
      0px,
      min(
        calc(var(--segment-left) * 1%),
        calc(100% - var(--segment-resolved-width))
      )
    );
    width: calc(var(--segment-resolved-width) + var(--segment-bleed-end));
    height: 0.62rem;
    border-radius: 999px;
    transform: translateY(-50%) scaleY(var(--segment-scale, 1));
    transform-origin: center;
    margin: 0;
    border: 0;
    padding: 0;
    font: inherit;
    appearance: none;
  }

  .status-service-timeline__segment--green {
    background: color-mix(in oklab, var(--color-success) 82%, white 18%);
    pointer-events: none;
    z-index: 1;
  }

  .status-service-timeline__segment--amber {
    background: var(--color-warning);
    z-index: 2;
  }

  .status-service-timeline__segment--red {
    background: var(--color-danger);
    z-index: 3;
  }

  .status-service-timeline__segment--problem {
    box-shadow: 0 0 0 1px
      color-mix(in oklab, var(--color-success) 14%, white 86%);
    transition:
      filter 160ms ease,
      transform 160ms ease;
  }

  .status-service-timeline__segment--problem:hover,
  .status-service-timeline__segment--problem:focus-visible {
    --segment-scale: 1.16;
    filter: saturate(1.15) brightness(0.97);
  }

  .status-service-timeline__segment--problem:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .status-service-timeline__segment--problem-active-end {
    --segment-bleed-end: 0.2rem;
  }

  .status-service-timeline__segment--compact-marker {
    --segment-min-width: 0.3rem;
  }

  .status-service-timeline__tooltip {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 50%;
    z-index: 20;
    display: grid;
    gap: 0.4rem;
    width: min(22rem, calc(100% - 0.5rem));
    max-width: calc(100vw - 1.5rem);
    padding: 0.75rem 0.85rem;
    border: 1px solid oklch(100% 0 0 / 0.44);
    border-radius: 1rem;
    background: oklch(100% 0 0 / 0.9);
    color: var(--color-text);
    backdrop-filter: blur(5px);
    box-shadow: 0 1.1rem 2.5rem oklch(24% 0.03 230 / 0.18);
    pointer-events: none;
    transform: translateX(-50%);
  }

  .status-service-timeline__tooltip[data-side='above'] {
    top: auto;
    bottom: calc(100% + 0.6rem);
  }

  .status-service-timeline__tooltip-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text);
  }

  .status-service-timeline__tooltip-row {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  .status-service-timeline__tooltip-list {
    display: grid;
    gap: 0.55rem;
  }

  .status-service-timeline__tooltip-item {
    display: grid;
    gap: 0.4rem;
  }

  .status-service-timeline__tooltip-item
    + .status-service-timeline__tooltip-item {
    padding-top: 0.7rem;
    border-top: 1px solid
      color-mix(in oklab, var(--color-border) 76%, white 24%);
  }

  .status-service-timeline__tooltip-phase-icon {
    display: inline-flex;
    inline-size: 1rem;
    block-size: 1rem;
    flex: none;
    margin-right: 0.18rem;
    align-items: center;
    justify-content: center;
    vertical-align: -0.17em;
  }

  .status-service-timeline__tooltip-phase-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .status-service-timeline__tooltip-phase-icon--alert {
    color: var(--color-danger);
  }

  .status-service-timeline__tooltip-phase-icon--check {
    color: var(--color-success);
  }
</style>

<script>
  import { hydrateStatusTimelines } from '@/lib/status/timeline.dom';

  hydrateStatusTimelines();
</script>
