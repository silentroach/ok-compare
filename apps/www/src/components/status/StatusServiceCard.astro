---
import DamIcon from '@shelkovo/ui/icons/services/Dam.astro';
import LightningIcon from '@shelkovo/ui/icons/services/Lightning.astro';
import WaterDropIcon from '@shelkovo/ui/icons/services/WaterDrop.astro';

import StatusServiceTimeline from './StatusServiceTimeline.astro';
import type { StatusServiceSummary } from '../../lib/status/schema';
import {
  formatStatusDate,
  formatStatusDuration,
  formatStatusService,
  formatStatusServiceState,
} from '../../lib/status/view';

interface Props {
  readonly summary: StatusServiceSummary;
  readonly timelineDays?: number;
  readonly serviceHref?: string;
}

const { summary, timelineDays = 90, serviceHref } = Astro.props;

const serviceLabel = formatStatusService(summary.service);
const stateLabel = formatStatusServiceState(summary.service_status);
const latestRecord = summary.incidents[0];
const latestMoment = latestRecord
  ? formatStatusDate(latestRecord.started_iso, {
      hasTime: latestRecord.started_has_time,
      nonBreaking: true,
    })
  : undefined;
const latestDuration =
  latestRecord && !latestRecord.is_active && latestRecord.duration
    ? formatStatusDuration(latestRecord.duration, { nonBreaking: true })
    : undefined;
const stateClass = {
  green: 'text-[color:var(--color-success)]',
  amber: 'text-[color:var(--color-warning-text)]',
  red: 'text-[color:var(--color-danger)]',
} as const;
const serviceMeta = {
  electricity: {
    Icon: LightningIcon,
    iconWrapClass:
      'bg-[color:var(--color-primary-soft)] text-[color:var(--color-primary)]',
  },
  water: {
    Icon: WaterDropIcon,
    iconWrapClass:
      'bg-[color:var(--color-water-soft)] text-[color:var(--color-water)]',
  },
  dam: {
    Icon: DamIcon,
    iconWrapClass:
      'bg-[color:var(--color-surface-muted)] text-[color:var(--color-earth)]',
  },
} as const;
const ServiceIcon = serviceMeta[summary.service].Icon;
---

<article class="status-service-row ui-shell px-5 py-4 md:px-6 md:py-5">
  <div
    class="flex flex-col gap-3 lg:grid lg:grid-cols-[minmax(0,15rem)_minmax(0,1fr)_minmax(0,11rem)_minmax(0,21rem)] lg:items-center lg:gap-5"
  >
    {
      serviceHref ? (
        <a
          href={serviceHref}
          class="group inline-flex items-center gap-3 self-start lg:self-auto"
        >
          <span
            class:list={[
              'inline-flex size-9 shrink-0 items-center justify-center rounded-full md:size-10',
              serviceMeta[summary.service].iconWrapClass,
            ]}
          >
            <ServiceIcon class="size-4 md:size-5" />
          </span>

          <div class="flex flex-col gap-1 lg:gap-0">
            <h3 class="text-lg font-semibold leading-tight tracking-tight text-foreground transition-colors group-hover:text-primary md:text-[1.1875rem]">
              {serviceLabel}
            </h3>
          </div>
        </a>
      ) : (
        <div class="flex items-center gap-3">
          <span
            class:list={[
              'inline-flex size-9 shrink-0 items-center justify-center rounded-full md:size-10',
              serviceMeta[summary.service].iconWrapClass,
            ]}
          >
            <ServiceIcon class="size-4 md:size-5" />
          </span>

          <div class="flex flex-col gap-1 lg:gap-0">
            <h3 class="text-lg font-semibold leading-tight tracking-tight text-foreground md:text-[1.1875rem]">
              {serviceLabel}
            </h3>
          </div>
        </div>
      )
    }

    <div class="flex flex-col gap-2 lg:gap-0">
      <StatusServiceTimeline
        service={summary.service}
        incidents={summary.incidents}
        timelineDays={timelineDays}
      />
    </div>

    <div>
      <p
        class:list={[
          'text-[0.9375rem] font-semibold leading-5',
          stateClass[summary.service_status],
        ]}
      >
        {stateLabel}
      </p>
    </div>

    <div class="hidden lg:block">
      <p
        class="text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-muted-foreground lg:hidden"
      >
        Последняя запись
      </p>

      {
        latestRecord ? (
          <div class="space-y-1">
            {latestRecord.has_page ? (
              <a
                href={latestRecord.url}
                class="site-inline-link block text-[0.9375rem] font-medium leading-[1.35] text-foreground"
              >
                {latestRecord.title}
              </a>
            ) : (
              <p class="text-[0.9375rem] font-medium leading-[1.35] text-foreground">
                {latestRecord.title}
              </p>
            )}
            {latestMoment && (
              <p class="text-[0.8125rem] leading-5 text-muted-foreground">
                {latestMoment}
              </p>
            )}
            {latestDuration && (
              <p class="text-[0.8125rem] leading-5 text-muted-foreground">
                Длительность: {latestDuration}
              </p>
            )}
          </div>
        ) : (
          <div class="space-y-1">
            <p class="text-[0.9375rem] leading-[1.35] text-foreground">
              Пока без записей по этому сервису
            </p>
            <p class="text-[0.8125rem] leading-5 text-muted-foreground">-</p>
          </div>
        )
      }
    </div>
  </div>
</article>
