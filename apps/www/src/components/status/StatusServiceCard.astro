---
import DamIcon from '@shelkovo/ui/icons/services/Dam.astro';
import FiberIcon from '@shelkovo/ui/icons/services/Fiber.astro';
import LightningIcon from '@shelkovo/ui/icons/services/Lightning.astro';
import WaterDropIcon from '@shelkovo/ui/icons/services/WaterDrop.astro';

import ShelkovoAreaIcon from '@/components/ShelkovoAreaIcon.astro';
import StatusServiceTimeline from './StatusServiceTimeline.astro';
import type { StatusServiceSummary } from '../../lib/status/types';
import {
  formatStatusDate,
  formatStatusDuration,
  formatStatusService,
  formatStatusServiceState,
} from '../../lib/status/view';

interface Props {
  readonly summary: StatusServiceSummary;
  readonly timelineDays?: number;
  readonly mobileTimelineDays?: number;
  readonly serviceHref?: string;
}

const {
  summary,
  timelineDays = 30,
  mobileTimelineDays,
  serviceHref,
} = Astro.props;

const serviceLabel = formatStatusService(summary.service);
const stateLabel = formatStatusServiceState(summary.serviceStatus);
const latestRecord = summary.incidents[0];
const latestMoment = latestRecord
  ? formatStatusDate(latestRecord.started.iso, {
      hasTime: latestRecord.started.hasTime,
      nonBreaking: true,
    })
  : undefined;
const latestDuration =
  latestRecord && !latestRecord.isActive && latestRecord.duration
    ? formatStatusDuration(latestRecord.duration, { nonBreaking: true })
    : undefined;
const latestAreas =
  latestRecord && !latestRecord.appliesToAllAreas ? latestRecord.areas : [];
const timelineIncidents = summary.incidents.map((incident) => ({
  id: incident.id,
  url: incident.url,
  hasPage: incident.hasPage,
  title: incident.title,
  kind: incident.kind,
  startedIso: incident.started.iso,
  startedHasTime: incident.started.hasTime,
  endedIso: incident.ended?.iso,
  endedHasTime: incident.ended?.hasTime ?? false,
  isActive: incident.isActive,
  areas: incident.appliesToAllAreas ? undefined : incident.areas,
  duration: incident.duration,
}));
const stateClass = {
  green: 'text-[color:var(--color-success)]',
  amber: 'text-[color:var(--color-warning-text)]',
  red: 'text-[color:var(--color-danger)]',
} as const;
const serviceMeta = {
  electricity: {
    Icon: LightningIcon,
    iconWrapClass:
      'bg-[color:var(--color-primary-soft)] text-[color:var(--color-primary)]',
  },
  water: {
    Icon: WaterDropIcon,
    iconWrapClass:
      'bg-[color:var(--color-water-soft)] text-[color:var(--color-water)]',
  },
  internet: {
    Icon: FiberIcon,
    iconWrapClass:
      'bg-[color:var(--color-unknown-soft)] text-[color:var(--color-unknown)]',
  },
  dam: {
    Icon: DamIcon,
    iconWrapClass:
      'bg-[color:var(--color-surface-muted)] text-[color:var(--color-earth)]',
  },
} as const;
const ServiceIcon = serviceMeta[summary.service].Icon;
const resolvedMobileTimelineDays = mobileTimelineDays ?? timelineDays;
const hasResponsiveTimeline = resolvedMobileTimelineDays !== timelineDays;
---

<article class="status-service-row ui-shell px-5 py-4 md:px-6 md:py-5">
  <div
    class="flex flex-col gap-3 lg:grid lg:grid-cols-[minmax(0,15rem)_minmax(0,1fr)_minmax(0,11rem)_minmax(0,21rem)] lg:items-center lg:gap-5"
  >
    {
      serviceHref ? (
        <a
          href={serviceHref}
          class="group inline-flex items-center gap-3 self-start lg:self-auto"
        >
          <span
            class:list={[
              'inline-flex size-9 shrink-0 items-center justify-center rounded-full md:size-10',
              serviceMeta[summary.service].iconWrapClass,
            ]}
          >
            <ServiceIcon class="size-4 md:size-5" />
          </span>

          <div class="flex flex-col gap-1 lg:gap-0">
            <h3 class="text-lg font-bold leading-tight tracking-tight text-foreground transition-colors group-hover:text-primary md:text-[1.1875rem]">
              {serviceLabel}
            </h3>
          </div>
        </a>
      ) : (
        <div class="flex items-center gap-3">
          <span
            class:list={[
              'inline-flex size-9 shrink-0 items-center justify-center rounded-full md:size-10',
              serviceMeta[summary.service].iconWrapClass,
            ]}
          >
            <ServiceIcon class="size-4 md:size-5" />
          </span>

          <div class="flex flex-col gap-1 lg:gap-0">
            <h3 class="text-lg font-bold leading-tight tracking-tight text-foreground md:text-[1.1875rem]">
              {serviceLabel}
            </h3>
          </div>
        </div>
      )
    }

    <div class="flex flex-col gap-2 lg:gap-0">
      {
        hasResponsiveTimeline ? (
          <>
            <div class="lg:hidden">
              <StatusServiceTimeline
                service={summary.service}
                incidents={timelineIncidents}
                timelineDays={resolvedMobileTimelineDays}
              />
            </div>

            <div class="hidden lg:block">
              <StatusServiceTimeline
                service={summary.service}
                incidents={timelineIncidents}
                timelineDays={timelineDays}
              />
            </div>
          </>
        ) : (
          <StatusServiceTimeline
            service={summary.service}
            incidents={timelineIncidents}
            timelineDays={timelineDays}
          />
        )
      }
    </div>

    <div>
      <p
        class:list={[
          'text-[0.9375rem] font-semibold leading-5',
          stateClass[summary.serviceStatus],
        ]}
      >
        {stateLabel}
      </p>
    </div>

    <div class="hidden lg:block">
      <p
        class="text-[0.68rem] font-semibold uppercase tracking-[0.06em] text-muted-foreground lg:hidden"
      >
        Последняя запись
      </p>

      {
        latestRecord ? (
          <div class="space-y-1">
            {latestRecord.hasPage ? (
              <a
                href={latestRecord.url}
                class="site-inline-link block text-[0.9375rem] font-medium leading-[1.35] text-foreground"
              >
                {latestRecord.title}
              </a>
            ) : (
              <p class="text-[0.9375rem] font-medium leading-[1.35] text-foreground">
                {latestRecord.title}
              </p>
            )}
            {(latestMoment || latestAreas.length > 0) && (
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.8125rem] leading-5 text-muted-foreground">
                {latestMoment && <span>{latestMoment}</span>}
                {latestAreas.map((area) => (
                  <ShelkovoAreaIcon area={area} />
                ))}
              </div>
            )}
            {latestDuration && (
              <p class="text-[0.8125rem] leading-5 text-muted-foreground">
                Длительность: {latestDuration}
              </p>
            )}
          </div>
        ) : (
          <div class="space-y-1">
            <p class="text-[0.9375rem] leading-[1.35] text-foreground">
              Пока без записей по этому сервису
            </p>
            <p class="text-[0.8125rem] leading-5 text-muted-foreground">-</p>
          </div>
        )
      }
    </div>
  </div>
</article>
