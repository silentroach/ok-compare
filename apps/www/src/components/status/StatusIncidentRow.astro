---
import AlertCircleIcon from '@shelkovo/ui/AlertCircleIcon.astro';
import CheckCircleIcon from '@shelkovo/ui/CheckCircleIcon.astro';

import type { StatusIncident } from '../../lib/status/schema';
import { renderNewsMarkdown } from '../../lib/news/html';
import StatusIncidentMeta from './StatusIncidentMeta.astro';

interface Props {
  readonly incident: StatusIncident;
}

const { incident } = Astro.props;

const excerptHtml = incident.excerpt
  ? renderNewsMarkdown(incident.excerpt)
  : undefined;
const rowStyle = incident.is_active
  ? incident.kind === 'maintenance'
    ? 'border-top-color: var(--color-warning-border); background: var(--color-warning-soft);'
    : 'border-top-color: var(--color-danger-border); background: var(--color-danger-soft);'
  : undefined;
const titleIcon =
  incident.kind !== 'incident'
    ? undefined
    : incident.is_active
      ? {
          Icon: AlertCircleIcon,
          toneClass: 'text-[color:var(--color-danger)]',
        }
      : incident.ended_iso
        ? {
            Icon: CheckCircleIcon,
            toneClass: 'text-[color:var(--color-success)]',
          }
        : undefined;
const TitleIcon = titleIcon?.Icon;
---

<article
  class="border-t border-border px-4 py-5 md:px-5 md:py-6"
  style={rowStyle}
>
  <div class="max-w-4xl space-y-3">
    <div class="space-y-2">
      <h3
        class="text-xl font-semibold tracking-tight text-foreground md:text-[1.55rem] md:leading-[1.15]"
      >
        <a
          href={incident.url}
          class="inline-flex items-start gap-2 site-inline-link"
        >
          {
            titleIcon && TitleIcon && (
              <span class:list={['mt-0.5 shrink-0', titleIcon.toneClass]}>
                <TitleIcon class="size-5" />
              </span>
            )
          }
          <span>{incident.title}</span>
        </a>
      </h3>

      <StatusIncidentMeta
        incident={incident}
        hideIncidentKind
        hideIncidentPhase
      />
    </div>

    {
      excerptHtml && (
        <div
          class="ui-copy max-w-3xl text-[0.975rem] text-muted-foreground [&_p]:my-0"
          set:html={excerptHtml}
        />
      )
    }
  </div>
</article>
