---
import TelegramIcon from '@shelkovo/ui/TelegramIcon.astro';

import type { StatusIncident } from '../../lib/status/schema';
import {
  formatStatusArea,
  formatStatusDate,
  formatStatusDuration,
  formatStatusKind,
  formatStatusService,
  getStatusIncidentPhase,
} from '../../lib/status/view';

interface Props {
  readonly incident: StatusIncident;
  readonly className?: string;
}

const { incident, className } = Astro.props;

const phase = getStatusIncidentPhase(incident);
const isTelegramSource =
  /^(?:tg:\/\/|(?:https?:\/\/)?(?:www\.)?(?:t\.me|telegram\.me)\/)/i.test(
    incident.source_url,
  );
const sourceTarget = isTelegramSource
  ? undefined
  : new URL(
      incident.source_url.startsWith('//')
        ? `https:${incident.source_url}`
        : incident.source_url,
    );
const sourceHost = isTelegramSource
  ? 'Telegram'
  : sourceTarget?.hostname.replace(/^www\./i, '') ||
    sourceTarget?.protocol.replace(/:$/, '');
const sourceLabel = sourceHost ? `Источник: ${sourceHost}` : 'Источник';
const showPhase = !incident.is_active;
const phaseClass = {
  danger: 'ui-badge-danger',
  warning: 'ui-badge-warning',
  success: 'ui-badge-success',
  muted: 'ui-badge-muted',
  info: 'ui-badge-info',
} as const;
const serviceClass =
  incident.service === 'water' ? 'ui-badge-water' : 'ui-badge-muted';
---

<div
  class:list={[
    'flex flex-wrap items-center gap-x-2.5 gap-y-2 text-sm leading-6 text-muted-foreground',
    className,
  ]}
>
  <span class:list={['ui-badge', serviceClass]}>
    {formatStatusService(incident.service)}
  </span>
  <span
    class:list={[
      'ui-badge',
      incident.kind === 'maintenance' ? 'ui-badge-warning' : 'ui-badge-muted',
    ]}
  >
    {formatStatusKind(incident.kind)}
  </span>
  {
    showPhase && (
      <span class:list={['ui-badge', phaseClass[phase.tone]]}>
        {phase.label}
      </span>
    )
  }

  <span>
    Начало{' '}
    <time datetime={incident.started_iso} class="font-medium text-foreground">
      {
        formatStatusDate(incident.started_iso, {
          hasTime: incident.started_has_time,
        })
      }
    </time>
  </span>

  {
    incident.ended_iso ? (
      <span>
        Завершение{' '}
        <time datetime={incident.ended_iso} class="font-medium text-foreground">
          {formatStatusDate(incident.ended_iso, {
            hasTime: incident.ended_has_time,
          })}
        </time>
      </span>
    ) : !incident.is_active ? (
      <span>Завершение не указано</span>
    ) : null
  }

  {
    incident.duration && (
      <span>
        Длительность{' '}
        <span class="font-medium text-foreground">
          {formatStatusDuration(incident.duration)}
        </span>
      </span>
    )
  }

  {
    !incident.applies_to_all_areas &&
      incident.areas.map((area) => (
        <span class="ui-chip">{formatStatusArea(area)}</span>
      ))
  }

  <a
    href={incident.source_url}
    target="_blank"
    rel="noreferrer noopener"
    aria-label={sourceLabel}
    class:list={[
      'ui-link font-medium',
      isTelegramSource && 'inline-flex items-center gap-1',
    ]}
  >
    {
      isTelegramSource && (
        <TelegramIcon class="size-3.5 shrink-0 text-primary" />
      )
    }
    <span>источник</span>
  </a>
</div>
