---
import '@shelkovo/ui/styles.css';
import '@/styles/site.css';

import StatusServiceTimeline from '@/components/status/StatusServiceTimeline.astro';
import type { StatusTimelineIncidentInput } from '@/lib/status/timeline';

const fixedNowIso = '2026-05-10T12:00:00Z';
const fixedNowMs = Date.parse(fixedNowIso);

// The component uses Date.now() during SSR, so the fixture freezes build time too.
Date.now = () => fixedNowMs;

const mixedIncidents: readonly StatusTimelineIncidentInput[] = [
  {
    id: 'mixed-maintenance',
    url: '/status/water/#mixed-maintenance',
    title: 'Промывка магистрали',
    kind: 'maintenance',
    started_iso: '2026-05-02T03:00:00Z',
    started_has_time: true,
    ended_iso: '2026-05-02T12:00:00Z',
    ended_has_time: true,
    is_active: false,
    duration: {
      total_minutes: 540,
    },
  },
  {
    id: 'mixed-incident',
    url: '/status/water/#mixed-incident',
    title: 'Аварийное отключение воды',
    kind: 'incident',
    started_iso: '2026-05-06T08:15:00Z',
    started_has_time: true,
    ended_iso: '2026-05-06T16:45:00Z',
    ended_has_time: true,
    is_active: false,
    duration: {
      total_minutes: 510,
    },
  },
];

const emptyIncidents: readonly StatusTimelineIncidentInput[] = [];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Status timeline visual fixture</title>
    <script
      is:inline
      set:html={`window.__STATUS_TIMELINE_NOW__ = ${JSON.stringify(fixedNowMs)};`}
    />
  </head>
  <body class="ui-root-site status-timeline-visual-page">
    <main
      class="status-timeline-visual-shell"
      data-testid="status-timeline-visual"
    >
      <section class="status-timeline-visual-card">
        <p class="status-timeline-visual-label">Mixed timeline</p>
        <div
          class="status-timeline-visual-target status-timeline-visual-target--tooltip"
          data-testid="status-timeline-mixed"
        >
          <StatusServiceTimeline
            service="water"
            incidents={mixedIncidents}
            timelineDays={10}
          />
        </div>
      </section>

      <section class="status-timeline-visual-card">
        <p class="status-timeline-visual-label">No incidents</p>
        <div
          class="status-timeline-visual-target"
          data-testid="status-timeline-empty"
        >
          <StatusServiceTimeline
            service="water"
            incidents={emptyIncidents}
            timelineDays={10}
          />
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .status-timeline-visual-page {
    min-height: 100vh;
    margin: 0;
    background:
      radial-gradient(circle at top, oklch(97% 0.012 145) 0, transparent 44%),
      linear-gradient(180deg, oklch(98% 0.008 140), oklch(95% 0.012 140));
    color: var(--color-text);
  }

  .status-timeline-visual-shell {
    display: grid;
    gap: 1.5rem;
    width: min(100%, 64rem);
    margin: 0 auto;
    padding: 3rem;
  }

  .status-timeline-visual-card {
    display: grid;
    gap: 0.75rem;
  }

  .status-timeline-visual-label {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .status-timeline-visual-target {
    width: 52rem;
    max-width: 100%;
    padding: 1rem 1rem 1.1rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 88%, white 12%);
    border-radius: 1.5rem;
    background: color-mix(in oklab, white 82%, var(--color-bg) 18%);
    box-shadow: 0 1.2rem 2.6rem oklch(22% 0.03 145 / 0.08);
    overflow: clip;
  }

  .status-timeline-visual-target--tooltip {
    padding-bottom: 5.2rem;
  }
</style>
