---
import '@styles/global.css';
import { collectKeywords, imageMimeType, serializeSchema } from '@shelkovo/seo';
import type { SchemaDoc } from '@shelkovo/seo';
import SiteFooter from '@shelkovo/ui/SiteFooter.astro';
import TelegramIcon from '@shelkovo/ui/icons/system/Telegram.astro';
import { browserColor, themeColor } from '@shelkovo/ui/theme';
import { COMPARE_KEYWORDS } from '@lib/seo';
import { canon } from '@lib/site';
import { withBase } from '@lib/url';

interface Props {
  title?: string;
  description?: string;
  keywords?: string | string[];
  robots?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: string;
  schema?: SchemaDoc | readonly SchemaDoc[];
}

const {
  title = 'Шелково Сравнение — тарифы, инфраструктура и обслуживание поселков',
  description = 'Сравнение тарифов, инфраструктуры и сервисов коттеджных поселков рядом с Шелково в Московской области.',
  keywords,
  robots,
  canonical: href,
  image,
  imageAlt,
  type = 'website',
  schema,
} = Astro.props;

const canonical = canon(href ?? Astro.url.pathname);
const keywordContent = collectKeywords(keywords, COMPARE_KEYWORDS).join(', ');
const social = image ? canon(withBase(image)) : undefined;
const socialAlt = social ? (imageAlt ?? title) : undefined;
const socialType = social ? imageMimeType(social) : undefined;
const docs = serializeSchema(schema);
const prod = import.meta.env.PROD;
const section = import.meta.env.SITE === 'https://kpshelkovo.online';
const ymId = section ? 108975391 : 108465472;
const ymInit = section
  ? '{ssr:true,clickmap:true,referrer:document.referrer,url:location.href,accurateTrackBounce:true,trackLinks:true}'
  : "{ssr:true,webvisor:true,clickmap:true,ecommerce:'dataLayer',referrer:document.referrer,url:location.href,accurateTrackBounce:true,trackLinks:true}";
const ym = `(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,'script','https://mc.yandex.ru/metrika/tag.js?id=${ymId}','ym');ym(${ymId},'init',${ymInit});`;
---

<!doctype html>
<html lang="ru" data-ym-id={String(ymId)}>
  <head>
    <base href={import.meta.env.BASE_URL} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="theme-color"
      content={themeColor.light}
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content={themeColor.dark}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="description" content={description} />
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content="Сравни с Шелково" />
    <meta name="apple-mobile-web-app-title" content="Шелково" />
    <meta name="msapplication-TileColor" content={browserColor.tile} />
    <meta name="msapplication-TileImage" content="/mstile-150x150.png" />
    <link rel="canonical" href={canonical} />
    {robots && <meta name="robots" content={robots} />}

    <link rel="preconnect" href="https://mc.yandex.ru" />
    <link rel="preconnect" href="https://api-maps.yandex.ru" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="mask-icon"
      href="/safari-pinned-tab.svg"
      color={browserColor.mask}
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Сравни с Шелково" />
    {social && <meta property="og:image" content={social} />}
    {socialAlt && <meta property="og:image:alt" content={socialAlt} />}
    {social && <meta property="og:image:width" content="1200" />}
    {social && <meta property="og:image:height" content="630" />}
    {socialType && <meta property="og:image:type" content={socialType} />}

    <meta
      name="twitter:card"
      content={social ? 'summary_large_image' : 'summary'}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {social && <meta name="twitter:image" content={social} />}
    {socialAlt && <meta name="twitter:image:alt" content={socialAlt} />}

    <title>{title}</title>

    {docs.map((item) => <script type="application/ld+json" set:html={item} />)}

    {prod && <script is:inline type="text/javascript" set:html={ym} />}
    {!section && <script>import '@lib/ymGoal.js';</script>}
  </head>
  <body class="flex min-h-screen flex-col text-foreground">
    {
      prod && (
        <noscript>
          <div>
            <img
              src={`https://mc.yandex.ru/watch/${ymId}`}
              style="position:absolute; left:-9999px;"
              alt=""
            />
          </div>
        </noscript>
      )
    }
    <div class="flex-1">
      <slot />
    </div>

    <SiteFooter>
      <p slot="right">
        Если нашли неточность или у вас есть данные про другие поселки &mdash;
        напишите
        <a
          href="https://t.me/silentroach"
          target="_blank"
          rel="noreferrer"
          aria-label="Написать в Telegram silentroach"
          class="ui-link whitespace-nowrap font-medium text-foreground"
        >
          <TelegramIcon
            class="mr-1 inline-block size-3.5 align-middle text-primary"
          />
          <span>silentroach</span>
        </a>
      </p>
    </SiteFooter>
  </body>
</html>
