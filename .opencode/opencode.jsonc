{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "astro": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp"
    },
    "sveltejs": {
      "type": "local",
      "command": ["npx", "-y", "@sveltejs/mcp"],
      "enabled": true
    }
  }
}
