{
  "name": "@shelkovo/ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test:visual:breadcrumbs": "playwright test -c playwright.breadcrumbs-visual.local.config.ts",
    "test:visual:breadcrumbs:update": "playwright test -c playwright.breadcrumbs-visual.local.config.ts --update-snapshots",
    "test:visual:breadcrumbs:serve": "node ../../scripts/check-port.mjs 4325 && astro build --root tests/breadcrumbs-visual && astro preview --root tests/breadcrumbs-visual --host 127.0.0.1 --port 4325"
  },
  "exports": {
    "./Breadcrumbs.astro": "./src/Breadcrumbs.astro",
    "./FontPreloads.astro": "./src/FontPreloads.astro",
    "./icons/areas/Forest.astro": "./src/icons/areas/Forest.astro",
    "./icons/areas/Park.astro": "./src/icons/areas/Park.astro",
    "./icons/areas/River.astro": "./src/icons/areas/River.astro",
    "./icons/areas/Village.astro": "./src/icons/areas/Village.astro",
    "./icons/services/Dam.astro": "./src/icons/services/Dam.astro",
    "./icons/services/Lightning.astro": "./src/icons/services/Lightning.astro",
    "./icons/services/WaterDrop.astro": "./src/icons/services/WaterDrop.astro",
    "./icons/system/AlertCircle.astro": "./src/icons/system/AlertCircle.astro",
    "./icons/system/CheckCircle.astro": "./src/icons/system/CheckCircle.astro",
    "./icons/system/Phone.astro": "./src/icons/system/Phone.astro",
    "./icons/system/Star.astro": "./src/icons/system/Star.astro",
    "./icons/system/Telegram.astro": "./src/icons/system/Telegram.astro",
    "./theme": "./src/theme.ts",
    "./Link.svelte": "./src/Link.svelte",
    "./SiteFooter.astro": "./src/SiteFooter.astro",
    "./styles.css": "./styles.css",
    "./icons/system/Domyland.astro": "./src/icons/system/Domyland.astro",
    "./LinkWithIcon.astro": "./src/LinkWithIcon.astro"
  },
  "dependencies": {
    "@fontsource/fira-sans": "^5.2.7",
    "@fontsource/pt-sans-caption": "^5.2.8",
    "@shelkovo/url": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.1.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
