---
import '@shelkovo/ui/styles.css';
import {
  AlertCircleIcon,
  CalendarPlusIcon,
  CheckCircleIcon,
  DamIcon,
  DomylandIcon,
  EmailIcon,
  FiberIcon,
  FilePdfIcon,
  ForestIcon,
  GlobeIcon,
  LightningIcon,
  MapPinIcon,
  ParkIcon,
  PhoneIcon,
  RiverIcon,
  StarIcon,
  TelegramIcon,
  VillageIcon,
  WaterDropIcon,
  WhatsAppIcon,
} from '@shelkovo/ui/icons';

const standaloneGroups = [
  {
    label: 'Территории',
    icons: [
      { name: 'ForestIcon', Icon: ForestIcon, wide: true },
      { name: 'ParkIcon', Icon: ParkIcon, wide: true },
      { name: 'RiverIcon', Icon: RiverIcon, wide: true },
      { name: 'VillageIcon', Icon: VillageIcon, wide: true },
    ],
  },
  {
    label: 'Сервисы',
    icons: [
      { name: 'DamIcon', Icon: DamIcon, wide: false },
      { name: 'FiberIcon', Icon: FiberIcon, wide: false },
      { name: 'LightningIcon', Icon: LightningIcon, wide: false },
      { name: 'WaterDropIcon', Icon: WaterDropIcon, wide: false },
    ],
  },
  {
    label: 'Состояния и действия',
    icons: [
      { name: 'AlertCircleIcon', Icon: AlertCircleIcon, wide: false },
      { name: 'CalendarPlusIcon', Icon: CalendarPlusIcon, wide: false },
      { name: 'CheckCircleIcon', Icon: CheckCircleIcon, wide: false },
      { name: 'StarIcon', Icon: StarIcon, wide: false },
    ],
  },
] as const;

const linkIcons = [
  {
    name: 'DomylandIcon',
    label: 'Домиленд',
    href: '#domyland',
    Icon: DomylandIcon,
  },
  {
    name: 'EmailIcon',
    label: 'Электронная почта',
    href: '#email',
    Icon: EmailIcon,
  },
  {
    name: 'FilePdfIcon',
    label: 'PDF-документ',
    href: '#pdf',
    Icon: FilePdfIcon,
  },
  {
    name: 'GlobeIcon',
    label: 'Сайт',
    href: '#website',
    Icon: GlobeIcon,
  },
  {
    name: 'MapPinIcon',
    label: 'Яндекс Карты',
    href: '#map',
    Icon: MapPinIcon,
  },
  {
    name: 'PhoneIcon',
    label: '+7 999 123-45-67',
    href: '#phone',
    Icon: PhoneIcon,
  },
  {
    name: 'TelegramIcon',
    label: 'Telegram',
    href: '#telegram',
    Icon: TelegramIcon,
  },
  {
    name: 'WhatsAppIcon',
    label: 'WhatsApp',
    href: '#whatsapp',
    Icon: WhatsAppIcon,
  },
] as const;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Каталог иконок</title>
  </head>
  <body class="ui-root-site icons-visual-page">
    <main class="icons-visual-shell" data-testid="icons-catalog">
      <header class="icons-visual-header">
        <h1>Каталог иконок</h1>
        <p>Самостоятельные иконки и примеры ссылок в рабочем размере.</p>
      </header>

      <section class="icons-visual-section" aria-labelledby="standalone-icons">
        <div class="icons-visual-section-heading">
          <h2 id="standalone-icons">Самостоятельные иконки</h2>
          <p>Иконка и имя компонента</p>
        </div>

        <div class="icons-visual-groups">
          {
            standaloneGroups.map((group) => (
              <section
                class="icons-visual-group"
                aria-labelledby={`icons-${group.label}`}
              >
                <h3 id={`icons-${group.label}`}>{group.label}</h3>
                <ul class="icons-visual-list">
                  {group.icons.map(({ name, Icon, wide }) => (
                    <li
                      class="icons-visual-item"
                      data-icon-item
                      data-icon-name={name}
                    >
                      <Icon
                        class:list={[
                          'icons-visual-icon',
                          wide && 'icons-visual-icon--wide',
                        ]}
                      />
                      <span>{name}</span>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <section class="icons-visual-section" aria-labelledby="link-icons">
        <div class="icons-visual-section-heading">
          <h2 id="link-icons">Иконки в ссылках</h2>
          <p>Ссылка с привычной подписью и имя компонента</p>
        </div>

        <ul class="icons-visual-links">
          {
            linkIcons.map(({ name, label, href, Icon }) => (
              <li data-icon-item data-icon-name={name}>
                <a href={href} class="icons-visual-link">
                  <Icon class="icons-visual-icon" />
                  <span>{label}</span>
                  <small>{name}</small>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  .icons-visual-page {
    min-height: 100vh;
    margin: 0;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .icons-visual-shell {
    display: grid;
    gap: 2.5rem;
    width: min(calc(100% - 2rem), 64rem);
    margin: 0 auto;
    padding-block: 3rem;
  }

  .icons-visual-header,
  .icons-visual-section,
  .icons-visual-section-heading,
  .icons-visual-group {
    display: grid;
  }

  .icons-visual-header {
    gap: 0.5rem;
  }

  .icons-visual-header h1,
  .icons-visual-header p,
  .icons-visual-section-heading h2,
  .icons-visual-section-heading p,
  .icons-visual-group h3 {
    margin: 0;
  }

  .icons-visual-header h1 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    line-height: 1.1;
  }

  .icons-visual-header p,
  .icons-visual-section-heading p {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .icons-visual-section {
    gap: 1.25rem;
  }

  .icons-visual-section-heading {
    gap: 0.25rem;
  }

  .icons-visual-section-heading h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .icons-visual-section-heading p {
    font-size: 0.875rem;
  }

  .icons-visual-groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 2rem;
  }

  .icons-visual-group {
    gap: 0.625rem;
  }

  .icons-visual-group h3 {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .icons-visual-list,
  .icons-visual-links {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .icons-visual-list,
  .icons-visual-links {
    border-top: 1px solid var(--color-border);
  }

  .icons-visual-item,
  .icons-visual-links li {
    border-bottom: 1px solid var(--color-border);
  }

  .icons-visual-item {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    gap: 1rem;
  }

  .icons-visual-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 2rem;
  }

  .icons-visual-link {
    display: grid;
    min-height: 4rem;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
    text-decoration-color: color-mix(in oklab, currentColor 35%, transparent);
    text-underline-offset: 0.2em;
  }

  .icons-visual-link:hover {
    color: var(--color-primary-hover);
    text-decoration-color: currentColor;
  }

  .icons-visual-link small {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 400;
  }

  :global(.icons-visual-icon) {
    width: 1.5rem;
    height: 1.5rem;
    flex: none;
    color: var(--color-primary);
  }

  :global(.icons-visual-icon--wide) {
    width: 2.75rem;
  }

  .icons-visual-links
    li[data-icon-name='TelegramIcon']
    :global(.icons-visual-icon) {
    color: var(--color-telegram);
  }

  .icons-visual-links
    li[data-icon-name='WhatsAppIcon']
    :global(.icons-visual-icon) {
    color: var(--color-whatsapp);
  }

  .icons-visual-item[data-icon-name='StarIcon'] :global(.icons-visual-icon) {
    color: var(--color-star);
  }

  .icons-visual-item[data-icon-name='WaterDropIcon']
    :global(.icons-visual-icon) {
    color: var(--color-water);
  }

  @media (max-width: 44rem) {
    .icons-visual-groups,
    .icons-visual-links {
      grid-template-columns: 1fr;
    }
  }
</style>
