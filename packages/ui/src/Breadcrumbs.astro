---
interface Item {
  readonly label: string;
  readonly href?: string;
}

interface Props {
  readonly items: readonly Item[];
  readonly linkLast?: boolean;
}

const { items, linkLast = false } = Astro.props;
---

{
  items.length > 0 && (
    <nav aria-label="Хлебные крошки">
      <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-sm text-muted-foreground md:gap-x-2">
        {items.map((item, index) => (
          <li class="flex items-center gap-1.5 md:gap-2">
            {index > 0 && <span aria-hidden="true">›</span>}
            {item.href && (linkLast || index < items.length - 1) ? (
              <a href={item.href} class="ui-link font-medium">
                {item.label}
              </a>
            ) : (
              <span
                class="font-medium text-foreground"
                aria-current={index === items.length - 1 ? 'page' : undefined}
              >
                {item.label}
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )
}
