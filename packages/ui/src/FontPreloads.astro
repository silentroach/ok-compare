---
import firaSansCyrillic400 from '@fontsource/fira-sans/files/fira-sans-cyrillic-400-normal.woff2';
import ptSansCaptionCyrillic700 from '@fontsource/pt-sans-caption/files/pt-sans-caption-cyrillic-700-normal.woff2';

const fonts = [firaSansCyrillic400, ptSansCaptionCyrillic700] as const;
---

{
  fonts.map((href) => (
    <link
      rel="preload"
      href={href}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  ))
}
