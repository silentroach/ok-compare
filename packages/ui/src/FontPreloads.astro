---
import firaSansCyrillic400 from '@fontsource/fira-sans/files/fira-sans-cyrillic-400-normal.woff2';
import ptSerifCyrillic700 from '@fontsource/pt-serif/files/pt-serif-cyrillic-700-normal.woff2';

const fonts = [firaSansCyrillic400, ptSerifCyrillic700] as const;
---

{
  fonts.map((href) => (
    <link
      rel="preload"
      href={href}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  ))
}
