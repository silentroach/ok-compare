---
interface Props {
  year?: number;
}

const { year = new Date().getFullYear() } = Astro.props;
const hasRight = Astro.slots.has('right');
---

<footer class="ui-page ui-site-footer">
  <div class="ui-site-footer-inner">
    <p>
      &copy; {year}. Инициативная группа{' '}
      <a href="https://kpshelkovo.online/" class="ui-link ui-site-footer-home">
        Шелково
      </a>
    </p>

    {
      hasRight && (
        <div class="ui-site-footer-side">
          <slot name="right" />
        </div>
      )
    }
  </div>
</footer>
