---
interface Props {
  readonly class?: string;
}

const { class: className }: Props = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <rect x="3.8" y="5.8" width="16.4" height="12.4" rx="2.2"></rect>
  <path d="m5 7.4 7 5.3 7-5.3"></path>
</svg>
