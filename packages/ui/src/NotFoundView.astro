---
import { getImage } from 'astro:assets';
import logo from './assets/logo.png';

interface Props {
  readonly title: string;
  readonly homeHref: string;
  readonly homeLabel: string;
  readonly description?: string;
  readonly fullHeight?: boolean;
}

const {
  title,
  homeHref,
  homeLabel,
  description,
  fullHeight = false,
} = Astro.props;
const logoWidths = [448, 672, 896] as const;
const logoImages = await Promise.all(
  logoWidths.map((width) =>
    getImage({ src: logo, width, format: 'webp', quality: 90 }),
  ),
);
const logoSrc = logoImages[logoImages.length - 1]?.src ?? logo.src;
const logoSrcset = logoImages
  .map((image, index) => `${image.src} ${logoWidths[index]}w`)
  .join(', ');
---

<main class:list={['not-found', { 'not-found--full-height': fullHeight }]}>
  <section aria-labelledby="not-found-title">
    <img
      src={logoSrc}
      srcset={logoSrcset}
      sizes="(max-width: 40rem) 92vw, 28rem"
      alt="Логотип Шелково"
      width={logo.width}
      height={logo.height}
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <h1 id="not-found-title">{title}</h1>
    {description && <p>{description}</p>}
    <a href={homeHref}>{homeLabel}</a>
  </section>
</main>

<style>
  .not-found {
    display: grid;
    box-sizing: border-box;
    min-height: calc(100dvh - 4rem);
    place-items: center;
    padding: 4rem 1.25rem;
    color: oklch(24% 0.04 145);
    text-align: center;
    background:
      radial-gradient(
        circle at 50% 28%,
        color-mix(in oklab, oklch(95.3% 0.045 82) 72%, transparent),
        transparent 24rem
      ),
      radial-gradient(
        circle at 50% 68%,
        color-mix(in oklab, oklch(96.5% 0.014 140) 74%, transparent),
        transparent 19rem
      ),
      rgb(252 250 246);
  }

  .not-found--full-height {
    min-height: 100dvh;
  }

  section {
    display: flex;
    width: 100%;
    max-width: 64rem;
    flex-direction: column;
    align-items: center;
  }

  img {
    width: min(28rem, 86vw);
    height: auto;
    mix-blend-mode: darken;
  }

  h1 {
    max-width: 42rem;
    margin: 1.75rem 0 0;
    font-family: 'PT Serif', Georgia, serif;
    font-size: clamp(2.25rem, 8vw, 3rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }

  p {
    max-width: 36rem;
    margin: 1rem 0 0;
    color: oklch(46% 0.02 135);
    font-family: 'Fira Sans', system-ui, sans-serif;
    font-size: 1.0625rem;
    line-height: 1.7;
    text-wrap: pretty;
  }

  a {
    margin-top: 1.75rem;
    color: oklch(36% 0.115 143);
    font-family: 'Fira Sans', system-ui, sans-serif;
    font-weight: 600;
    text-decoration-color: oklch(36% 0.115 143 / 0.45);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
  }

  a:hover {
    color: oklch(30% 0.105 143);
    text-decoration-color: currentColor;
  }

  a:focus-visible {
    border-radius: 0.15rem;
    outline: 0.2rem solid oklch(83% 0.155 78);
    outline-offset: 0.25rem;
  }

  @media (max-width: 40rem) {
    img {
      width: min(22rem, 92vw);
    }
  }
</style>
