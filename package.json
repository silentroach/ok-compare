{
  "name": "shelkovo-compare",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "clean": "rm -rf dist apps/www/dist apps/www/.astro node_modules/.astro",
    "dev": "turbo run dev",
    "start": "pnpm dev",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:changed": "lint-staged",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "postinstall": "node scripts/hooks.mjs"
  },
  "lint-staged": {
    "*.{astro,svelte,js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,yaml,yml,css,html}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.1",
    "@fontsource/fira-sans": "^5.2.7",
    "@fontsource/pt-sans-caption": "^5.2.8",
    "@shelkovo/format": "workspace:*",
    "@shelkovo/geo": "workspace:*",
    "@shelkovo/markdown": "workspace:*",
    "@shelkovo/ui": "workspace:*",
    "@shelkovo/url": "workspace:*",
    "astro": "^6.3.7",
    "svelte": "^5.55.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@yandex/ymaps3-types": "^1.0.19724900",
    "astro-compressor": "^1.3.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.0",
    "skills": "^1.5.9",
    "tailwindcss": "^4.3.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
