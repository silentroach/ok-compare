{
  "name": "shelkovo-compare",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "vite": "^7"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "pnpm build:pages",
    "build:pages": "astro build --mode pages",
    "build:vps": "BUILD_TARGET=vps ASTRO_BASE=/ ASTRO_COMPRESS=1 astro build --mode pages",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro sync && tsc --noEmit",
    "format": "prettier --write .",
    "format:changed": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/hooks.mjs"
  },
  "lint-staged": {
    "*.{astro,svelte,js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,yaml,yml,css,html}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.0.4",
    "@fontsource/fira-sans": "^5.2.7",
    "@fontsource/pt-sans-caption": "^5.2.8",
    "astro": "^6.1.3",
    "luxon": "^3.6.1",
    "svelte": "^5.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/luxon": "^3.6.2",
    "@yandex/ymaps3-types": "^1.0.19072130",
    "astro-compressor": "^1.3.0",
    "happy-dom": "^20.8.9",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
