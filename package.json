{
  "name": "shelkovo-compare",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "clean": "rm -rf dist apps/www/dist apps/www/.astro node_modules/.astro",
    "dev": "turbo run dev",
    "start": "pnpm dev",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:changed": "lint-staged",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "postinstall": "node scripts/hooks.mjs"
  },
  "lint-staged": {
    "*.{astro,svelte,js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,yaml,yml,css,html}": "prettier --write"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@yandex/ymaps3-types": "^1.0.19917650",
    "astro-compressor": "^1.3.0",
    "happy-dom": "^20.10.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.0",
    "skills": "^1.5.10",
    "tailwindcss": "^4.3.0",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
