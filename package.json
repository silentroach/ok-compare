{
  "name": "shelkovo-compare",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "vite": "^7"
    }
  },
  "scripts": {
    "clean": "rm -rf dist apps/compare/dist apps/www/dist node_modules/.astro apps/compare/.astro apps/www/.astro",
    "prebuild": "pnpm run clean",
    "predev": "pnpm run clean",
    "dev": "turbo run dev --filter=@shelkovo/www --filter=@shelkovo/compare",
    "dev:compare": "turbo run dev --filter=@shelkovo/compare",
    "dev:www": "turbo run dev --filter=@shelkovo/www",
    "start": "pnpm dev",
    "build": "pnpm run build:main && pnpm run build:legacy",
    "build:main": "turbo run build --filter=@shelkovo/www && turbo run build:section --filter=@shelkovo/compare && node scripts/compose-www.mjs",
    "build:legacy": "turbo run build:legacy --filter=@shelkovo/compare && node scripts/compose-legacy.mjs",
    "preview": "pnpm --dir apps/www exec astro preview",
    "preview:compare": "pnpm --dir apps/compare exec astro preview",
    "typecheck": "turbo run typecheck --filter=@shelkovo/www --filter=@shelkovo/compare",
    "format": "prettier --write .",
    "format:changed": "lint-staged",
    "test": "turbo run test --filter=@shelkovo/www --filter=@shelkovo/compare",
    "test:watch": "pnpm --dir apps/compare exec vitest",
    "postinstall": "node scripts/hooks.mjs"
  },
  "lint-staged": {
    "*.{astro,svelte,js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,yaml,yml,css,html}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.0.4",
    "@fontsource/fira-sans": "^5.2.7",
    "@fontsource/pt-sans-caption": "^5.2.8",
    "@shelkovo/format": "workspace:*",
    "@shelkovo/geo": "workspace:*",
    "@shelkovo/ui": "workspace:*",
    "@shelkovo/url": "workspace:*",
    "astro": "^6.1.6",
    "svelte": "^5.55.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@yandex/ymaps3-types": "^1.0.19287993",
    "astro-compressor": "^1.3.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "tailwindcss": "^4.0.0",
    "turbo": "^2.9.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
