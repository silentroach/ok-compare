{
  "name": "shelkovo-compare",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "vite": "^7"
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules/.astro/data-store.json .astro",
    "prebuild": "pnpm run clean",
    "predev": "pnpm run clean",
    "dev": "turbo run dev:app",
    "dev:app": "astro dev",
    "start": "pnpm dev",
    "build": "turbo run build:app",
    "build:app": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "turbo run typecheck:app",
    "typecheck:app": "astro sync && tsc --noEmit",
    "format": "prettier --write .",
    "format:changed": "lint-staged",
    "test": "turbo run test:app",
    "test:app": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/hooks.mjs"
  },
  "lint-staged": {
    "*.{astro,svelte,js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,yaml,yml,css,html}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.0.4",
    "@fontsource/fira-sans": "^5.2.7",
    "@fontsource/pt-sans-caption": "^5.2.8",
    "@shelkovo/format": "workspace:*",
    "@shelkovo/geo": "workspace:*",
    "@shelkovo/ui": "workspace:*",
    "@shelkovo/url": "workspace:*",
    "astro": "^6.1.6",
    "svelte": "^5.55.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@yandex/ymaps3-types": "^1.0.19072130",
    "astro-compressor": "^1.3.0",
    "happy-dom": "^20.8.9",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "tailwindcss": "^4.0.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  }
}
