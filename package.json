{
  "name": "shelkovo-compare",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro sync && tsc --noEmit",
    "format": "prettier --write .",
    "format:changed": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/hooks.mjs"
  },
  "lint-staged": {
    "*.{astro,svelte,js,jsx,ts,tsx,mjs,cjs,mts,cts,json,md,yaml,yml,css,html}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.0.3",
    "astro": "^6.0.8",
    "luxon": "^3.6.1",
    "svelte": "^5.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/luxon": "^3.6.2",
    "@yandex/ymaps3-types": "^1.0.19072130",
    "happy-dom": "^20.8.9",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
