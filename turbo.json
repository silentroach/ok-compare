{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "globalDependencies": [
    ".env*",
    "apps/*/.env*",
    "packages/*/package.json",
    "packages/*/src/**",
    "packages/*/styles.css"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "outputs": []
    }
  }
}
