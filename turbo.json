{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env*", "apps/*/.env*"],
  "tasks": {
    "build": {
      "outputs": ["dist/site/**"]
    },
    "build:section": {
      "outputs": ["dist/section/**"]
    },
    "build:legacy": {
      "outputs": ["dist/legacy/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
