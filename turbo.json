{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!playwright*.config.*",
        "!vitest.config.*",
        "!vitest.*.setup.*",
        "!**/*.test.*",
        "!**/*.spec.*",
        "!tests/**",
        "!**/__snapshots__/**",
        "!**/*-snapshots/**"
      ]
    },
    "build": {
      "dependsOn": ["^build", "transit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.env*",
        "!playwright*.config.*",
        "!vitest.config.*",
        "!vitest.*.setup.*",
        "!**/*.test.*",
        "!**/*.spec.*",
        "!tests/**",
        "!**/__snapshots__/**",
        "!**/*-snapshots/**"
      ],
      "env": ["PUBLIC_YANDEX_MAPS_API_KEY", "LIGHTHOUSE_DISABLE_ANALYTICS"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!playwright*.config.*",
        "!vitest.config.*",
        "!vitest.*.setup.*",
        "!**/*.test.*",
        "!**/*.spec.*",
        "!tests/**",
        "!**/__snapshots__/**",
        "!**/*-snapshots/**"
      ],
      "outputs": []
    }
  }
}
