---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Link from '../../components/Link.astro';
import { loadAllData, findBaseline } from '../../lib/data';
import { formatCurrency, formatTariff, formatDistance, formatPercentage, calculateDistance } from '../../lib/format';
import type { Settlement } from '../../lib/schema';
import InfrastructureTable from '../../components/InfrastructureTable.svelte';
import ServiceTable from '../../components/ServiceTable.svelte';
import SourcesList from '../../components/SourcesList.svelte';

// Generate static paths for all settlements
export async function getStaticPaths() {
  const { settlements, comparisons } = await loadAllData();
  const shelkovo = findBaseline(settlements);
  
  return settlements.map((settlement) => ({
    params: { slug: settlement.slug },
    props: { 
      settlement,
      comparison: comparisons.get(settlement.slug),
      shelkovo: shelkovo || null
    },
  }));
}

interface Props {
  settlement: Settlement;
  comparison: {
    tariffDelta: number;
    tariffDeltaPercent: number;
    isCheaper: boolean;
    infrastructureDelta: Record<string, number>;
    servicesDelta: Record<string, number>;
    transparencyDelta: Record<string, number>;
  } | undefined;
  shelkovo: Settlement | null;
}

const { settlement, comparison, shelkovo } = Astro.props;

// Calculate distance from Shelkovo
const distanceFromShelkovo = shelkovo && !settlement.is_baseline
  ? calculateDistance(
      shelkovo.location.lat,
      shelkovo.location.lng,
      settlement.location.lat,
      settlement.location.lng
    )
  : 0;

// Build page title
const pageTitle = `${settlement.name} — Тарифы и сравнение`;
---

<BaseLayout title={pageTitle}>
  <main class="ui-page py-6 md:py-10">
    <header class="ui-shell-strong mb-6 p-6 md:mb-8 md:p-8">
      <div class="mb-4 flex items-center gap-3">
        <Link href="/" class="ui-link text-sm font-semibold">
          ← Назад к списку
        </Link>
      </div>
      
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div>
          <div class="mb-2 flex items-center gap-3">
            <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">
              {settlement.name}
            </h1>
            <div class="flex items-center gap-2">
              {settlement.website && (
                <a
                  href={settlement.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Открыть сайт поселка"
                  class="rounded-md p-1 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700"
                  title="Перейти на сайт поселка"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                </a>
              )}
              <a
                href={settlement.location.map_url ?? `https://yandex.ru/maps/?pt=${settlement.location.lng},${settlement.location.lat}&z=15&l=map`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Открыть поселок на Яндекс.Картах"
                class="rounded-md p-1 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700"
                title="Открыть на Яндекс.Картах"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </a>
            </div>
          </div>
          <p class="text-slate-600">
            {settlement.location.district} район
          </p>
        </div>
        
        {settlement.is_baseline && (
          <span class="inline-flex items-center rounded-full border border-sky-200 bg-sky-100 px-3 py-1 text-sm font-semibold text-sky-800">
            Наш посёлок
          </span>
        )}
      </div>
    </header>

    <section class="ui-shell mb-6 p-6 md:mb-8" data-testid="base-info-section">
      <h2 class="mb-6 text-xl font-semibold text-slate-900">Основная информация</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">Тариф на обслуживание</h3>
          <div class="text-3xl font-bold text-slate-900">
            {formatTariff(settlement.tariff.normalized_per_sotka_month)}
          </div>
          {settlement.tariff.note && (
            <p class="mt-1 text-sm text-slate-500">{settlement.tariff.note}</p>
          )}
        </div>
        
        {!settlement.is_baseline && comparison && (
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">Сравнение с Шелково</h3>
            <div class={`text-2xl font-bold ${comparison.isCheaper ? 'text-emerald-700' : 'text-amber-700'}`}>
              {comparison.isCheaper ? '−' : '+'}{formatCurrency(Math.abs(comparison.tariffDelta))}
            </div>
            <p class="mt-1 text-sm text-slate-600">
              {comparison.isCheaper ? 'Дешевле' : 'Дороже'} Шелково на {formatPercentage(comparison.tariffDeltaPercent / 100)}
            </p>
          </div>
        )}
        
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 md:col-span-2">
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-500">Расположение</h3>
          <p class="text-slate-900">{settlement.location.address_text}</p>
          {distanceFromShelkovo > 0 && (
            <p class="mt-1 text-sm text-slate-500">
              {formatDistance(distanceFromShelkovo)} от Шелково
            </p>
          )}
        </div>
      </div>
    </section>

    <section class="ui-shell mb-6 p-6 md:mb-8" data-testid="infrastructure-section">
      <h2 class="mb-5 text-xl font-semibold text-slate-900">Инфраструктура</h2>
      <InfrastructureTable 
        infra={settlement.infrastructure} 
        shelkovoInfra={!settlement.is_baseline ? shelkovo?.infrastructure || null : null}
      />
    </section>

    <section class="ui-shell mb-6 p-6 md:mb-8" data-testid="services-section">
      <h2 class="mb-5 text-xl font-semibold text-slate-900">Модель обслуживания</h2>
      <ServiceTable 
        services={settlement.service_model} 
        shelkovoServices={!settlement.is_baseline ? shelkovo?.service_model || null : null}
      />
    </section>

    {settlement.sources.length > 0 && (
      <section class="ui-shell mb-6 p-6 md:mb-8" data-testid="sources-section">
        <h2 class="mb-4 text-xl font-semibold text-slate-900">Источники</h2>
        <SourcesList sources={settlement.sources} />
      </section>
    )}
  </main>
</BaseLayout>
