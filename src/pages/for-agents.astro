---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllData } from '../lib/data';
import { CATALOG, EXPLORER, FEED, OPENAPI, SCHEMA } from '../lib/discovery';
import { withBase } from '../lib/url';

const { settlements } = await loadAllData();
const picks = [
  settlements.find((item) => item.is_baseline),
  ...settlements
    .filter((item) => !item.is_baseline)
    .sort((a, b) => a.short_name.localeCompare(b.short_name, 'ru'))
    .slice(0, 2),
].filter((item): item is (typeof settlements)[number] => Boolean(item));

const title = 'Для агентов: полный feed поселков';
const description =
  'Краткая документация по data/settlements.json: где лежит полный feed поселков, чем он отличается от data/explorer.json и где найти schema, OpenAPI и API catalog.';
const root = Astro.site ?? Astro.url.origin;
const page = new URL(withBase('/for-agents/'), root).toString();
const schema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  name: title,
  description,
  url: page,
  inLanguage: 'ru-RU',
};

const refs = [
  {
    href: withBase(FEED),
    label: FEED,
    note: 'Основной полный feed только для чтения со всеми подтвержденными полями, рейтингом и агрегатами.',
  },
  {
    href: withBase(EXPLORER),
    label: EXPLORER,
    note: 'Облегченный feed для главной, списка и карты, когда важен минимальный payload.',
  },
  {
    href: withBase(SCHEMA),
    label: SCHEMA,
    note: 'JSON Schema для реального ответа feed.',
  },
  {
    href: withBase(OPENAPI),
    label: OPENAPI,
    note: 'OpenAPI 3.1-обертка вокруг одного маршрута только для чтения.',
  },
  {
    href: withBase(CATALOG),
    label: '/.well-known/api-catalog',
    note: 'Linkset JSON для автоматического обнаружения API.',
  },
  {
    href: withBase('/rating/'),
    label: '/rating/',
    note: 'Публичное объяснение того, как считается условный рейтинг.',
  },
];

const uses = [
  'получить все подтвержденные поля поселка одним запросом без обхода detail-страниц',
  'брать slug, website, telegram, sources, полный location и полный tariff',
  'строить карту по location.lat и location.lng и сразу иметь контекст по инфраструктуре и сервисам',
  'сравнивать тариф и рейтинг пакетно по всему списку',
  'использовать comparisons[slug] для сравнения с Шелково',
  'использовать один feed как основной discovery-слой для агентов',
];

const light = [
  'когда нужен самый короткий payload для списка, карты или массовой первичной выборки',
  'когда достаточно short_name, slug, rating, координат и нормализованного тарифа',
  'когда нужно повторить поведение главной страницы, которая сама читает data/explorer.json',
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <main class="ui-page py-6 md:py-10 lg:py-12">
    <section class="ui-shell-strong overflow-hidden p-6 md:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_22rem] lg:gap-10">
        <div class="space-y-5">
          <div class="flex flex-wrap gap-2">
            <span class="ui-chip">Feed</span>
            <span class="ui-chip">JSON Schema</span>
            <span class="ui-chip">API Catalog</span>
          </div>

          <div class="space-y-3">
            <h1
              class="text-4xl font-bold tracking-tight text-foreground md:text-5xl md:leading-[1.08]"
            >
              Полный JSON feed для машинного чтения
            </h1>
            <p class="ui-copy max-w-3xl text-muted-foreground">
              <a href={withBase(FEED)} class="ui-link font-semibold">
                <code>data/settlements.json</code>
              </a>
              {' '}это стабильный полный feed только для чтения для discovery,
              массового сравнения и обхода всей базы.{' '}
              <a href={withBase(EXPLORER)} class="ui-link font-semibold">
                <code>data/explorer.json</code>
              </a>
              {' '}остается облегченной версией для главной, списка и карты.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div
              class="rounded-2xl border border-border bg-white/60 p-5 backdrop-blur-[2px]"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
              >
                Структура
              </p>
              <ul
                class="mt-3 space-y-2 text-sm leading-7 text-muted-foreground"
              >
                <li>
                  <code>settlements[]</code> — полные карточки поселков с rating и
                  подтвержденными полями
                </li>
                <li><code>stats</code> — агрегаты по тарифам и размеру базы</li>
                <li>
                  <code>comparisons</code> — сравнение по slug относительно Шелково
                </li>
              </ul>
            </div>

            <div
              class="rounded-2xl border border-info-border bg-info-soft/70 p-5"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.18em] text-info-text/80"
              >
                Ограничение
              </p>
              <p class="mt-3 text-sm leading-7 text-info-text">
                Отсутствие поля обычно означает «неизвестно», а не «точно нет».
                Детальные HTML- и Markdown-страницы все еще полезны как
                каноническое человекочитаемое представление по одному slug.
              </p>
            </div>
          </div>
        </div>

        <aside class="space-y-4">
          <div
            class="rounded-[1.35rem] border border-white/55 bg-white/68 p-5 shadow-[0_18px_40px_-26px_rgba(15,23,42,0.35)] backdrop-blur-md"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Ключевые URL
            </p>
            <ul class="mt-4 space-y-3">
              {
                refs.map((item) => (
                  <li class="rounded-xl border border-border/70 bg-card/85 px-4 py-3">
                    <a href={item.href} class="ui-link text-sm font-semibold">
                      {item.label}
                    </a>
                    <p class="mt-1 text-xs leading-5 text-muted-foreground">
                      {item.note}
                    </p>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <div
      class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start"
    >
      <div class="space-y-6">
        <section class="ui-shell p-6 md:p-7">
          <div class="max-w-3xl space-y-4">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Для чего подходит
            </p>
            <h2
              class="text-2xl font-semibold leading-tight text-foreground md:text-[2rem] md:leading-[1.15]"
            >
              Один запрос вместо обхода карточек
            </h2>
            <ul
              class="space-y-2 text-sm leading-7 text-muted-foreground md:text-base"
            >
              {uses.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>

        <section class="ui-shell p-6 md:p-7">
          <div class="max-w-3xl space-y-4">
            <p
              class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
            >
              Когда все еще нужен explorer
            </p>
            <h2
              class="text-2xl font-semibold leading-tight text-foreground md:text-[2rem] md:leading-[1.15]"
            >
              Облегченный feed оставлен для списка и карты
            </h2>
            <ul
              class="space-y-2 text-sm leading-7 text-muted-foreground md:text-base"
            >
              {light.map((item) => <li>{item}</li>)}
            </ul>
            <p class="ui-copy text-muted-foreground">
              Для агентного discovery лучше начинать с полного feed выше, а
              data/explorer.json использовать только когда важен минимальный
              размер ответа.
            </p>
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="ui-shell p-5">
          <p
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Детальные страницы
          </p>
          <p class="mt-3 text-sm leading-7 text-muted-foreground">
            Шаблон маршрута: <code>/settlements/[slug]/</code>. Используйте его,
            когда нужна каноническая HTML- или Markdown-страница по одному slug.
          </p>
          <ul class="mt-4 space-y-2 text-sm leading-6 text-muted-foreground">
            {
              picks.map((item) => (
                <li>
                  <a
                    href={withBase(`/settlements/${item.slug}/`)}
                    class="ui-link font-medium"
                  >
                    {item.short_name}
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="ui-shell p-5">
          <p
            class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
          >
            Когда нужен рейтинг
          </p>
          <p class="mt-3 text-sm leading-7 text-muted-foreground">
            Поле <code>rating</code> уже сериализовано как число <code
              >0..100</code
            >
            и в полном feed, и в explorer feed, а полная методика описана на{
              ' '
            }
            <a href={withBase('/rating/')} class="ui-link font-medium">
              странице рейтинга
            </a>
            .
          </p>
        </section>
      </aside>
    </div>
  </main>
</BaseLayout>
