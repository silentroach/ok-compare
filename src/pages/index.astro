---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.svelte';
import KPIStats from '../components/KPIStats.svelte';
import SettlementCard from '../components/SettlementCard.svelte';
import SettlementsExplorer from '../components/SettlementsExplorer.svelte';
import { loadAllData } from '../lib/data';

// Load all data at build time
const { settlements, stats, comparisons } = await loadAllData();

// Convert comparisons Map to a plain object for serialization
const comparisonsObj = Object.fromEntries(comparisons);
const dataUrl = `${import.meta.env.BASE_URL}data/explorer.json`;

const cards = [...settlements].sort((a, b) => {
	const d = a.tariff.normalized_per_sotka_month - b.tariff.normalized_per_sotka_month;
	if (d !== 0) return d;
	return a.short_name.localeCompare(b.short_name, 'ru');
});

const base = cards.findIndex((s) => s.is_baseline);
if (base > 0) {
	const item = cards.splice(base, 1)[0];
	cards.unshift(item);
}
---

<BaseLayout>
	<main class="container mx-auto px-4 py-8 max-w-6xl">
		<Hero 
			title="Тарифы на содержание поселков"
		/>

		{/* Временно скрыто: вернем плашки, когда данных станет больше */}
		{false && <KPIStats stats={stats} />}

		<section id="settlements" class="space-y-6">
			<SettlementsExplorer dataUrl={dataUrl} client:only="svelte" />

			<div id="settlements-static">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{cards.map((settlement) => (
						<SettlementCard
							settlement={settlement}
							comparison={comparisonsObj[settlement.slug] || null}
							maxTariff={stats.maxTariff}
							isBaseline={settlement.is_baseline}
						/>
					))}
				</div>
			</div>

			<script is:inline>
				window.addEventListener('explorer:ready', () => {
					const fallback = document.getElementById('settlements-static');
					if (fallback) fallback.style.display = 'none';
				});
			</script>
		</section>
	</main>
</BaseLayout>
