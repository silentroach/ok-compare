---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.svelte';
import KPIStats from '../components/KPIStats.svelte';
import SettlementsExplorer from '../components/SettlementsExplorer.svelte';
import SettlementMap from '../components/SettlementMap.svelte';
import { loadAllData } from '../lib/data';

// Load all data at build time
const { settlements, stats, comparisons } = await loadAllData();

// Convert comparisons Map to a plain object for serialization
const comparisonsObj = Object.fromEntries(comparisons);

// Prepare map data from settlements
const mapData = settlements.map(s => ({
  slug: s.slug,
  name: s.name,
  lat: s.location.lat,
  lng: s.location.lng,
  normalizedTariff: s.tariff.normalized_per_sotka_month,
  isBaseline: s.is_baseline,
}));
---

<BaseLayout>
	<main class="container mx-auto px-4 py-8 max-w-6xl">
		<!-- Hero Section -->
		<Hero 
			title="Сравнение тарифов на содержание коттеджных поселков"
			subtitle="Анализ стоимости обслуживания в Истринском районе Московской области"
		/>

		<!-- KPI Stats Section -->
		<KPIStats stats={stats} />

		<!-- Interactive Map Section -->
		<section id="map" class="mb-12">
			<h2 class="text-2xl font-bold text-gray-900 mb-4">Карта поселков</h2>
			<p class="text-gray-600 mb-6">Кликните на маркер для просмотра деталей</p>
			
			<SettlementMap 
				settlements={mapData}
				client:visible
			/>
		</section>

		<!-- Settlements Explorer with filters -->
		<section id="settlements">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">Коттеджные посёлки</h2>
			
			<SettlementsExplorer 
				settlements={settlements}
				comparisons={comparisonsObj}
				stats={stats}
				client:visible
			/>
		</section>
	</main>
</BaseLayout>
