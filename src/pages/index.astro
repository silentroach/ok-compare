---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.svelte';
import KPIStats from '../components/KPIStats.svelte';
import SettlementsExplorer from '../components/SettlementsExplorer.svelte';
import { loadAllData } from '../lib/data';

// Load all data at build time
const { settlements, stats, comparisons } = await loadAllData();

// Convert comparisons Map to a plain object for serialization
const comparisonsObj = Object.fromEntries(comparisons);

const cards = [...settlements].sort((a, b) => {
	const d = a.tariff.normalized_per_sotka_month - b.tariff.normalized_per_sotka_month;
	if (d !== 0) return d;
	return a.short_name.localeCompare(b.short_name, 'ru');
});

const base = cards.findIndex((s) => s.is_baseline);
if (base > 0) {
	const item = cards.splice(base, 1)[0];
	cards.unshift(item);
}
---

<BaseLayout>
	<main class="ui-page py-6 md:py-10">
		<Hero
			title="Тарифы на содержание поселков"
			subtitle="Структурированное сравнение поселков по цене, инфраструктуре и сервисам с опорой на проверяемые источники."
		>
			<KPIStats stats={stats} embed />
		</Hero>

		<section id="settlements" class="mt-6 space-y-6 md:mt-8">
			<SettlementsExplorer
				settlements={cards}
				comparisons={comparisonsObj}
				stats={stats}
				client:idle
			/>
		</section>
	</main>
</BaseLayout>
