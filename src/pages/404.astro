---
import BaseLayout from '../layouts/BaseLayout.astro';
import Link from '../components/Link.astro';

const title = 'Страница не найдена — Шелково Сравнение';
---

<BaseLayout title={title}>
  <main class="container mx-auto px-4 py-16 text-center max-w-2xl">
    <div class="mb-8">
      <h1 class="text-6xl font-bold text-gray-300 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-gray-900 mb-4">
        Страница не найдена
      </h2>
      <p class="text-gray-600 mb-8">
        Запрашиваемая страница не существует или была перемещена.
      </p>
    </div>
    
    <div class="space-y-4">
      <Link 
        href="/" 
        class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
      >
        На главную
      </Link>
      
      <div class="text-sm text-gray-500">
        <p>Или посмотрите <Link href="/" class="text-blue-600 hover:text-blue-800">список всех посёлков</Link></p>
      </div>
    </div>
  </main>
</BaseLayout>
