---
import '../styles/global.css';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  robots?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'Шелково Сравнение — Сравнение тарифов на обслуживание коттеджных поселков',
  description = 'Сравнение тарифов на обслуживание коттеджных поселков в Истринском районе. Прозрачные данные о стоимости услуг управляющих компаний.',
  robots,
  canonical: href,
  image,
  imageAlt,
  type = 'website',
  schema,
} = Astro.props;

const root = Astro.site ?? Astro.url.origin;
const canonical = new URL(href ?? Astro.url.pathname, root).toString();
const social = image ? new URL(withBase(image), root).toString() : undefined;
const socialAlt = social ? (imageAlt ?? title) : undefined;
const socialType = !social
  ? undefined
  : social.endsWith('.svg')
    ? 'image/svg+xml'
    : social.endsWith('.png')
      ? 'image/png'
      : undefined;
const docs = (schema ? (Array.isArray(schema) ? schema : [schema]) : []).map(
  (item) => JSON.stringify(item).replace(/</g, '\\u003c'),
);
const year = new Date().getFullYear();
const prod = import.meta.env.PROD;
const ymId = 108465472;
const ym = `(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,'script','https://mc.yandex.ru/metrika/tag.js?id=${ymId}','ym');ym(${ymId},'init',{ssr:true,webvisor:true,clickmap:true,ecommerce:'dataLayer',referrer:document.referrer,url:location.href,accurateTrackBounce:true,trackLinks:true});`;
---

<!doctype html>
<html lang="ru">
  <head>
    <base href={import.meta.env.BASE_URL} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="theme-color"
      content="#edf3f7"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1b222b"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content="Сравни с Шелково" />
    <meta name="apple-mobile-web-app-title" content="Шелково" />
    <meta name="msapplication-TileColor" content="#dceeff" />
    <link rel="canonical" href={canonical} />
    {robots && <meta name="robots" content={robots} />}

    <link
      rel="icon"
      type="image/svg+xml"
      href={withBase('favicon.svg')}
      sizes="any"
    />
    <link rel="icon" type="image/x-icon" href={withBase('favicon.ico')} />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={withBase('favicon-32x32.png')}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={withBase('favicon-16x16.png')}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={withBase('apple-touch-icon.png')}
    />
    <link rel="manifest" href={withBase('site.webmanifest')} />
    <link
      rel="mask-icon"
      href={withBase('safari-pinned-tab.svg')}
      color="#8a5a36"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Сравни с Шелково" />
    {social && <meta property="og:image" content={social} />}
    {socialAlt && <meta property="og:image:alt" content={socialAlt} />}
    {social && <meta property="og:image:width" content="1200" />}
    {social && <meta property="og:image:height" content="630" />}
    {socialType && <meta property="og:image:type" content={socialType} />}

    <meta
      name="twitter:card"
      content={social ? 'summary_large_image' : 'summary'}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {social && <meta name="twitter:image" content={social} />}
    {socialAlt && <meta name="twitter:image:alt" content={socialAlt} />}

    <title>{title}</title>

    {docs.map((item) => <script type="application/ld+json" set:html={item} />)}

    {prod && <script is:inline type="text/javascript" set:html={ym} />}
    {prod && <script>import '../lib/ymGoal.js';</script>}
  </head>
  <body class="min-h-screen text-foreground">
    {
      prod && (
        <noscript>
          <div>
            <img
              src={`https://mc.yandex.ru/watch/${ymId}`}
              style="position:absolute; left:-9999px;"
              alt=""
            />
          </div>
        </noscript>
      )
    }
    <slot />

    <footer
      class="ui-page mt-6 border-t border-border/80 py-4 text-xs text-muted-foreground md:mt-8 md:py-5"
    >
      <div
        class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between md:gap-4"
      >
        <p>
          &copy; {year}. Инициативная группа{' '}
          <a
            href="https://шелково.рф"
            class="ui-link font-medium text-foreground"
          >
            Шелково
          </a>
        </p>

        <p class="text-left md:text-right">
          Если нашли неточность или у вас есть данные про другие поселки &mdash;
          напишите
          <a
            href="https://t.me/silentroach"
            target="_blank"
            rel="noreferrer"
            aria-label="Написать в Telegram silentroach"
            class="ui-link whitespace-nowrap font-medium text-foreground"
          >
            <svg
              viewBox="0 0 24 24"
              class="mr-1 inline-block size-3.5 align-middle text-primary"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M21.5 4.5c.4-.2.9.1.8.6l-3 14.3c-.1.5-.7.8-1.1.5l-4.6-3.4-2.4 2.3c-.3.3-.8.1-.8-.3v-3.2l8.1-7.4c.2-.2 0-.5-.2-.4l-9.8 6.2-4.2-1.4c-.5-.2-.6-.9-.1-1.1l16.3-6.7Z"
              ></path>
            </svg>
            <span>silentroach</span>
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
